{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Starter log-search view over EDEN service logs ingested into Loki (issue #110). One logs panel scoped by the service / level template variables; extend it in Grafana's Explore view.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "eden-loki" },
      "description": "Every EDEN service log line matching the selected services + levels. Records carry the JSON context fields (decision_type, task_id, variant_id, …) inline; expand a line to see them.",
      "gridPos": { "h": 24, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "eden-loki" },
          "editorMode": "code",
          "expr": "{experiment_id=~\"$experiment_id\", service=~\"$service\", level=~\"$level\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "EDEN service logs",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["eden"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "loki", "uid": "eden-loki" },
        "allValue": ".*",
        "definition": "label_values(experiment_id)",
        "includeAll": true,
        "label": "experiment_id",
        "multi": true,
        "name": "experiment_id",
        "options": [],
        "query": { "label": "experiment_id", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "", "type": 1 },
        "refresh": 2,
        "regex": "",
        "type": "query"
      },
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "loki", "uid": "eden-loki" },
        "allValue": ".+",
        "definition": "label_values(service)",
        "includeAll": true,
        "label": "service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": { "label": "service", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "", "type": 1 },
        "refresh": 2,
        "regex": "",
        "type": "query"
      },
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "loki", "uid": "eden-loki" },
        "allValue": ".*",
        "definition": "label_values(level)",
        "includeAll": true,
        "label": "level",
        "multi": true,
        "name": "level",
        "options": [],
        "query": { "label": "level", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "", "type": 1 },
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "EDEN explore",
  "uid": "eden-explore",
  "version": 1,
  "weekStart": ""
}
