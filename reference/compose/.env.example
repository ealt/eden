# EDEN reference Compose stack — example environment.
# Copy to ".env" for local use; "docker compose up" reads from .env automatically.
# CI uses these defaults verbatim; do NOT use these in production.
#
# In normal use, do NOT edit .env by hand; instead run
# `reference/scripts/setup-experiment/setup-experiment.sh <config>
# --experiment-id <id>` which generates the per-experiment .env with
# fresh secrets and the right paths. This file documents what a fully
# populated .env looks like.

# --- Postgres ---
POSTGRES_DB=eden
POSTGRES_USER=eden
POSTGRES_PASSWORD=eden-dev-password-change-me
POSTGRES_HOST_PORT=5433

# --- Forgejo ---
# SECRET_KEY: Forgejo uses this for cookie / CSRF / 2FA encryption.
# Generate with: forgejo generate secret SECRET_KEY  (or 64 hex chars).
FORGEJO_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcd
# INTERNAL_TOKEN: Forgejo uses this for inter-component auth.
FORGEJO_INTERNAL_TOKEN=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcd
FORGEJO_HOST_PORT=3001
FORGEJO_SSH_HOST_PORT=2222
# Per-experiment HTTP password for the workers' git operations.
FORGEJO_REMOTE_PASSWORD=eden-dev-forgejo-password-change-me
# In-network URL the workers use to clone/push.
FORGEJO_REMOTE_URL=http://forgejo:3000/eden/${EDEN_EXPERIMENT_ID}.git
# Host-accessible URL surfaced in the implementer UI for users to clone.
# Embeds HTTP Basic credentials so `git clone` works directly (issue #161,
# local-demo posture). Override for deployments where rendering the
# password in the UI is unacceptable.
FORGEJO_CLONE_URL_HOST=http://eden:${FORGEJO_REMOTE_PASSWORD}@localhost:${FORGEJO_HOST_PORT}/eden/${EDEN_EXPERIMENT_ID}.git

# --- Task store / web UI ports ---
WEB_UI_HOST_PORT=8090
TASK_STORE_HOST_PORT=8080

# --- Log search UI (Loki/Alloy/Grafana overlay, issue #110) ---
# Used only by `compose.logging.yaml` (opt-in:
#   docker compose -f compose.yaml -f compose.logging.yaml up -d).
# setup-experiment.sh always generates EDEN_GRAFANA_ADMIN_PASSWORD and
# creates the loki/ + alloy/ data-root subdirs, so the overlay works
# against any bootstrapped stack with no extra setup flag. Both are
# negligible when the overlay isn't used.
# Grafana admin password (sign in as user `admin`). Generated fresh by
# setup-experiment; the value below is the .env.example placeholder.
EDEN_GRAFANA_ADMIN_PASSWORD=eden-dev-grafana-password-change-me
# Host port for the Grafana UI. 3000 is Grafana's well-known port;
# override on a local collision.
GRAFANA_HOST_PORT=3000
# Required ONLY for the optional infra-stdout overlay
# (compose.logging-infra.yaml): the gid of /var/run/docker.sock as seen
# FROM INSIDE A CONTAINER (probe-from-inside, NOT host-side stat). The
# default file-tail overlay does NOT need it. Probe with:
#   docker run --rm -v /var/run/docker.sock:/var/run/docker.sock \
#     alpine:3.20 stat -c '%g' /var/run/docker.sock
# EDEN_LOGGING_DOCKER_GID=

# --- Substrate data root (Phase 12a-1g) ---
# Host-side parent directory under which every durable substrate
# (postgres data, forgejo data, artifacts, per-host bare clones, and
# per-host worker credentials) is bind-mounted. setup-experiment.sh
# resolves this to an absolute path and writes it here; do NOT
# hand-edit to a path containing $HOME or ~ (compose does not shell-
# expand those). Default: $HOME/.eden/experiments/$EDEN_EXPERIMENT_ID.
# Override with `setup-experiment.sh --data-root <path>` if you want
# substrates to live somewhere else (e.g. on a backed-up volume).
# Disk failure or explicit `rm -rf` of this directory destroys the
# experiment; see docs/operations/experiment-data-durability.md.
EDEN_EXPERIMENT_DATA_ROOT=

# --- Experiment identity + secrets ---
EDEN_EXPERIMENT_ID=manual-ui
# Set by setup-experiment after seeding the bare repo.
EDEN_BASE_COMMIT_SHA=0000000000000000000000000000000000000000
# Deployment admin token (chapter 07 §13). The task-store-server
# accepts ``Authorization: Bearer admin:<this>`` for admin-gated
# operations (register_worker, reissue_credential, etc.). Each
# worker host reads this at startup to bootstrap its per-worker
# credential — see plan §D.1 / §8.2 + the
# eden_service_common.auth.bootstrap_worker_credential flow.
EDEN_ADMIN_TOKEN=eden-dev-admin-token-change-me
# Web UI session-cookie signing key.
EDEN_SESSION_SECRET=eden-dev-session-secret-change-me
# Postgres connection URL the task-store-server uses.
EDEN_STORE_URL=postgresql://eden:eden-dev-password-change-me@postgres:5432/eden

# --- Ideation policy (issue #133) ---
# The orchestrator reads the ideation policy from the experiment
# config's `ideation_policy` block (see
# spec/v0/schemas/experiment-config.schema.json). Smoke scripts that
# want a fixed-total budget add a block like:
#   ideation_policy: { kind: fixed_total, total: 3 }
# directly to the YAML before bringing the stack up. When the block
# is absent the orchestrator defaults to maintain_pending(target=3).

# Termination policy (issue #157). The single-experiment orchestrator
# reads its termination policy from the experiment config's
# `termination_policy` block (see
# spec/v0/schemas/experiment-config.schema.json + docs/operations/
# experiment-lifecycle.md). The retired EDEN_TERMINATION_POLICY /
# EDEN_TERMINATION_MAX_VARIANTS env vars are gone; smoke scripts inject a
# block like `termination_policy: { kind: max_variants, target: 200 }`
# into the YAML when a policy is wanted. Absent block → never_terminate.

# Worker id the auto-orchestrator registers under at startup.
# Multi-replica deployments override per-replica (auto-orchestrator-1,
# auto-orchestrator-2, …) — each replica MUST hold a unique id; the
# `_ensure_orchestrators_membership` helper adds the id to the
# `orchestrators` group on every startup (idempotent).
EDEN_ORCHESTRATOR_WORKER_ID=orchestrator
# Initial admin worker seeded into the `admins` group by
# setup-experiment.sh. Operators acting through the web UI authenticate
# as this worker (or any other admin you've added later); it's the
# only principal that can drive reassign_task / update_dispatch_mode /
# create_task(kind=execution) under the wave-3 authority gates.
EDEN_ADMINS_INITIAL_MEMBER=operator
# Worker_id under which the web-ui authenticates against the
# task-store-server. setup-experiment.sh pre-registers this worker and
# adds it to the `admins` group, so the /admin/dispatch-mode/ and
# /admin/tasks/{T}/reassign routes have the §3.7 admins-gated authority
# they need. Per-user session bearers are a deferred follow-up; until
# then the web-ui acts as a single deployment-level admin principal.
EDEN_WEB_UI_WORKER_ID=web-ui-1
EDEN_IDEAS_PER_IDEATION=1
# Quiescence budget (issue #157): iterations of zero progress before the
# single-experiment orchestrator declares the experiment done. This is
# now the experiment-config `max_quiescent_iterations` field, NOT an env
# var — the retired EDEN_MAX_QUIESCENT_ITERATIONS is gone. Each iteration
# is one --poll-interval (1.0s by default), so 30 = 30s of stall
# tolerance. Smoke scripts inject `max_quiescent_iterations: 30` into the
# YAML; manual-UI sessions where a human is drafting / claiming at human
# speed should set a much higher value (e.g., 36000 ≈ 10h). See GitHub
# issue #98 (the structural fix is deferred to Phase 12c control plane).

# --- Subprocess / docker-exec mode (chunk 10d / 10d-followup-A) ---
# Host paths bind-mounted into the worker hosts. setup-experiment
# fills these from --experiment-dir; required only when running with
# compose.subprocess.yaml or compose.docker-exec.yaml overlays.
EDEN_EXPERIMENT_DIR_HOST=
EDEN_FORGEJO_CREDS_DIR_HOST=
# Docker-exec mode (compose.docker-exec.yaml) only:
EDEN_EXEC_IMAGE=eden-runtime:dev
EDEN_DOCKER_GID=
EDEN_CIDFILES_DIR_HOST=
