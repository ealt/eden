#!/usr/bin/env python3
"""eden-manual — operator CLI for manual-UI sessions.

Drives the ideator / executor / evaluator roles end-to-end against
the EDEN reference Compose stack via the task-store-server wire (no
web-UI session cookies required). Reads ``reference/compose/.env`` for
the admin token, experiment id, gitea creds, and host ports.

Post-12a-1 auth: admin operations use ``admin:$EDEN_ADMIN_TOKEN``;
worker-gated operations (claim / submit / create_idea /
mark_idea_ready / create_variant) use a per-worker bearer
``<worker_id>:<credential>`` persisted at
``/tmp/eden-manual/.credentials.json`` (mode 0600). Workers are
registered lazily on first use.

Subcommands:

    list-tasks [--kind ...] [--state ...]
    show <task-id>                    — full task context
    list-commits                      — base + integrated variant SHAs
    creds                             — gitea URL with creds embedded

    claim <task-id> [--worker-id W] [--ttl-seconds N]
                                      — claim a task; persists the
                                        worker_id in /tmp/eden-manual/.claims.json
    checkout <task-id> [--dest D]     — clone gitea + check out the
                                        right ref
    push <workdir> [--branch B] [--message M]
                                      — git add -A + commit + push

    ideation-submit <task-id> --ideas-file F   (or --status error)
    execution-submit <task-id> --sha SHA [--description D] (or --status error)
    evaluation-submit <task-id> --field K=V [--field K=V ...] (or --status evaluation_error|error)

The claim/submit subcommands talk to the wire directly and bypass the
web-UI's session/CSRF layer, but produce identical store state.
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import urllib.error
import urllib.parse
import urllib.request
import uuid
from datetime import UTC, datetime, timedelta
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[3]
COMPOSE_DIR = REPO_ROOT / "reference" / "compose"
ENV_FILE = COMPOSE_DIR / ".env"
WORK_ROOT = Path(os.environ.get("EDEN_MANUAL_WORK_ROOT", "/tmp/eden-manual"))
CLAIMS_FILE = WORK_ROOT / ".claims.json"
CREDENTIALS_FILE = WORK_ROOT / ".credentials.json"
ARTIFACTS_DIR = WORK_ROOT / "artifacts"


# ---------------------------------------------------------------- env / wire

def _load_env() -> dict[str, str]:
    if not ENV_FILE.is_file():
        sys.exit(f"error: {ENV_FILE} not found — run setup-experiment.sh first")
    env: dict[str, str] = {}
    for line in ENV_FILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        env[k.strip()] = v.strip()
    required = (
        "EDEN_EXPERIMENT_ID",
        "EDEN_ADMIN_TOKEN",
        "GITEA_HOST_PORT",
        "GITEA_REMOTE_PASSWORD",
    )
    missing = [k for k in required if k not in env]
    if missing:
        sys.exit(f"error: missing keys in {ENV_FILE}: {', '.join(missing)}")
    return env


def _wire(
    env: dict[str, str],
    path: str,
    *,
    method: str = "GET",
    body: object = None,
    bearer: str | None = None,
    swallow_401: bool = False,
):
    """Call the task-store wire API.

    The bearer defaults to ``admin:<EDEN_ADMIN_TOKEN>`` (spec chapter
    07 §13). Worker-gated endpoints (claim / submit / create_idea /
    mark_idea_ready / create_variant) MUST use a worker bearer —
    pass ``bearer="<worker_id>:<credential>"``.

    ``swallow_401``: when True, return None on HTTP 401 instead of
    sys.exit. Used by the ``/whoami`` verify path in
    ``_worker_bearer`` to fall through to the register-or-reissue
    recovery branch. All other non-2xx responses still trigger
    sys.exit.
    """
    port = env.get("TASK_STORE_HOST_PORT", "8080")
    url = f"http://localhost:{port}{path}"
    data = None
    if bearer is None:
        bearer = f"admin:{env['EDEN_ADMIN_TOKEN']}"
    headers = {
        "Authorization": f"Bearer {bearer}",
        "X-Eden-Experiment-Id": env["EDEN_EXPERIMENT_ID"],
    }
    if body is not None:
        data = json.dumps(body).encode()
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req) as resp:
            raw = resp.read()
    except urllib.error.HTTPError as e:
        if swallow_401 and e.code == 401:
            return None
        sys.exit(f"wire error {e.code} on {method} {path}: {e.read().decode()[:400]}")
    if not raw:
        return None
    return json.loads(raw)


def _exp(env: dict[str, str]) -> str:
    return env["EDEN_EXPERIMENT_ID"]


# ------------------------------------------------------- worker credentials

def _read_credentials() -> dict[str, str]:
    # Corrupt-state recovery: parse / shape failures (truncated file,
    # invalid JSON, non-object value) are treated as cold-start so
    # the register-or-reissue ladder can rebuild the entry.
    if not CREDENTIALS_FILE.is_file():
        return {}
    try:
        raw = json.loads(CREDENTIALS_FILE.read_text())
    except (OSError, json.JSONDecodeError) as e:
        print(
            f"warning: {CREDENTIALS_FILE} is unreadable ({e}); ignoring and recovering",
            file=sys.stderr,
        )
        return {}
    if not isinstance(raw, dict):
        print(
            f"warning: {CREDENTIALS_FILE} is not a JSON object; ignoring and recovering",
            file=sys.stderr,
        )
        return {}
    return {k: v for k, v in raw.items() if isinstance(v, str)}


def _save_credentials(creds: dict[str, str]) -> None:
    # Atomic, 0o600-from-creation write: open the per-PID-named temp
    # file with O_CREAT|O_TRUNC and mode 0o600, then os.replace() into
    # place. Avoids the brief wrong-permissions window of
    # write_text-then-chmod. We don't use O_EXCL because the temp name
    # encodes our PID, so a leftover from a prior crash by this process
    # ID is correctly clobbered. No advisory lock around read/write —
    # the manual CLI assumes a single operator; concurrent sessions
    # are out of scope.
    CREDENTIALS_FILE.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = CREDENTIALS_FILE.with_suffix(
        CREDENTIALS_FILE.suffix + f".{os.getpid()}.tmp"
    )
    fd = os.open(str(tmp_path), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    try:
        os.write(fd, (json.dumps(creds, indent=2) + "\n").encode())
    finally:
        os.close(fd)
    os.replace(str(tmp_path), str(CREDENTIALS_FILE))


def _try_whoami(env: dict[str, str], *, bearer: str) -> str | None:
    """Return the authenticated worker_id, or None on 401."""
    resp = _wire(
        env, f"/v0/experiments/{_exp(env)}/whoami",
        bearer=bearer, swallow_401=True,
    )
    if resp is None:
        return None
    return resp.get("worker_id")


def _reissue_worker(env: dict[str, str], worker_id: str) -> str:
    resp = _wire(
        env,
        f"/v0/experiments/{_exp(env)}/workers/{worker_id}/reissue-credential",
        method="POST", body={},
    )
    return resp["registration_token"]


def _register_or_reissue(env: dict[str, str], worker_id: str) -> str:
    """Register a worker; reissue if the row already exists."""
    resp = _wire(
        env, f"/v0/experiments/{_exp(env)}/workers",
        method="POST", body={"worker_id": worker_id},
    )
    new_token = resp.get("registration_token")
    if new_token is None:
        # Idempotent re-register hit an existing row whose token we
        # don't have locally. Reissue to mint a fresh one.
        new_token = _reissue_worker(env, worker_id)
    return new_token


def _worker_bearer(env: dict[str, str], worker_id: str) -> str:
    """Return ``<worker_id>:<credential>`` for the manual CLI ladder.

    Differs from ``eden_service_common.auth.bootstrap_worker_credential``
    on the stale-credential branch: where the service-host helper
    forbids fall-through to fresh-register per spec §8.2 (the
    long-running service owns its registry row), the manual CLI
    accepts that the row may have been wiped by a
    ``setup-experiment.sh`` rerun and uses register-then-reissue
    recovery for both stale and cold-start paths.
    """
    creds = _read_credentials()
    persisted = creds.get(worker_id)

    if persisted is not None:
        # Step 1: verify via /whoami.
        bearer = f"{worker_id}:{persisted}"
        verified_id = _try_whoami(env, bearer=bearer)
        if verified_id == worker_id:
            return bearer
        # Step 2: stale — fall through to register-then-reissue.

    # Step 3 (also stale-fall-through from step 2).
    new_token = _register_or_reissue(env, worker_id)
    creds[worker_id] = new_token
    _save_credentials(creds)
    return f"{worker_id}:{new_token}"


def _now_iso() -> str:
    return datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%S.%fZ")


# --------------------------------------------------------------- gitea / git

def _gitea_clone_url(env: dict[str, str], *, with_creds: bool = True) -> str:
    port = env["GITEA_HOST_PORT"]
    exp = _exp(env)
    if with_creds:
        pw = urllib.parse.quote(env["GITEA_REMOTE_PASSWORD"], safe="")
        return f"http://eden:{pw}@localhost:{port}/eden/{exp}.git"
    return f"http://localhost:{port}/eden/{exp}.git"


def _git(*args: str, cwd: Path | None = None, check: bool = True, capture: bool = False):
    return subprocess.run(
        ["git", *args],
        cwd=str(cwd) if cwd else None,
        check=check,
        text=True,
        capture_output=capture,
    )


def _workdir_for(task_id: str) -> Path:
    return WORK_ROOT / task_id


# ------------------------------------------------------------- claim state

def _read_claims() -> dict[str, dict[str, str]]:
    if not CLAIMS_FILE.is_file():
        return {}
    return json.loads(CLAIMS_FILE.read_text())


def _write_claims(claims: dict[str, dict[str, str]]) -> None:
    CLAIMS_FILE.parent.mkdir(parents=True, exist_ok=True)
    CLAIMS_FILE.write_text(json.dumps(claims, indent=2) + "\n")


def _record_claim(task_id: str, *, worker_id: str, variant_id: str | None = None) -> None:
    # Post-12a-1: claim ownership is identity-keyed (no per-claim
    # opaque token). We only remember which worker_id holds the
    # claim so submit can pick the right bearer.
    claims = _read_claims()
    entry: dict[str, str] = {"worker_id": worker_id}
    if variant_id is not None:
        entry["variant_id"] = variant_id
    claims[task_id] = entry
    _write_claims(claims)


def _get_claim(task_id: str) -> dict[str, str]:
    claims = _read_claims()
    if task_id not in claims:
        sys.exit(f"error: no recorded claim for {task_id!r}; run `eden-manual claim` first")
    return claims[task_id]


def _drop_claim(task_id: str) -> None:
    claims = _read_claims()
    claims.pop(task_id, None)
    _write_claims(claims)


# --------------------------------------------------------------- read commands

def cmd_list_tasks(env: dict[str, str], args: argparse.Namespace) -> None:
    qs = []
    if args.kind:
        qs.append(f"kind={args.kind}")
    if args.state:
        qs.append(f"state={args.state}")
    suffix = ("?" + "&".join(qs)) if qs else ""
    tasks = _wire(env, f"/v0/experiments/{_exp(env)}/tasks{suffix}")
    if args.json:
        json.dump(tasks, sys.stdout, indent=2)
        sys.stdout.write("\n")
        return
    for t in tasks or []:
        print(f"{t['task_id']:40s}  kind={t['kind']:10s}  state={t['state']}")


def cmd_show(env: dict[str, str], args: argparse.Namespace) -> None:
    task = _wire(env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}")
    out: dict[str, object] = {"task": task}
    if task["kind"] == "execution":
        idea_id = task["payload"]["idea_id"]
        idea = _wire(env, f"/v0/experiments/{_exp(env)}/ideas/{idea_id}")
        out["idea"] = idea
        # Inline content if it's a file:// URI we can read.
        content_text = _try_read_content(idea.get("artifacts_uri"))
        if content_text is not None:
            out["content_text"] = content_text
    elif task["kind"] == "evaluation":
        variant_id = task["payload"]["variant_id"]
        out["variant"] = _wire(env, f"/v0/experiments/{_exp(env)}/variants/{variant_id}")
    json.dump(out, sys.stdout, indent=2)
    sys.stdout.write("\n")


def _try_read_content(uri: str | None) -> str | None:
    if not uri or not uri.startswith("file://"):
        return None
    p = Path(urllib.parse.urlparse(uri).path)
    if not p.is_file():
        return None
    try:
        text = p.read_text()
    except OSError:
        return None
    return text if len(text) <= 64 * 1024 else text[: 64 * 1024] + "\n[... truncated]"


def cmd_list_commits(env: dict[str, str], args: argparse.Namespace) -> None:
    base = env.get("EDEN_BASE_COMMIT_SHA", "")
    out = []
    if base:
        out.append({"kind": "base", "sha": base, "label": "seed"})
    variants = _wire(env, f"/v0/experiments/{_exp(env)}/variants") or []
    for v in variants:
        if v.get("variant_commit_sha"):
            out.append({
                "kind": "integrated_variant",
                "sha": v["variant_commit_sha"],
                "label": v.get("branch", v.get("variant_id", "")),
                "variant_id": v.get("variant_id"),
            })
    if args.json:
        json.dump(out, sys.stdout, indent=2)
        sys.stdout.write("\n")
        return
    for entry in out:
        print(f"{entry['sha']}  {entry['kind']:18s}  {entry['label']}")


def cmd_creds(env: dict[str, str], args: argparse.Namespace) -> None:
    print(_gitea_clone_url(env, with_creds=True))


# --------------------------------------------------------------- claim / checkout / push

def cmd_claim(env: dict[str, str], args: argparse.Namespace) -> None:
    task = _wire(env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}")
    if task["state"] != "pending":
        sys.exit(f"error: task {args.task_id!r} is in state {task['state']!r}, not pending")
    # Post-12a-1: the claim body carries only an optional expires_at;
    # the claimant worker_id is taken from the authenticated bearer's
    # principal. Bootstrap a credential for --worker-id (registers
    # it on first use, persists at /tmp/eden-manual/.credentials.json).
    bearer = _worker_bearer(env, args.worker_id)
    body: dict[str, object] = {}
    expires_at = None
    if args.ttl_seconds:
        expires_at = (datetime.now(UTC) + timedelta(seconds=args.ttl_seconds)).strftime(
            "%Y-%m-%dT%H:%M:%S.%fZ"
        )
        body["expires_at"] = expires_at
    _wire(
        env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}/claim",
        method="POST", body=body, bearer=bearer,
    )
    variant_id = None
    if task["kind"] == "execution":
        # Pre-allocate a variant_id at claim time so the canonical work-branch
        # name is stable across the execution flow (matches web-ui posture).
        variant_id = uuid.uuid4().hex
    _record_claim(args.task_id, worker_id=args.worker_id, variant_id=variant_id)
    out: dict[str, object] = {"task_id": args.task_id, "worker_id": args.worker_id}
    if variant_id:
        out["variant_id"] = variant_id
    if expires_at:
        out["expires_at"] = expires_at
    json.dump(out, sys.stdout, indent=2)
    sys.stdout.write("\n")


def cmd_checkout(env: dict[str, str], args: argparse.Namespace) -> None:
    task = _wire(env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}")
    kind = task["kind"]
    if kind == "ideation":
        sys.exit(
            "error: ideation tasks have no commit context. The ideator picks "
            "parent_commits when drafting an idea — use list-commits."
        )
    if kind == "execution":
        idea_id = task["payload"]["idea_id"]
        idea = _wire(env, f"/v0/experiments/{_exp(env)}/ideas/{idea_id}")
        target_sha = idea["parent_commits"][0]
        label = idea["slug"]
    elif kind == "evaluation":
        variant_id = task["payload"]["variant_id"]
        variant = _wire(env, f"/v0/experiments/{_exp(env)}/variants/{variant_id}")
        target_sha = variant["commit_sha"]
        label = f"eval-{variant.get('branch', variant_id)}"
    else:
        sys.exit(f"error: unsupported task kind {kind!r}")

    dest = Path(args.dest) if args.dest else _workdir_for(args.task_id)
    dest.parent.mkdir(parents=True, exist_ok=True)
    if dest.exists() and not (dest / ".git").is_dir():
        sys.exit(f"error: {dest} exists but is not a git checkout; refusing to clobber")
    if not dest.exists():
        _git("clone", _gitea_clone_url(env), str(dest))
    _git("fetch", "origin", cwd=dest)
    _git("checkout", target_sha, cwd=dest)
    print(json.dumps({
        "workdir": str(dest),
        "task_id": args.task_id,
        "kind": kind,
        "checked_out": target_sha,
        "label": label,
    }, indent=2))


def cmd_push(env: dict[str, str], args: argparse.Namespace) -> None:
    workdir = Path(args.workdir).resolve()
    if not (workdir / ".git").is_dir():
        sys.exit(f"error: {workdir} is not a git checkout")
    branch = args.branch or "manual-work"
    _git("checkout", "-B", branch, cwd=workdir)
    _git("add", "-A", cwd=workdir)
    has_staged = _git("diff", "--cached", "--quiet", cwd=workdir, check=False).returncode != 0
    if has_staged:
        # Pin identity + disable signing so the commit doesn't depend on
        # ambient global git config (gpgsign with 1Password etc. fails in
        # noninteractive subprocess).
        msg = args.message or "manual executor change"
        _git(
            "-c", "commit.gpgsign=false",
            "-c", "user.name=eden-manual",
            "-c", "user.email=manual@eden.invalid",
            "commit", "-m", msg, cwd=workdir,
        )
    elif args.message:
        print(
            "warning: --message provided but working tree is clean; pushing existing HEAD",
            file=sys.stderr,
        )
    _git("push", "origin", branch, "--force-with-lease", cwd=workdir)
    sha = _git("rev-parse", "HEAD", cwd=workdir, capture=True).stdout.strip()
    print(json.dumps({"sha": sha, "branch": branch, "workdir": str(workdir)}, indent=2))


# ------------------------------------------------------------ ideation-submit

def cmd_ideation_submit(env: dict[str, str], args: argparse.Namespace) -> None:
    claim = _get_claim(args.task_id)
    bearer = _worker_bearer(env, claim["worker_id"])
    if args.status == "error":
        _wire(
            env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}/submit",
            method="POST",
            body={"payload": {"status": "error"}}, bearer=bearer,
        )
        _drop_claim(args.task_id)
        print(json.dumps({"task_id": args.task_id, "status": "error"}, indent=2))
        return

    if not args.ideas_file:
        sys.exit("error: --ideas-file required for status=success")
    spec = json.loads(Path(args.ideas_file).read_text())
    raw_ideas = spec.get("ideas", spec) if isinstance(spec, dict) else spec
    if not raw_ideas:
        sys.exit("error: --ideas-file contained no ideas")

    ARTIFACTS_DIR.mkdir(parents=True, exist_ok=True)
    idea_ids: list[str] = []

    # Phase 1: create_idea as drafting for each.
    for raw in raw_ideas:
        idea_id = uuid.uuid4().hex
        content = raw.get("content", "")
        artifact_path = ARTIFACTS_DIR / f"{idea_id}.md"
        artifact_path.write_text(content)
        idea = {
            "idea_id": idea_id,
            "experiment_id": _exp(env),
            "slug": raw["slug"],
            "priority": float(raw.get("priority", 1.0)),
            "parent_commits": list(raw["parent_commits"]),
            "artifacts_uri": f"file://{artifact_path.resolve()}",
            "state": "drafting",
            "created_at": _now_iso(),
        }
        _wire(env, f"/v0/experiments/{_exp(env)}/ideas", method="POST", body=idea, bearer=bearer)
        idea_ids.append(idea_id)

    # Phase 2: mark_ready for each.
    for iid in idea_ids:
        _wire(
            env, f"/v0/experiments/{_exp(env)}/ideas/{iid}/mark-ready",
            method="POST", bearer=bearer,
        )

    # Phase 3: submit the ideation task.
    _wire(
        env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}/submit",
        method="POST",
        body={"payload": {"status": "success", "idea_ids": idea_ids}},
        bearer=bearer,
    )
    _drop_claim(args.task_id)
    print(json.dumps({
        "task_id": args.task_id,
        "status": "success",
        "idea_ids": idea_ids,
    }, indent=2))


# ----------------------------------------------------------- execution-submit

def _branch_name(slug: str, variant_id: str) -> str:
    return f"work/{slug}-{variant_id}"


def cmd_execution_submit(env: dict[str, str], args: argparse.Namespace) -> None:
    claim = _get_claim(args.task_id)
    bearer = _worker_bearer(env, claim["worker_id"])
    variant_id = claim.get("variant_id")
    if not variant_id:
        sys.exit("error: execution claim record is missing variant_id; reclaim the task")

    task = _wire(env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}")
    idea = _wire(
        env, f"/v0/experiments/{_exp(env)}/ideas/{task['payload']['idea_id']}"
    )

    if args.status == "error":
        # Per spec: error executor submission just records the failure;
        # no variant is created.
        _wire(
            env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}/submit",
            method="POST",
            body={"payload": {"status": "error", "variant_id": variant_id}},
            bearer=bearer,
        )
        _drop_claim(args.task_id)
        print(json.dumps({"task_id": args.task_id, "status": "error"}, indent=2))
        return

    if not args.sha:
        sys.exit("error: --sha required for status=success")
    sha = args.sha.strip()

    # Reachability check against the workdir (cloned from gitea).
    workdir = Path(args.workdir) if args.workdir else _workdir_for(args.task_id)
    if not (workdir / ".git").is_dir():
        sys.exit(
            f"error: {workdir} is not a git checkout; run `eden-manual checkout` first "
            "or pass --workdir explicitly"
        )
    _git("fetch", "origin", cwd=workdir)
    rc = _git("cat-file", "-e", f"{sha}^{{commit}}", cwd=workdir, check=False).returncode
    if rc != 0:
        sys.exit(
            f"error: commit {sha!r} not reachable in {workdir} after fetch — "
            "did you push your branch to origin?"
        )
    for parent in idea["parent_commits"]:
        rc = _git(
            "merge-base", "--is-ancestor", parent, sha,
            cwd=workdir, check=False,
        ).returncode
        if rc != 0:
            sys.exit(
                f"error: commit {sha!r} does not descend from declared parent {parent!r}"
            )

    # No-op guard: refuse to submit a variant whose tree is identical
    # to parent_commits[0]'s tree. Catches both `sha == parent[0]`
    # (literal no-op) and empty commits on top of parent (same tree,
    # new SHA). The CLI does this defensively; spec-level enforcement
    # is RFC'd at docs/design/executor-no-op-variant-rejection.md.
    if idea["parent_commits"]:
        head_tree = _git(
            "rev-parse", f"{sha}^{{tree}}",
            cwd=workdir, capture=True,
        ).stdout.strip()
        parent_tree = _git(
            "rev-parse", f"{idea['parent_commits'][0]}^{{tree}}",
            cwd=workdir, capture=True,
        ).stdout.strip()
        if head_tree == parent_tree:
            sys.exit(
                f"error: variant tree is identical to parent_commits[0] tree "
                f"({head_tree[:12]}) — refusing to submit a no-op variant"
            )

    branch = _branch_name(idea["slug"], variant_id)

    # Phase 1: create_variant in starting state. ``branch`` is REQUIRED
    # for integration to find the canonical ref later.
    variant = {
        "variant_id": variant_id,
        "experiment_id": _exp(env),
        "idea_id": idea["idea_id"],
        "status": "starting",
        "parent_commits": list(idea["parent_commits"]),
        "branch": branch,
        "started_at": _now_iso(),
    }
    if args.description:
        variant["description"] = args.description
    _wire(env, f"/v0/experiments/{_exp(env)}/variants", method="POST", body=variant, bearer=bearer)

    # Phase 2: push the canonical work branch directly to gitea.
    # `<sha>:refs/heads/<branch>` creates the named ref on origin.
    push_target = f"{sha}:refs/heads/{branch}"
    _git("push", "origin", push_target, cwd=workdir)

    # Phase 3: submit the execution task.
    _wire(
        env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}/submit",
        method="POST",
        body={
            "payload": {
                "status": "success",
                "variant_id": variant_id,
                "commit_sha": sha,
            },
        },
        bearer=bearer,
    )
    _drop_claim(args.task_id)
    print(json.dumps({
        "task_id": args.task_id,
        "status": "success",
        "variant_id": variant_id,
        "commit_sha": sha,
        "branch": branch,
    }, indent=2))


# ---------------------------------------------------------- evaluation-submit

def _parse_field(raw: str) -> tuple[str, object]:
    if "=" not in raw:
        sys.exit(f"error: --field must be K=V (got {raw!r})")
    k, v = raw.split("=", 1)
    k = k.strip()
    v = v.strip()
    if not k:
        sys.exit("error: empty field name")
    # Coerce: try int → float → leave as string.
    try:
        if v.lstrip("-").isdigit():
            return k, int(v)
        return k, float(v)
    except ValueError:
        return k, v


def cmd_evaluation_submit(env: dict[str, str], args: argparse.Namespace) -> None:
    claim = _get_claim(args.task_id)
    bearer = _worker_bearer(env, claim["worker_id"])

    task = _wire(env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}")
    variant_id = task["payload"]["variant_id"]

    payload: dict[str, object] = {"status": args.status, "variant_id": variant_id}
    if args.status == "success":
        if not args.field:
            sys.exit("error: --field K=V required for status=success (one per evaluation field)")
        evaluation = dict(_parse_field(f) for f in args.field)
        payload["evaluation"] = evaluation
    if args.artifacts_uri:
        payload["artifacts_uri"] = args.artifacts_uri

    _wire(
        env, f"/v0/experiments/{_exp(env)}/tasks/{args.task_id}/submit",
        method="POST",
        body={"payload": payload}, bearer=bearer,
    )
    _drop_claim(args.task_id)
    print(json.dumps({"task_id": args.task_id, "status": args.status, "variant_id": variant_id}, indent=2))


# --------------------------------------------------------------------- main

def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="eden-manual")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("list-tasks")
    sp.add_argument("--kind", choices=("ideation", "execution", "evaluation"))
    sp.add_argument("--state")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_list_tasks)

    sp = sub.add_parser("show")
    sp.add_argument("task_id")
    sp.set_defaults(func=cmd_show)

    sp = sub.add_parser("list-commits")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_list_commits)

    sp = sub.add_parser("creds")
    sp.set_defaults(func=cmd_creds)

    sp = sub.add_parser("claim")
    sp.add_argument("task_id")
    sp.add_argument("--worker-id", default="eden-manual")
    sp.add_argument("--ttl-seconds", type=int, default=0,
                    help="0 = no expiry (default)")
    sp.set_defaults(func=cmd_claim)

    sp = sub.add_parser("checkout")
    sp.add_argument("task_id")
    sp.add_argument("--dest")
    sp.set_defaults(func=cmd_checkout)

    sp = sub.add_parser("push")
    sp.add_argument("workdir")
    sp.add_argument("--branch")
    sp.add_argument("--message")
    sp.set_defaults(func=cmd_push)

    sp = sub.add_parser("ideation-submit")
    sp.add_argument("task_id")
    sp.add_argument("--ideas-file")
    sp.add_argument("--status", choices=("success", "error"), default="success")
    sp.set_defaults(func=cmd_ideation_submit)

    sp = sub.add_parser("execution-submit")
    sp.add_argument("task_id")
    sp.add_argument("--sha")
    sp.add_argument("--description")
    sp.add_argument("--workdir", help="default: /tmp/eden-manual/<task_id>")
    sp.add_argument("--status", choices=("success", "error"), default="success")
    sp.set_defaults(func=cmd_execution_submit)

    sp = sub.add_parser("evaluation-submit")
    sp.add_argument("task_id")
    sp.add_argument("--field", action="append", default=[],
                    help="K=V (repeatable); required when --status=success")
    sp.add_argument("--artifacts-uri")
    sp.add_argument("--status", choices=("success", "error", "evaluation_error"),
                    default="success")
    sp.set_defaults(func=cmd_evaluation_submit)

    args = p.parse_args(argv)
    env = _load_env()
    args.func(env, args)
    return 0


if __name__ == "__main__":
    sys.exit(main())
