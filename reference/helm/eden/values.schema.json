{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "EDEN Helm chart values",
  "type": "object",
  "required": ["image", "experiment", "replicas", "storage", "config"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Container image repository. REQUIRED — build + push the eden-reference image to a registry the cluster can pull from."
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "description": "Image tag. REQUIRED."
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "pullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": { "name": { "type": "string", "minLength": 1 } }
          }
        }
      }
    },
    "experiment": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "config": { "type": "object" },
        "configRaw": {
          "type": "string",
          "description": "Raw experiment-config YAML as a string (takes precedence over `config` when non-empty). Set by setup-experiment-helm.sh via --set-file."
        },
        "baseCommitSha": { "type": "string" }
      }
    },
    "replicas": {
      "type": "object",
      "properties": {
        "taskStoreServer": {
          "description": "Operator-singleton in v0: one minted worker-facing endpoint per experiment, and file-mode blob storage (blob.backend=file) mounts a single ReadWriteOnce PVC. Capped at 1 until a multi-replica task-store/blob design exists.",
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "controlPlane": { "type": "integer", "minimum": 0 },
        "orchestrator": { "type": "integer", "minimum": 0 },
        "ideatorHost": {
          "description": "Operator-singleton in v0: the ideator Deployment uses one minted worker_id, so >1 replica would race on one worker credential. Capped at 1 until unique worker ids are generated per replica.",
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "executorHost": { "type": "integer", "minimum": 0 },
        "evaluatorHost": { "type": "integer", "minimum": 0 },
        "webUi": {
          "description": "Operator-singleton in v0: a fixed --worker-id + RWO clone/artifacts PVCs make >1 replica incoherent (credential reissue races, split artifacts). Capped at 1 until horizontal scaling lands.",
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "adminToken": { "type": "string" },
        "sessionSecret": { "type": "string" },
        "postgresPassword": { "type": "string" },
        "readonlyPassword": { "type": "string" },
        "forgejoRemotePassword": { "type": "string" },
        "forgejoSecretKey": { "type": "string" },
        "forgejoInternalToken": { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "className": { "type": "string" },
        "postgresSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "forgejoSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "orchestratorRepoSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "executorRepoSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "evaluatorRepoSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "webUiRepoSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
        "artifactsSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" }
      }
    },
    "blob": {
      "type": "object",
      "properties": {
        "backend": {
          "description": "Where the §16 artifact deposit endpoint persists bytes (issue #174). 'file' (default) = chart-managed PVC; 's3' / 'gcs' = operator-supplied bucket (see the per-mode required values enforced in allOf).",
          "type": "string",
          "enum": ["file", "s3", "gcs"]
        },
        "file": {
          "type": "object",
          "properties": {
            "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
            "className": { "type": "string" },
            "mountPath": { "type": "string", "minLength": 1 }
          }
        },
        "s3": {
          "type": "object",
          "properties": {
            "bucket": { "type": "string" },
            "region": { "type": "string" },
            "prefix": { "type": "string" },
            "endpointUrl": { "type": "string" },
            "irsa": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "roleArn": { "type": "string" }
              }
            },
            "existingSecret": { "type": "string" },
            "accessKeyIdKey": { "type": "string", "minLength": 1 },
            "secretAccessKeyKey": { "type": "string", "minLength": 1 }
          }
        },
        "gcs": {
          "type": "object",
          "properties": {
            "bucket": { "type": "string" },
            "prefix": { "type": "string" },
            "workloadIdentity": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "serviceAccount": { "type": "string" }
              }
            },
            "existingSecret": { "type": "string" },
            "serviceAccountKeyKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "object" },
        "tls": { "type": "array" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "leaseDurationSeconds": { "type": "integer", "minimum": 1 },
        "stateSyncIntervalSeconds": { "type": "integer", "minimum": 1 },
        "stateSyncFailureThreshold": { "type": "integer", "minimum": 1 },
        "maxQuiescentIterations": {
          "description": "0 = never exit on quiescence (Kubernetes default); otherwise >= 2.",
          "anyOf": [
            { "type": "integer", "const": 0 },
            { "type": "integer", "minimum": 2 }
          ]
        },
        "pollIntervalSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "workerMode": {
          "description": "Only 'scripted' is supported in 13a (Decision 10).",
          "type": "string",
          "enum": ["scripted"]
        }
      }
    },
    "orchestrator": {
      "type": "object",
      "properties": {
        "leaseMode": {
          "type": "object",
          "properties": {
            "enabled": {
              "description": "Lease-driven HA toggle. false (default) = single-experiment, control plane idle/not-rendered. true = lease-driven mode (control plane rendered, EDEN_CONTROL_PLANE_URL set, experiment registered). DEFERRED + unvalidated behind #281.",
              "type": "boolean"
            }
          }
        }
      }
    },
    "identity": {
      "description": "Per-service minted opaque worker identities (#128). Filled by setup-experiment-helm.sh after the task-store-server mints them. Each service renders only once BOTH its workerId and token are set (they must be supplied together).",
      "type": "object",
      "properties": {
        "orchestrator": { "$ref": "#/definitions/serviceIdentity" },
        "webUi": { "$ref": "#/definitions/serviceIdentity" },
        "ideatorHost": { "$ref": "#/definitions/serviceIdentity" },
        "executorHost": { "$ref": "#/definitions/serviceIdentity" },
        "evaluatorHost": { "$ref": "#/definitions/serviceIdentity" }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "mode": {
          "description": "Postgres provisioning mode. embedded (default) = in-cluster StatefulSet (13a). external = operator-supplied managed Postgres DSN; the chart deploys no Postgres.",
          "type": "string",
          "enum": ["embedded", "external"]
        },
        "image": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "database": { "type": "string", "minLength": 1 },
        "controlPlaneDatabase": { "type": "string", "minLength": 1 },
        "user": { "type": "string", "minLength": 1 },
        "resources": { "type": "object" },
        "external": {
          "type": "object",
          "properties": {
            "connectionString": { "type": "string" },
            "existingSecret": { "type": "string" },
            "connectionStringKey": { "type": "string" },
            "tlsAlreadyEncodedInSecret": { "type": "boolean" }
          }
        },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": {
              "description": "libpq sslmode. Weak modes (disable/allow/prefer) are intentionally not allowed for a managed deployment.",
              "type": "string",
              "enum": ["require", "verify-ca", "verify-full"]
            },
            "caBundleSecret": { "type": "string" },
            "caBundleKey": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "tls": {
                "properties": {
                  "enabled": { "const": true },
                  "mode": { "enum": ["verify-ca", "verify-full"] }
                },
                "required": ["enabled", "mode"]
              }
            },
            "required": ["tls"]
          },
          "then": {
            "properties": {
              "tls": {
                "properties": { "caBundleSecret": { "type": "string", "minLength": 1 } },
                "required": ["caBundleSecret"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": { "const": "external" },
              "tls": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
              "external": { "properties": { "existingSecret": { "type": "string", "minLength": 1 } }, "required": ["existingSecret"] }
            },
            "required": ["mode", "tls", "external"]
          },
          "then": {
            "properties": {
              "external": {
                "properties": { "tlsAlreadyEncodedInSecret": { "const": true } },
                "required": ["tlsAlreadyEncodedInSecret"]
              }
            }
          }
        }
      ]
    },
    "forgejo": {
      "type": "object",
      "properties": {
        "image": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "resources": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" }
  },
  "allOf": [
    {
      "$comment": "mode=external WITHOUT a whole-chart secrets.existingSecret: the chart-managed Secret must carry the DSN, so require an inline URL connectionString OR an external.existingSecret reference. (When secrets.existingSecret IS set, the DSN comes from that Secret's EDEN_STORE_URL — see the next clause.)",
      "if": {
        "required": ["postgres"],
        "properties": {
          "postgres": { "required": ["mode"], "properties": { "mode": { "const": "external" } } },
          "secrets": { "properties": { "existingSecret": { "const": "" } } }
        }
      },
      "then": {
        "properties": {
          "postgres": {
            "required": ["external"],
            "properties": {
              "external": {
                "anyOf": [
                  {
                    "properties": {
                      "connectionString": { "type": "string", "minLength": 1, "pattern": "^postgres(ql)?://" }
                    },
                    "required": ["connectionString"]
                  },
                  {
                    "properties": {
                      "existingSecret": { "type": "string", "minLength": 1 },
                      "connectionStringKey": { "type": "string", "minLength": 1 }
                    },
                    "required": ["existingSecret", "connectionStringKey"]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "$comment": "mode=external WITH a whole-chart secrets.existingSecret: that Secret is authoritative for EDEN_STORE_URL and the chart-managed Secret template does not render, so an inline postgres.external.connectionString would be silently dropped. Reject it — put the DSN in the existingSecret, or use postgres.external.existingSecret to point at a dedicated DSN Secret.",
      "if": {
        "required": ["postgres", "secrets"],
        "properties": {
          "postgres": { "required": ["mode"], "properties": { "mode": { "const": "external" } } },
          "secrets": { "required": ["existingSecret"], "properties": { "existingSecret": { "minLength": 1 } } }
        }
      },
      "then": {
        "properties": {
          "postgres": {
            "properties": {
              "external": { "properties": { "connectionString": { "const": "" } } }
            }
          }
        }
      }
    },
    {
      "$comment": "TLS is only supported for mode=external. The embedded StatefulSet runs the stock Postgres image with no server-side TLS, so appending sslmode to its DSN would make the task-store-server fail to connect. Reject tls.enabled=true unless mode=external.",
      "if": {
        "required": ["postgres"],
        "properties": {
          "postgres": { "required": ["tls"], "properties": { "tls": { "required": ["enabled"], "properties": { "enabled": { "const": true } } } } }
        }
      },
      "then": {
        "properties": {
          "postgres": { "required": ["mode"], "properties": { "mode": { "const": "external" } } }
        }
      }
    },
    {
      "$comment": "mode=external + TLS with a whole-chart secrets.existingSecret: the chart-managed Secret does not render, so the chart cannot append the sslmode/sslrootcert suffix — the operator must encode TLS into the EDEN_STORE_URL inside that Secret and acknowledge it. Mirrors the postgres.external.existingSecret guard for the whole-chart-secret path.",
      "if": {
        "required": ["postgres", "secrets"],
        "properties": {
          "postgres": { "required": ["mode", "tls"], "properties": { "mode": { "const": "external" }, "tls": { "required": ["enabled"], "properties": { "enabled": { "const": true } } } } },
          "secrets": { "required": ["existingSecret"], "properties": { "existingSecret": { "minLength": 1 } } }
        }
      },
      "then": {
        "properties": {
          "postgres": {
            "required": ["external"],
            "properties": {
              "external": { "required": ["tlsAlreadyEncodedInSecret"], "properties": { "tlsAlreadyEncodedInSecret": { "const": true } } }
            }
          }
        }
      }
    },
    {
      "$comment": "external + lease mode is unsupported in v0 (deferred behind #281; control-plane provisioning on a managed instance is tracked in #299). The control-plane Deployment would start with --store-url $(EDEN_CONTROL_PLANE_STORE_URL), which external mode does not wire to a valid control-plane database. Reject the combination so it fails at lint time rather than crash-looping the control-plane.",
      "if": {
        "required": ["postgres"],
        "properties": {
          "postgres": { "required": ["mode"], "properties": { "mode": { "const": "external" } } }
        }
      },
      "then": {
        "properties": {
          "orchestrator": {
            "properties": {
              "leaseMode": { "properties": { "enabled": { "const": false } } }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["blob"],
        "properties": {
          "blob": {
            "required": ["backend"],
            "properties": { "backend": { "const": "s3" } }
          }
        }
      },
      "then": {
        "properties": {
          "blob": {
            "required": ["s3"],
            "properties": {
              "s3": {
                "description": "blob.backend=s3 REQUIRES a non-empty bucket plus exactly one auth path: irsa.enabled=true with a roleArn (pod identity), or a non-empty existingSecret (static keys) with IRSA off. No auth at all — or both at once — fails at lint time.",
                "required": ["bucket"],
                "properties": {
                  "bucket": { "type": "string", "minLength": 1 }
                },
                "oneOf": [
                  {
                    "description": "Pod-identity auth: IRSA enabled with a role ARN, no static secret.",
                    "required": ["irsa"],
                    "properties": {
                      "irsa": {
                        "required": ["enabled", "roleArn"],
                        "properties": {
                          "enabled": { "const": true },
                          "roleArn": { "type": "string", "minLength": 1 }
                        }
                      },
                      "existingSecret": { "const": "" }
                    }
                  },
                  {
                    "description": "Static-credentials auth: existingSecret set, IRSA off.",
                    "required": ["existingSecret"],
                    "properties": {
                      "irsa": { "properties": { "enabled": { "const": false } } },
                      "existingSecret": { "type": "string", "minLength": 1 }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["blob"],
        "properties": {
          "blob": {
            "required": ["backend"],
            "properties": { "backend": { "const": "gcs" } }
          }
        }
      },
      "then": {
        "properties": {
          "blob": {
            "required": ["gcs"],
            "properties": {
              "gcs": {
                "description": "blob.backend=gcs REQUIRES a non-empty bucket plus exactly one auth path: workloadIdentity.enabled=true with a serviceAccount (pod identity), or a non-empty existingSecret (service-account key JSON) with Workload Identity off.",
                "required": ["bucket"],
                "properties": {
                  "bucket": { "type": "string", "minLength": 1 }
                },
                "oneOf": [
                  {
                    "description": "Pod-identity auth: Workload Identity enabled with a bound GCP service account, no key secret.",
                    "required": ["workloadIdentity"],
                    "properties": {
                      "workloadIdentity": {
                        "required": ["enabled", "serviceAccount"],
                        "properties": {
                          "enabled": { "const": true },
                          "serviceAccount": { "type": "string", "minLength": 1 }
                        }
                      },
                      "existingSecret": { "const": "" }
                    }
                  },
                  {
                    "description": "Key-file auth: existingSecret set, Workload Identity off.",
                    "required": ["existingSecret"],
                    "properties": {
                      "workloadIdentity": { "properties": { "enabled": { "const": false } } },
                      "existingSecret": { "type": "string", "minLength": 1 }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "serviceIdentity": {
      "type": "object",
      "description": "A minted worker identity. workerId and token MUST be supplied together — set both (provisioned) or leave both empty (not yet provisioned). A half-set state renders neither the identity Secret nor the workload.",
      "properties": {
        "workerId": { "type": "string" },
        "token": { "type": "string" }
      },
      "oneOf": [
        {
          "properties": {
            "workerId": { "const": "" },
            "token": { "const": "" }
          }
        },
        {
          "required": ["workerId", "token"],
          "properties": {
            "workerId": { "minLength": 1 },
            "token": { "minLength": 1 }
          }
        }
      ]
    }
  }
}
