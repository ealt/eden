# Node (reference web-ui, lands in Phase 9)
node_modules/

# macOS
.DS_Store

# Review artifacts
# Track durable review content (*-review.md, *.patch) so future sessions
# can learn from past reviews; ignore large Codex transcript files that
# are regenerable from the next review run.
docs/plans/review/**/*.jsonl
docs/plans/review/**/*.stderr
docs/plans/review/**/*.stdout
docs/plans/review/**/prompt.txt

# Claude Code local runtime state (scheduled-task lock, etc.)
.claude/

# Compose secrets — example template is committed; real .env is not.
reference/compose/.env
