# Editors
.vscode
.idea

# Python (lands in Phase 3)
__pycache__/
*.pyc
*.egg-info/
.venv/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/

# Databases (reference impl may write these)
*.db
*.sqlite
*.sqlite-journal
*.log

# Node (reference web-ui, lands in Phase 9)
node_modules/

# macOS
.DS_Store

# Review artifacts
# Track durable review content (*-review.md, *.patch) so future sessions
# can learn from past reviews; ignore large Codex transcript files that
# are regenerable from the next review run.
docs/plans/review/**/*.jsonl
docs/plans/review/**/*.stderr
docs/plans/review/**/*.stdout
docs/plans/review/**/prompt.txt

# Claude Code local runtime state (scheduled-task lock, etc.) —
# but track project-specific skills under .claude/skills/.
.claude/*
!.claude/skills/

# Compose secrets — example template is committed; real .env (and any
# editor / sed -i.bak / shell-redirect derivatives) is not.
reference/compose/.env
reference/compose/.env.*
!reference/compose/.env.example
# Generated by setup-experiment / compose smoke runs.
reference/compose/experiment-config.yaml

# Phase 10d follow-up A: per-experiment cidfiles dir (host-side
# bind-mount source). Per-spawn cidfiles are deleted by the
# cleanup callbacks; the dir itself sticks around between runs.
reference/compose/.cidfiles-*/

# Phase 10d follow-up B: per-experiment git-remote credential-helper
# scripts (host-side bind-mount source). Contains the per-experiment
# git-remote password — must NOT be committed. The .gitea-creds-*
# pattern is retained for back-compat with pre-#113 worktrees;
# .forgejo-creds-* is the current shape.
reference/compose/.gitea-creds-*/
reference/compose/.forgejo-creds-*/
/reference/compose/checkpoints/
