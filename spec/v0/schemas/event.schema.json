{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EDEN event envelope",
  "description": "The envelope every event appended to an EDEN event log MUST carry. Registered types have per-type payload shapes enumerated under allOf; types outside the registry pass the envelope only. Full normative registry and semantics are in 05-event-protocol.md.",
  "type": "object",
  "required": ["event_id", "type", "occurred_at", "experiment_id", "data"],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this event within the log."
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Dotted type name, e.g. task.claimed, variant.succeeded."
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "When the state change happened; UTC (trailing Z) required."
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": "object",
      "description": "Type-specific payload; shape fixed by the registry entry for the event's type."
    }
  },
  "$defs": {
    "taskId": {"type": "string", "minLength": 1},
    "ideaId": {"type": "string", "minLength": 1},
    "variantId": {"type": "string", "minLength": 1},
    "workerId": {"type": "string", "minLength": 1},
    "taskKind": {"type": "string", "enum": ["ideation", "execution", "evaluation"]},
    "commitSha": {"type": "string", "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"},
    "failReason": {"type": "string", "enum": ["worker_error", "validation_error", "policy_limit"]},
    "reclaimCause": {"type": "string", "enum": ["expired", "operator", "health_policy"]}
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"const": "task.created"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["task_id", "kind"],
            "properties": {
              "task_id": {"$ref": "#/$defs/taskId"},
              "kind": {"$ref": "#/$defs/taskKind"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "task.claimed"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["task_id", "worker_id"],
            "properties": {
              "task_id": {"$ref": "#/$defs/taskId"},
              "worker_id": {"$ref": "#/$defs/workerId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "task.submitted"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["task_id"],
            "properties": {
              "task_id": {"$ref": "#/$defs/taskId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "task.completed"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["task_id"],
            "properties": {
              "task_id": {"$ref": "#/$defs/taskId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "task.failed"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["task_id", "reason"],
            "properties": {
              "task_id": {"$ref": "#/$defs/taskId"},
              "reason": {"$ref": "#/$defs/failReason"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "task.reclaimed"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["task_id", "cause"],
            "properties": {
              "task_id": {"$ref": "#/$defs/taskId"},
              "cause": {"$ref": "#/$defs/reclaimCause"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "task.reassigned"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["task_id", "new_target", "reason", "reassigned_by"],
            "properties": {
              "task_id": {"$ref": "#/$defs/taskId"},
              "new_target": {
                "oneOf": [
                  {"type": "null"},
                  {
                    "type": "object",
                    "required": ["kind", "id"],
                    "properties": {
                      "kind": {"type": "string", "enum": ["worker", "group"]},
                      "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"}
                    }
                  }
                ]
              },
              "reason": {"type": "string", "minLength": 1},
              "reassigned_by": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "experiment.dispatch_mode_changed"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["dispatch_mode", "changed", "updated_by"],
            "properties": {
              "dispatch_mode": {
                "type": "object",
                "additionalProperties": {"type": "string", "enum": ["auto", "manual"]}
              },
              "changed": {
                "type": "object",
                "additionalProperties": {"type": "string", "enum": ["auto", "manual"]}
              },
              "updated_by": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "idea.drafted"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["idea_id"],
            "properties": {
              "idea_id": {"$ref": "#/$defs/ideaId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "idea.ready"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["idea_id"],
            "properties": {
              "idea_id": {"$ref": "#/$defs/ideaId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "idea.dispatched"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["idea_id", "task_id"],
            "properties": {
              "idea_id": {"$ref": "#/$defs/ideaId"},
              "task_id": {"$ref": "#/$defs/taskId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "idea.completed"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["idea_id", "task_id"],
            "properties": {
              "idea_id": {"$ref": "#/$defs/ideaId"},
              "task_id": {"$ref": "#/$defs/taskId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "variant.started"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["variant_id"],
            "properties": {
              "variant_id": {"$ref": "#/$defs/variantId"},
              "idea_id": {"$ref": "#/$defs/ideaId"},
              "kind": {"type": "string", "enum": ["baseline"]}
            },
            "allOf": [
              {
                "description": "idea_id is required on variant.started unless the variant is a baseline (spec/v0/05-event-protocol.md §3.3).",
                "if": {"not": {"properties": {"kind": {"const": "baseline"}}, "required": ["kind"]}},
                "then": {"required": ["idea_id"]}
              }
            ]
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "variant.succeeded"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["variant_id", "commit_sha"],
            "properties": {
              "variant_id": {"$ref": "#/$defs/variantId"},
              "commit_sha": {"$ref": "#/$defs/commitSha"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "variant.errored"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["variant_id"],
            "properties": {
              "variant_id": {"$ref": "#/$defs/variantId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "variant.evaluation_errored"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["variant_id"],
            "properties": {
              "variant_id": {"$ref": "#/$defs/variantId"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "variant.integrated"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["variant_id", "variant_commit_sha"],
            "properties": {
              "variant_id": {"$ref": "#/$defs/variantId"},
              "variant_commit_sha": {"$ref": "#/$defs/commitSha"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "experiment.terminated"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["reason", "terminated_by"],
            "properties": {
              "reason": {"type": "string"},
              "terminated_by": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"type": {"const": "experiment.policy_error"}}, "required": ["type"]},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["policy_kind", "error_type", "error_message"],
            "properties": {
              "policy_kind": {"type": "string", "minLength": 1},
              "error_type": {"type": "string", "minLength": 1},
              "error_message": {"type": "string"}
            }
          }
        }
      }
    }
  ]
}
