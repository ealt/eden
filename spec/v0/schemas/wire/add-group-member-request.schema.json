{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EDEN wire — add-group-member request",
  "description": "Request body for POST /v0/experiments/{E}/groups/{G}/members (07-wire-protocol.md §7.2). Admin-gated.",
  "type": "object",
  "required": ["member_id"],
  "additionalProperties": false,
  "properties": {
    "member_id": {
      "type": "string",
      "pattern": "^(wkr|grp)_[0-9a-hjkmnp-tv-z]{26}$",
      "description": "Member id — a worker_id (wkr_*) or a group_id (grp_*) (spec/v0/02-data-model.md §1.6)."
    }
  }
}
