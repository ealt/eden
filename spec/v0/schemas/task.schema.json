{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EDEN task",
  "description": "A unit of work dispatched to a role. The task object carries kind, state, payload, target, attribution, and optional claim; its state-machine semantics are defined in 04-task-protocol.md.",
  "type": "object",
  "required": ["task_id", "kind", "state", "payload", "created_at", "updated_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["ideation", "execution", "evaluation"]
    },
    "state": {
      "type": "string",
      "enum": ["pending", "claimed", "submitted", "completed", "failed"]
    },
    "payload": {
      "type": "object"
    },
    "target": {
      "type": "object",
      "description": "Constrains which workers may claim the task (spec/v0/02-data-model.md §3.5). Tagged so worker-id and group-id namespaces are disambiguated.",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["worker", "group"]
        },
        "id": {
          "type": "string",
          "pattern": "^(wkr|grp)_[0-9a-hjkmnp-tv-z]{26}$",
          "description": "Target id — a worker_id (wkr_*) or a group_id (grp_*) (spec/v0/02-data-model.md §1.6)."
        }
      }
    },
    "created_by": {
      "type": "string",
      "pattern": "^(admin|wkr_[0-9a-hjkmnp-tv-z]{26})$",
      "description": "Actor identifier of the caller that created the task: the admin sentinel `admin` or a worker_id (spec/v0/02-data-model.md §1.6)."
    },
    "submitted_by": {
      "type": "string",
      "pattern": "^wkr_[0-9a-hjkmnp-tv-z]{26}$",
      "description": "worker_id of the claimant whose submission was committed; preserved across the terminal transition that clears `claim` (spec/v0/02-data-model.md §3.4)."
    },
    "claim": {
      "type": "object",
      "required": ["worker_id", "claimed_at"],
      "properties": {
        "worker_id": {
          "type": "string",
          "pattern": "^wkr_[0-9a-hjkmnp-tv-z]{26}$"
        },
        "claimed_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  },
  "allOf": [
    {
      "if": {"properties": {"kind": {"const": "ideation"}}, "required": ["kind"]},
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["experiment_id"],
            "properties": {
              "experiment_id": {"type": "string", "pattern": "^exp_[0-9a-hjkmnp-tv-z]{26}$"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"kind": {"const": "execution"}}, "required": ["kind"]},
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["idea_id"],
            "properties": {
              "idea_id": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"kind": {"const": "evaluation"}}, "required": ["kind"]},
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["variant_id"],
            "properties": {
              "variant_id": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"state": {"enum": ["claimed", "submitted"]}},
        "required": ["state"]
      },
      "then": {"required": ["claim"]},
      "else": {"not": {"required": ["claim"]}}
    }
  ]
}
