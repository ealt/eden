{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EDEN proposal",
  "description": "A planner's output: the plan document metadata required to dispatch implementation work. Lifecycle semantics are in 04-task-protocol.md.",
  "type": "object",
  "required": [
    "proposal_id",
    "experiment_id",
    "slug",
    "priority",
    "parent_commits",
    "artifacts_uri",
    "state",
    "created_at"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "priority": {
      "type": "number"
    },
    "parent_commits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$",
        "description": "Lowercase hex SHA-1 (40 chars) or SHA-256 (64 chars) commit identifier."
      }
    },
    "artifacts_uri": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["drafting", "ready", "dispatched", "completed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  }
}
