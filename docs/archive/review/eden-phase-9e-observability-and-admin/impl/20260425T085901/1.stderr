   196	    def test_cas_miss_redirects_ref_changed(
   197	        self,
   198	        signed_in_admin_repo_client: TestClient,
   199	        store: InMemoryStore,
   200	        bare_repo: GitRepo,
   201	        base_sha: str,
   202	        artifacts_dir: Path,
   203	    ) -> None:
   204	        """SHA rewritten between the route's read and the delete call → ref-changed.
   205	
   206	        We simulate this by monkey-patching ``GitRepo.delete_ref`` to
   207	        raise ``GitError`` (the CAS miss surface).
   208	        """
   209	        seed_evaluate_task(
   210	            store,
   211	            slug="t3",
   212	            trial_id="trial-C",
   213	            artifacts_dir=artifacts_dir,
   214	            commit_sha=make_child_commit(bare_repo, base_sha, "c"),
   215	        )
   216	        trial = store.read_trial("trial-C")
   217	        assert trial.branch is not None
   218	        assert trial.commit_sha is not None
   219	        bare_repo.create_ref(f"refs/heads/{trial.branch}", trial.commit_sha)
   220	        store.declare_trial_eval_error("trial-C")
   221	        from eden_git.repo import GitError
   222	
   223	        def boom(self, *args, **kwargs):
   224	            raise GitError(["git", "update-ref"], 1, "", "expected ... but is ...")
   225	
   226	        with pytest.MonkeyPatch.context() as mp:
   227	            mp.setattr(GitRepo, "delete_ref", boom)
   228	            csrf = get_csrf(signed_in_admin_repo_client)
   229	            resp = signed_in_admin_repo_client.post(
   230	                "/admin/work-refs/delete",
   231	                data={
   232	                    "csrf_token": csrf,
   233	                    "ref_name": f"refs/heads/{trial.branch}",
   234	                },
   235	                follow_redirects=False,
   236	            )
   237	        assert resp.status_code == 303
   238	        assert "?error=ref-changed" in resp.headers["location"]
   239	
   240	    def test_unexpected_git_error_propagates_5xx(
   241	        self,
   242	        signed_in_admin_repo_client: TestClient,
   243	        store: InMemoryStore,
   244	        bare_repo: GitRepo,
   245	        base_sha: str,
   246	        artifacts_dir: Path,
   247	    ) -> None:
   248	        """Plan §G + impl-review finding 2: a non-CAS GitError must not
   249	        be silenced as ``ref-changed``. It propagates to FastAPI's
   250	        default 500 handler so the operator sees a real error and the
   251	        failure shows up in logs.
   252	        """
   253	        seed_evaluate_task(
   254	            store,
   255	            slug="t4",
   256	            trial_id="trial-P",
   257	            artifacts_dir=artifacts_dir,
   258	            commit_sha=make_child_commit(bare_repo, base_sha, "p"),
   259	        )
   260	        trial = store.read_trial("trial-P")
   261	        assert trial.branch is not None
   262	        assert trial.commit_sha is not None
   263	        bare_repo.create_ref(f"refs/heads/{trial.branch}", trial.commit_sha)
   264	        store.declare_trial_eval_error("trial-P")
   265	        from eden_git.repo import GitError
   266	
   267	        # exit code 128 + stderr without "expected" => unexpected git
   268	        # failure. The route must re-raise.
   269	        def perm_boom(self, *args, **kwargs):
   270	            raise GitError(
   271	                ["git", "update-ref"],
   272	                128,
   273	                "",
   274	                "fatal: cannot lock ref: permission denied",
   275	            )
   276	
   277	        with pytest.MonkeyPatch.context() as mp:
   278	            mp.setattr(GitRepo, "delete_ref", perm_boom)
   279	            csrf = get_csrf(signed_in_admin_repo_client)
   280	            with pytest.raises(GitError):
   281	                signed_in_admin_repo_client.post(
   282	                    "/admin/work-refs/delete",
   283	                    data={
   284	                        "csrf_token": csrf,
   285	                        "ref_name": f"refs/heads/{trial.branch}",
   286	                    },
   287	                    follow_redirects=False,
   288	                )
