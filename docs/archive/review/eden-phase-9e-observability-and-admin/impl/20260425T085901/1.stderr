   307	@router.post("/tasks/{task_id}/reclaim", response_model=None)
   308	async def task_reclaim(
   309	    task_id: str,
   310	    request: Request,
   311	    csrf_token: str = Form(""),
   312	) -> RedirectResponse | HTMLResponse:
   313	    session = get_session(request)
   314	    if session is None:
   315	        return RedirectResponse(url="/signin", status_code=303)
   316	    if not csrf_ok(session, csrf_token):
   317	        return _csrf_failure_response()
   318	    store = request.app.state.store
   319	    try:
   320	        store.reclaim(task_id, "operator")
   321	    except IllegalTransition:
   322	        return RedirectResponse(
   323	            url=f"/admin/tasks/{task_id}/?error=illegal-transition",
   324	            status_code=303,
   325	        )
   326	    except Exception:  # noqa: BLE001 — transport-shaped from StoreClient
   327	        return RedirectResponse(
   328	            url=f"/admin/tasks/{task_id}/?error=transport",
   329	            status_code=303,
   330	        )
   331	    return RedirectResponse(
   332	        url=f"/admin/tasks/{task_id}/?reclaimed=ok",
   333	        status_code=303,
   334	    )
