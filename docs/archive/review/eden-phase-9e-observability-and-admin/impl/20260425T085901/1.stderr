    65	class TestTaskReclaimFailures:
    66	    def test_illegal_transition_redirects_with_error_banner(
    67	        self, signed_in_client: TestClient, store: InMemoryStore
    68	    ) -> None:
    69	        """Terminal task → reclaim raises IllegalTransition → ?error=illegal-transition."""
