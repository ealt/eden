    78	def _coerce_filter(raw: str | None, allowed: tuple[str, ...]) -> str | None:
    79	    """Map ``raw`` to a value in ``allowed``, ``None`` (no filter), or ``_INVALID_FILTER``."""
    80	    if raw is None or raw == "*" or raw == "":
    81	        return None
    82	    if raw in allowed:
    83	        return raw
    84	    return _INVALID_FILTER
