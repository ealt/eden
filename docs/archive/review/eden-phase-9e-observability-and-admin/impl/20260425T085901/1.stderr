   342	@router.get("/trials/", response_class=HTMLResponse, response_model=None)
   343	async def trials_index(request: Request) -> HTMLResponse | RedirectResponse:
   344	    session = get_session(request)
   345	    if session is None:
   346	        return RedirectResponse(url="/signin", status_code=303)
   347	    store = request.app.state.store
   348	
   349	    status = _coerce_filter(request.query_params.get("status"), _TRIAL_STATUS_VALUES)
   350	    if status == _INVALID_FILTER:
   351	        return request.app.state.templates.TemplateResponse(
   352	            request,
   353	            "admin_trials.html",
   354	            {
   355	                "session": session,
   356	                "rows": [],
   357	                "selected_status": request.query_params.get("status", "*"),
   358	                "trial_statuses": _TRIAL_STATUS_VALUES,
   359	            },
   360	        )
   361	
   362	    try:
   363	        trials = store.list_trials(status=status)
   364	        impl_tasks = store.list_tasks(kind="implement")
   365	    except Exception:  # noqa: BLE001 — transport/store-domain
   366	        return _read_failure_response(request, "could not load trials")
   367	    impl_terminal_by_proposal: dict[str, bool] = {
   368	        t.payload.proposal_id: (t.state in {"completed", "failed"})
   369	        for t in impl_tasks
   370	    }
   371	
   372	    rows: list[dict[str, Any]] = []
   373	    for tr in trials:
   374	        orphaned = (
   375	            tr.status == "starting"
   376	            and impl_terminal_by_proposal.get(tr.proposal_id, False)
   377	        )
   378	        rows.append(
   379	            {
   380	                "trial_id": tr.trial_id,
   381	                "proposal_id": tr.proposal_id,
   382	                "status": tr.status,
   383	                "branch": tr.branch,
   384	                "commit_sha": tr.commit_sha,
   385	                "trial_commit_sha": tr.trial_commit_sha,
   386	                "started_at": tr.started_at,
   387	                "completed_at": tr.completed_at,
   388	                "orphaned": orphaned,
   389	            }
   390	        )
   391	
   392	    return request.app.state.templates.TemplateResponse(
   393	        request,
   394	        "admin_trials.html",
   395	        {
   396	            "session": session,
