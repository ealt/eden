   404	@router.get(
   405	    "/trials/{trial_id}/", response_class=HTMLResponse, response_model=None
   406	)
   407	async def trial_detail(
   408	    trial_id: str, request: Request
   409	) -> HTMLResponse | RedirectResponse:
   410	    session = get_session(request)
   411	    if session is None:
   412	        return RedirectResponse(url="/signin", status_code=303)
   413	    store = request.app.state.store
   414	    artifacts_dir = request.app.state.artifacts_dir
   415	
   416	    try:
   417	        trial = store.read_trial(trial_id)
   418	        proposal = store.read_proposal(trial.proposal_id)
   419	        events_full = store.replay()
   420	        related, total_related = _events_for_trial(
   421	            events_full, store, trial_id=trial_id, proposal_id=trial.proposal_id
   422	        )
   423	    except StorageNotFound:
   424	        raise
   425	    except Exception:  # noqa: BLE001 — transport/store-domain
   426	        return _read_failure_response(request, "could not load trial")
   427	
   428	    inline_artifact = read_trial_artifact(trial.artifacts_uri, artifacts_dir)
   429	
   430	    return request.app.state.templates.TemplateResponse(
   431	        request,
   432	        "admin_trial_detail.html",
   433	        {
   434	            "session": session,
   435	            "trial": trial,
   436	            "proposal": proposal,
   437	            "related_events": list(reversed(related))[:_TRIAL_DETAIL_EVENT_CAP],
   438	            "related_total": total_related,
   439	            "trial_artifact_inline": inline_artifact,
   440	        },
   441	    )
   442	
   443	
   444	def _events_for_trial(
   445	    events_full: list[Event],
   446	    store: Any,
   447	    *,
   448	    trial_id: str,
   449	    proposal_id: str,
   450	) -> tuple[list[Event], int]:
   451	    """Return (events_correlated_to_this_trial_in_replay_order, total_match_count).
   452	
   453	    Correlation per chunk-9e plan §A.5: trial-id direct match + task-id
   454	    match for the implement task that produced this trial + task-id
   455	    match for any evaluate task whose payload references this trial.
   456	    """
   457	    impl_task_ids = {
   458	        t.task_id
   459	        for t in store.list_tasks(kind="implement")
   460	        if t.payload.proposal_id == proposal_id
   461	    }
   462	    eval_task_ids = {
   463	        t.task_id
   464	        for t in store.list_tasks(kind="evaluate")
   465	        if t.payload.trial_id == trial_id
   466	    }
   467	    related: list[Event] = []
   468	    for ev in events_full:  # replay order
   469	        if ev.data.get("trial_id") == trial_id:
   470	            related.append(ev)
   471	            continue
   472	        tid = ev.data.get("task_id")
   473	        if tid is not None and (tid in impl_task_ids or tid in eval_task_ids):
   474	            related.append(ev)
   475	    return related, len(related)
   476	
   477	
   478	# ---------------------------------------------------------------------
   479	# Events
   480	# ---------------------------------------------------------------------
