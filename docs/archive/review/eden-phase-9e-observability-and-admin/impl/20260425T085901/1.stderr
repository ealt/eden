    87	def _claim_age_seconds(task: Task, now: datetime) -> float | None:
    88	    if task.claim is None:
    89	        return None
    90	    claimed_at = _parse_dt(task.claim.claimed_at)
    91	    if claimed_at is None:
    92	        return None
    93	    return (now - claimed_at).total_seconds()
