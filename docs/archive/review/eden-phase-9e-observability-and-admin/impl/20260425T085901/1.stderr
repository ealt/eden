    96	def _claim_expired(task: Task, now: datetime) -> bool:
    97	    if task.claim is None or task.claim.expires_at is None:
    98	        return False
    99	    expires_at = _parse_dt(task.claim.expires_at)
   100	    if expires_at is None:
   101	        return False
   102	    return expires_at < now
   103	
