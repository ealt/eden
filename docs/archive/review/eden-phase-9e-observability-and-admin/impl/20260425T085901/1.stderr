   530	# ---------------------------------------------------------------------
   531	# Work-ref GC
   532	# ---------------------------------------------------------------------
   533	
   534	
   535	@router.get("/work-refs/", response_class=HTMLResponse, response_model=None)
   536	async def work_refs_index(request: Request) -> HTMLResponse | RedirectResponse:
   537	    session = get_session(request)
   538	    if session is None:
   539	        return RedirectResponse(url="/signin", status_code=303)
   540	    repo = request.app.state.repo
   541	    outcome = _outcome(request, "deleted", "error", _REF_DELETE_OUTCOMES)
   542	    if repo is None:
   543	        return request.app.state.templates.TemplateResponse(
   544	            request,
   545	            "admin_work_refs.html",
   546	            {
   547	                "session": session,
   548	                "csrf_token": session.csrf,
   549	                "repo_enabled": False,
   550	                "groups": None,
   551	                "outcome": outcome,
   552	            },
   553	        )
   554	    store = request.app.state.store
   555	    try:
   556	        groups = _classify_work_refs(repo, store)
   557	    except Exception:  # noqa: BLE001 — git or transport
   558	        return _read_failure_response(request, "could not list work refs")
   559	    return request.app.state.templates.TemplateResponse(
   560	        request,
   561	        "admin_work_refs.html",
   562	        {
   563	            "session": session,
   564	            "csrf_token": session.csrf,
   565	            "repo_enabled": True,
   566	            "groups": groups,
   567	            "outcome": outcome,
   568	        },
   569	    )
   570	
   571	
   572	@router.post("/work-refs/delete", response_model=None)
   573	async def work_refs_delete(
   574	    request: Request,
   575	    ref_name: str = Form(""),
   576	    expected_old_sha: str = Form(""),  # noqa: ARG001 — accepted for symmetry, never trusted
   577	    csrf_token: str = Form(""),
   578	) -> RedirectResponse | HTMLResponse:
   579	    session = get_session(request)
   580	    if session is None:
   581	        return RedirectResponse(url="/signin", status_code=303)
   582	    if not csrf_ok(session, csrf_token):
   583	        return _csrf_failure_response()
   584	    repo = request.app.state.repo
   585	    if repo is None:
   586	        return RedirectResponse(
   587	            url="/admin/work-refs/?error=invalid-ref-name", status_code=303
   588	        )
   589	    if not _WORK_REF_RE.match(ref_name) or ".." in ref_name:
   590	        return RedirectResponse(
   591	            url="/admin/work-refs/?error=invalid-ref-name", status_code=303
   592	        )
   593	    store = request.app.state.store
   594	    groups = _classify_work_refs(repo, store)
   595	    target = None
   596	    for entry in (*groups["eligible"], *groups["orphan"]):
   597	        if entry["ref_name"] == ref_name:
   598	            target = entry
   599	            break
   600	    if target is None:
   601	        # Could be a not-eligible entry (still listed) or vanished.
   602	        for entry in groups["not_eligible"]:
   603	            if entry["ref_name"] == ref_name:
   604	                return RedirectResponse(
   605	                    url="/admin/work-refs/?error=not-eligible", status_code=303
   606	                )
   607	        return RedirectResponse(
   608	            url="/admin/work-refs/?error=not-found", status_code=303
   609	        )
   610	    live_sha = target["current_sha"]
   611	    from eden_git.repo import GitError
   612	
   613	    try:
   614	        repo.delete_ref(ref_name, expected_old_sha=live_sha)
   615	    except GitError as exc:
   616	        # CAS miss surfaces as exit 1 with stderr containing the
   617	        # "expected ... but is ..." text from update-ref. Anything
   618	        # else (permissions issues, broken repo, etc.) is a real
   619	        # failure that should not be silenced as ``ref-changed``.
   620	        stderr = (exc.stderr or "").lower()
   621	        if "expected" in stderr or exc.returncode == 1:
   622	            return RedirectResponse(
   623	                url="/admin/work-refs/?error=ref-changed", status_code=303
   624	            )
   625	        # Unexpected git failure — propagate to FastAPI's default
   626	        # 500 handler so the operator sees a real error page and
   627	        # the failure shows up in logs.
   628	        raise
   629	    return RedirectResponse(
   630	        url="/admin/work-refs/?deleted=ok", status_code=303
   631	    )
   632	
   633	
   634	def _classify_work_refs(repo: Any, store: Any) -> dict[str, list[dict[str, Any]]]:
   635	    """Group ``refs/heads/work/*`` refs by GC eligibility.
   636	
   637	    Ownership is keyed off exact ``trial.branch`` equality (chunk 9e
   638	    plan §A.7), not by parsing the ref name.
   639	    """
   640	    trials = store.list_trials()
   641	    branch_index: dict[str, Trial] = {
   642	        tr.branch: tr for tr in trials if tr.branch is not None
   643	    }
   644	    pairs = repo.list_refs("refs/heads/work/*")
   645	    eligible: list[dict[str, Any]] = []
   646	    not_eligible: list[dict[str, Any]] = []
   647	    orphan: list[dict[str, Any]] = []
   648	    for refname, current_sha in pairs:
   649	        branch_name = refname.removeprefix("refs/heads/")
   650	        trial = branch_index.get(branch_name)
   651	        entry: dict[str, Any] = {
   652	            "ref_name": refname,
   653	            "current_sha": current_sha,
   654	            "branch_name": branch_name,
   655	            "trial": trial,
   656	        }
   657	        if trial is None:
   658	            entry["reason"] = "no trial owns this ref"
   659	            orphan.append(entry)
   660	            continue
   661	        if not _trial_terminal_handled(trial):
   662	            entry["reason"] = (
   663	                f"trial is {trial.status}"
   664	                + (
   665	                    " (integrator has not yet promoted)"
   666	                    if trial.status == "success" and trial.trial_commit_sha is None
   667	                    else ""
   668	                )
   669	            )
   670	            not_eligible.append(entry)
   671	            continue
   672	        if trial.commit_sha != current_sha:
   673	            entry["reason"] = (
   674	                "ref SHA does not match trial.commit_sha (manual rewrite?)"
   675	            )
   676	            not_eligible.append(entry)
   677	            continue
   678	        entry["reason"] = (
   679	            f"trial {trial.trial_id} is {trial.status}; safe to delete"
   680	        )
   681	        eligible.append(entry)
   682	    return {
   683	        "eligible": eligible,
   684	        "not_eligible": not_eligible,
   685	        "orphan": orphan,
   686	    }
   687	
   688	
   689	# ---------------------------------------------------------------------
   690	# Helpers
   691	# ---------------------------------------------------------------------
   692	
   693	
   694	def _csrf_failure_response() -> HTMLResponse:
   695	    return HTMLResponse(content="CSRF token missing or invalid", status_code=403)
   696	
   697	
   698	def _read_failure_response(request: Request, message: str) -> HTMLResponse:
   699	    """Inline placeholder for transport-shaped read failures (plan §G).
   700	
   701	    We render the standard ``_error.html`` page with a 502 so the
   702	    operator sees a clear "transport failure; refresh to retry"
   703	    surface instead of an unhandled 500 from the underlying
   704	    ``StoreClient`` / ``GitRepo`` exception.
   705	    """
   706	    return request.app.state.templates.TemplateResponse(
   707	        request,
   708	        "_error.html",
   709	        {
   710	            "title": "Transport failure",
   711	            "message": (
   712	                f"{message}; refresh to retry. If the failure persists, "
   713	                "check the task-store-server logs."
   714	            ),
   715	        },
   716	        status_code=502,
   717	    )
   718	
   719	
   720	def _outcome(
   721	    request: Request,
   722	    ok_param: str,
   723	    err_param: str,
   724	    table: dict[str, tuple[str, str]],
   725	) -> dict[str, str] | None:
   726	    """Resolve the action-result banner by looking up the closed allowlist.
   727	
   728	    ``ok_param`` is the success querystring key (``reclaimed``,
   729	    ``deleted``); ``err_param`` is always ``error``. The value is
   730	    looked up in ``table``; an unknown value renders no banner.
   731	    """
   732	    raw_ok = request.query_params.get(ok_param)
   733	    raw_err = request.query_params.get(err_param)
   734	    raw = raw_err if raw_err else raw_ok
   735	    if raw is None:
   736	        return None
   737	    pair = table.get(raw)
   738	    if pair is None:
   739	        return None
   740	    level, message = pair
   741	    return {"level": level, "message": message}
   742	
   743	
   744	__all__ = ["router"]

