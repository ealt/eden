   264	@router.get("/tasks/{task_id}/", response_class=HTMLResponse, response_model=None)
   265	async def task_detail(
   266	    task_id: str, request: Request
   267	) -> HTMLResponse | RedirectResponse:
   268	    session = get_session(request)
   269	    if session is None:
   270	        return RedirectResponse(url="/signin", status_code=303)
   271	    store = request.app.state.store
   272	    now = _now_dt(request)
   273	
   274	    # ``StorageNotFound`` propagates to the app-wide 404 handler.
   275	    # Other exceptions (transport-shaped) get the inline placeholder.
   276	    try:
   277	        task = store.read_task(task_id)
   278	        events_full = store.replay()
   279	    except StorageNotFound:
   280	        raise
   281	    except Exception:  # noqa: BLE001 — transport/store-domain
   282	        return _read_failure_response(request, "could not load task")
   283	    related = [ev for ev in events_full if ev.data.get("task_id") == task_id]
   284	
   285	    reclaim_outcome = _outcome(request, "reclaimed", "error", _RECLAIM_OUTCOMES)
   286	    can_reclaim = task.state in {"claimed", "submitted"}
   287	    is_force = task.state == "submitted"
   288	
   289	    return request.app.state.templates.TemplateResponse(
   290	        request,
   291	        "admin_task_detail.html",
   292	        {
   293	            "session": session,
   294	            "csrf_token": session.csrf,
   295	            "task": task,
   296	            "payload_json": task.payload.model_dump(mode="json"),
   297	            "claim_age": _claim_age_seconds(task, now),
   298	            "claim_expired": _claim_expired(task, now),
   299	            "related_events": list(reversed(related))[:50],
   300	            "outcome": reclaim_outcome,
   301	            "can_reclaim": can_reclaim,
   302	            "is_force": is_force,
   303	        },
