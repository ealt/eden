   482	
   483	@router.get("/events/", response_class=HTMLResponse, response_model=None)
   484	async def events_index(request: Request) -> HTMLResponse | RedirectResponse:
   485	    session = get_session(request)
   486	    if session is None:
   487	        return RedirectResponse(url="/signin", status_code=303)
   488	    store = request.app.state.store
   489	
   490	    raw_limit = request.query_params.get("limit")
   491	    limit = _DEFAULT_EVENTS_LIMIT
   492	    if raw_limit is not None:
   493	        try:
   494	            limit = max(1, min(_MAX_EVENTS_LIMIT, int(raw_limit)))
   495	        except ValueError:
   496	            limit = _DEFAULT_EVENTS_LIMIT
   497	
   498	    type_filter = request.query_params.get("type") or None
   499	
   500	    try:
   501	        events_full = store.replay()
   502	    except Exception:  # noqa: BLE001 — transport/store-domain
   503	        return _read_failure_response(request, "could not load events")
   504	    total = len(events_full)
   505	
   506	    indexed: list[tuple[int, Event]] = []
   507	    for idx, ev in enumerate(events_full, start=1):
   508	        if type_filter is not None and ev.type != type_filter:
   509	            continue
   510	        indexed.append((idx, ev))
   511	
   512	    filtered_total = len(indexed)
   513	    sliced = indexed[-limit:]
   514	    rows = list(reversed(sliced))
   515	
   516	    return request.app.state.templates.TemplateResponse(
   517	        request,
   518	        "admin_events.html",
   519	        {
   520	            "session": session,
   521	            "rows": rows,
   522	            "limit": limit,
   523	            "total": total,
   524	            "filtered_total": filtered_total,
   525	            "type_filter": type_filter,
   526	        },
   527	    )
