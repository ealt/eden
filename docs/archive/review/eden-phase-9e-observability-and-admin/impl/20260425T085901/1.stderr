   105	def _parse_dt(raw: str | datetime | None) -> datetime | None:
   106	    if raw is None:
   107	        return None
   108	    if isinstance(raw, datetime):
   109	        return raw
   110	    try:
   111	        return datetime.fromisoformat(raw)
   112	    except ValueError:
   113	        return None
   114	
   115	
   116	def _trial_terminal_handled(trial: Trial) -> bool:
   117	    """Return True iff the trial has reached a terminal-and-handled status."""
   118	    if trial.status in {"error", "eval_error"}:
   119	        return True
   120	    return trial.status == "success" and trial.trial_commit_sha is not None
   121	
