     1	"""Postgres-specific tests for ``PostgresStore``.
     2	
     3	The parametrized conformance suite in the rest of this directory
     4	runs every public-API scenario against all three backends (memory,
     5	sqlite, postgres). This file holds **postgres-only** tests for
     6	behavior that's specific to the Postgres backend: reopen-on-an-
     7	existing-non-default-schema, migration idempotency, and DSN
     8	handling. Skipped without ``EDEN_TEST_POSTGRES_DSN``; CI's
     9	``python-test-postgres`` job sets it.
    10	"""
    11	
    12	from __future__ import annotations
    13	
    14	import os
    15	import secrets
    16	from collections.abc import Iterator
    17	
    18	import pytest
    19	from eden_contracts import MetricsSchema
    20	from eden_storage import InvalidPrecondition, PostgresStore
    21	
    22	_DSN = os.environ.get("EDEN_TEST_POSTGRES_DSN") or None
    23	
    24	pytestmark = pytest.mark.skipif(
    25	    _DSN is None,
    26	    reason="EDEN_TEST_POSTGRES_DSN not set",
    27	)
