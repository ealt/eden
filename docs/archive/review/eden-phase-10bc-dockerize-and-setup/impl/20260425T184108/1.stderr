     1	#!/usr/bin/env bash
     2	set -euo pipefail
     3	
     4	# setup-experiment — bootstrap an EDEN reference Compose stack for a
     5	# given experiment config. Reads a YAML config, generates (or
     6	# preserves) the secrets the stack needs, runs the one-shot
     7	# bare-repo init service, and writes everything into
     8	# `reference/compose/.env` + `reference/compose/experiment-config.yaml`
     9	# so `docker compose up -d --wait` brings the stack online.
    10	#
    11	# Idempotent: re-running on an already-configured stack preserves
    12	# existing secrets (POSTGRES_PASSWORD, EDEN_SHARED_TOKEN,
    13	# EDEN_SESSION_SECRET, GITEA_*) and re-runs the seed step (which
    14	# itself short-circuits on a previously-seeded repo).
    15	#
    16	# Usage:
    17	#   setup-experiment.sh <config.yaml> [--experiment-id <id>]
    18	#                                     [--shared-token <T>]
    19	#                                     [--postgres-password <P>]
    20	#                                     [--env-file <path>]
    21	
    22	usage() {
    23	    cat <<'EOF' >&2
    24	Usage:
    25	  setup-experiment.sh <config.yaml>
    26	                      [--experiment-id <id>]
    27	                      [--shared-token <T>]
    28	                      [--postgres-password <P>]
    29	                      [--env-file <path>]
    30	
    31	Generates `reference/compose/.env` and copies <config.yaml> to
    32	`reference/compose/experiment-config.yaml`, then seeds the bare
    33	repo via a one-shot `compose run --rm --no-deps eden-repo-init`
    34	call. Operator's next step is `docker compose up -d --wait`.
    35	EOF
    36	}
    37	
    38	# --- Tooling preflight ---
    39	for tool in docker python3; do
    40	    command -v "$tool" >/dev/null || {
    41	        echo "setup-experiment.sh requires '$tool' on PATH" >&2
    42	        exit 2
    43	    }
    44	done
    45	docker compose version >/dev/null || {
    46	    echo "setup-experiment.sh requires the 'docker compose' v2 plugin" >&2
    47	    exit 2
    48	}
    49	
    50	# --- Parse args ---
    51	CONFIG_PATH=""
    52	ENV_FILE=""
    53	EXPERIMENT_ID=""
    54	ARG_SHARED_TOKEN=""
    55	ARG_POSTGRES_PASSWORD=""
    56	
    57	require_value() {
    58	    # Validate that a flag's value is present, since `set -u` would
    59	    # turn a bare `$2` lookup into a confusing "unbound variable"
    60	    # error rather than a clear "missing argument" message.
    61	    local flag="$1" remaining="$2"
    62	    if [[ "$remaining" -lt 2 ]]; then
    63	        echo "$flag requires a value" >&2
    64	        usage
    65	        exit 2
    66	    fi
    67	}
    68	
    69	while [[ $# -gt 0 ]]; do
    70	    case "$1" in
    71	        --experiment-id)        require_value "$1" "$#"; EXPERIMENT_ID="$2";         shift 2 ;;
    72	        --shared-token)         require_value "$1" "$#"; ARG_SHARED_TOKEN="$2";      shift 2 ;;
    73	        --postgres-password)    require_value "$1" "$#"; ARG_POSTGRES_PASSWORD="$2"; shift 2 ;;
    74	        --env-file)             require_value "$1" "$#"; ENV_FILE="$2";              shift 2 ;;
    75	        -h|--help)              usage; exit 0 ;;
    76	        --*)                    echo "unknown flag: $1" >&2; usage; exit 2 ;;
    77	        *)
    78	            if [[ -z "$CONFIG_PATH" ]]; then
    79	                CONFIG_PATH="$1"
    80	            else
    81	                echo "unexpected positional arg: $1" >&2
    82	                usage
    83	                exit 2
    84	            fi
    85	            shift
    86	            ;;
    87	    esac
    88	done
    89	
    90	# Resolve absolute paths so this script works no matter where it
    91	# was invoked from (compute SCRIPT_DIR before we may need it for the
    92	# default config path below).
    93	SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    94	COMPOSE_DIR="$(cd "${SCRIPT_DIR}/../../compose" && pwd)"
    95	REPO_ROOT="$(cd "${COMPOSE_DIR}/../.." && pwd)"
    96	
    97	if [[ -z "$CONFIG_PATH" ]]; then
    98	    # Default to the repo's fixture experiment so re-running with no
    99	    # args is a no-friction smoke path.
   100	    CONFIG_PATH="${REPO_ROOT}/tests/fixtures/experiment/.eden/config.yaml"
   101	fi
   102	if [[ ! -f "$CONFIG_PATH" ]]; then
   103	    echo "config not found: $CONFIG_PATH" >&2
   104	    exit 2
   105	fi
   106	
   107	CONFIG_PATH="$(cd "$(dirname "$CONFIG_PATH")" && pwd)/$(basename "$CONFIG_PATH")"
   108	
   109	if [[ -z "$ENV_FILE" ]]; then
   110	    ENV_FILE="${COMPOSE_DIR}/.env"
   111	fi
   112	
   113	# --- Default experiment-id from the config's parent dir ---
   114	if [[ -z "$EXPERIMENT_ID" ]]; then
   115	    # `<some-path>/.eden/config.yaml` → use the directory containing `.eden`.
   116	    parent="$(dirname "$CONFIG_PATH")"
   117	    grandparent="$(dirname "$parent")"
   118	    if [[ "$(basename "$parent")" == ".eden" ]]; then
   119	        EXPERIMENT_ID="$(basename "$grandparent")"
   120	    else
   121	        EXPERIMENT_ID="$(basename "$parent")"
   122	    fi
   123	fi
   124	
   125	# --- Secret helpers ---
   126	gen_hex() {
   127	    # 32 bytes of hex.
   128	    python3 -c 'import secrets,sys; sys.stdout.write(secrets.token_hex(int(sys.argv[1])))' "${1:-32}"
   129	}
   130	
   131	# Read a key from an existing env file, returning empty if absent.
   132	read_env_key() {
   133	    local key="$1" file="$2"
   134	    if [[ -f "$file" ]]; then
   135	        # Strip surrounding quotes that an operator may have added.
   136	        sed -n "s/^${key}=\(.*\)$/\1/p" "$file" | head -n1
   137	    fi
   138	}
   139	
   140	# --- Resolve / preserve / generate secrets ---
   141	EXISTING_POSTGRES_PASSWORD="$(read_env_key POSTGRES_PASSWORD "$ENV_FILE")"
   142	POSTGRES_PASSWORD="${ARG_POSTGRES_PASSWORD:-${EXISTING_POSTGRES_PASSWORD:-$(gen_hex 32)}}"
   143	
   144	EXISTING_SHARED_TOKEN="$(read_env_key EDEN_SHARED_TOKEN "$ENV_FILE")"
   145	EDEN_SHARED_TOKEN="${ARG_SHARED_TOKEN:-${EXISTING_SHARED_TOKEN:-$(gen_hex 32)}}"
   146	
   147	EXISTING_SESSION_SECRET="$(read_env_key EDEN_SESSION_SECRET "$ENV_FILE")"
   148	EDEN_SESSION_SECRET="${EXISTING_SESSION_SECRET:-$(gen_hex 32)}"
   149	
   150	EXISTING_GITEA_SECRET_KEY="$(read_env_key GITEA_SECRET_KEY "$ENV_FILE")"
   151	GITEA_SECRET_KEY="${EXISTING_GITEA_SECRET_KEY:-$(gen_hex 32)}"
   152	
   153	EXISTING_GITEA_INTERNAL_TOKEN="$(read_env_key GITEA_INTERNAL_TOKEN "$ENV_FILE")"
   154	GITEA_INTERNAL_TOKEN="${EXISTING_GITEA_INTERNAL_TOKEN:-$(gen_hex 32)}"
   155	
   156	EXISTING_PG_HOST_PORT="$(read_env_key POSTGRES_HOST_PORT "$ENV_FILE")"
   157	POSTGRES_HOST_PORT="${EXISTING_PG_HOST_PORT:-5433}"
   158	
   159	EXISTING_GITEA_HOST_PORT="$(read_env_key GITEA_HOST_PORT "$ENV_FILE")"
   160	GITEA_HOST_PORT="${EXISTING_GITEA_HOST_PORT:-3001}"
   161	
   162	EXISTING_GITEA_SSH_HOST_PORT="$(read_env_key GITEA_SSH_HOST_PORT "$ENV_FILE")"
   163	GITEA_SSH_HOST_PORT="${EXISTING_GITEA_SSH_HOST_PORT:-2222}"
   164	
   165	EXISTING_WEB_UI_HOST_PORT="$(read_env_key WEB_UI_HOST_PORT "$ENV_FILE")"
   166	WEB_UI_HOST_PORT="${EXISTING_WEB_UI_HOST_PORT:-8090}"
   167	
   168	EXISTING_PLAN_TASKS="$(read_env_key EDEN_PLAN_TASKS "$ENV_FILE")"
   169	EDEN_PLAN_TASKS="${EXISTING_PLAN_TASKS:-3}"
   170	
   171	# --- Copy experiment config into compose dir ---
   172	cp "$CONFIG_PATH" "${COMPOSE_DIR}/experiment-config.yaml"
   173	
   174	# --- Write the partial .env (no EDEN_BASE_COMMIT_SHA yet) ---
   175	# Postgres DSN points at the in-network postgres service hostname.
   176	# Percent-encode the password so user-supplied passwords containing
   177	# reserved URI characters (`@`, `:`, `/`, `?`, `#`, …) don't break
   178	# the DSN. The auto-generated 32-byte hex passwords are
   179	# percent-encoding-safe by construction; this matters only when an
   180	# operator passes `--postgres-password <raw-string>`.
   181	POSTGRES_PASSWORD_ENC="$(python3 -c 'import sys, urllib.parse; sys.stdout.write(urllib.parse.quote(sys.argv[1], safe=""))' "$POSTGRES_PASSWORD")"
   182	EDEN_STORE_URL="postgresql://eden:${POSTGRES_PASSWORD_ENC}@postgres:5432/eden"
   183	
   184	ENV_TMP="$(mktemp)"
   185	cat >"$ENV_TMP" <<EOF
   186	# Generated by setup-experiment.sh — do not edit by hand. Re-run
   187	# the script to regenerate. Manual edits to secrets will be
   188	# preserved across re-runs (they are read back from this file).
   189	
   190	# --- 10a infrastructure ---
   191	POSTGRES_DB=eden
   192	POSTGRES_USER=eden
   193	POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
   194	POSTGRES_HOST_PORT=${POSTGRES_HOST_PORT}
   195	GITEA_SECRET_KEY=${GITEA_SECRET_KEY}
   196	GITEA_INTERNAL_TOKEN=${GITEA_INTERNAL_TOKEN}
   197	GITEA_HOST_PORT=${GITEA_HOST_PORT}
   198	GITEA_SSH_HOST_PORT=${GITEA_SSH_HOST_PORT}
   199	
   200	# --- 10b/c reference services ---
   201	EDEN_EXPERIMENT_ID=${EXPERIMENT_ID}
   202	EDEN_SHARED_TOKEN=${EDEN_SHARED_TOKEN}
   203	EDEN_SESSION_SECRET=${EDEN_SESSION_SECRET}
   204	EDEN_STORE_URL=${EDEN_STORE_URL}
   205	EDEN_PLAN_TASKS=${EDEN_PLAN_TASKS}
   206	WEB_UI_HOST_PORT=${WEB_UI_HOST_PORT}
   207	
   208	# Placeholder; replaced at the end of setup-experiment with the
   209	# real seed SHA. compose v2 validates ALL services' interpolation
   210	# on every operation, so we need *some* value here for `compose
   211	# build eden-repo-init` to succeed.
   212	EDEN_BASE_COMMIT_SHA=0000000000000000000000000000000000000000
   213	EOF
   214	
   215	mv "$ENV_TMP" "$ENV_FILE"
   216	
   217	# --- Build the shared image (so eden-repo-init can run) ---
   218	echo "--- building eden-reference:dev ---" >&2
   219	(cd "$COMPOSE_DIR" && docker compose --env-file "$ENV_FILE" build eden-repo-init >&2)
   220	
   221	# --- Seed the bare-repo volume ---
   222	echo "--- seeding eden-bare-repo volume ---" >&2
   223	SEED_OUTPUT="$(cd "$COMPOSE_DIR" && \
   224	    docker compose --env-file "$ENV_FILE" run --rm --no-deps eden-repo-init)"
   225	SEED_SHA="$(echo "$SEED_OUTPUT" | sed -nE 's/^EDEN_REPO_(SEEDED|ALREADY_SEEDED) sha=([0-9a-f]{40})$/\2/p' | head -n1)"
   226	if [[ -z "$SEED_SHA" ]]; then
   227	    echo "failed to parse seed SHA from eden-repo-init output:" >&2
   228	    echo "$SEED_OUTPUT" >&2
   229	    exit 1
   230	fi
   231	
   232	# Replace the placeholder zeros with the real SHA so the file has
   233	# exactly one definition (later definitions in env files don't
   234	# silently override earlier ones for every consumer — `grep ^X=`
   235	# patterns are happiest with a unique line). Use a portable sed
   236	# invocation that works on both BSD and GNU.
   237	TMP_REPLACE="$(mktemp)"
   238	sed -E "s/^EDEN_BASE_COMMIT_SHA=.*/EDEN_BASE_COMMIT_SHA=${SEED_SHA}/" \
   239	    "$ENV_FILE" > "$TMP_REPLACE"
   240	mv "$TMP_REPLACE" "$ENV_FILE"
   241	
   242	cat <<EOF
   243	setup-experiment complete.
   244	
   245	  experiment id:    ${EXPERIMENT_ID}
   246	  store URL:        ${EDEN_STORE_URL}
   247	  base commit SHA:  ${SEED_SHA}
   248	  env file:         ${ENV_FILE}
   249	
   250	Next steps:
   251	
   252	  cd ${COMPOSE_DIR}
   253	  docker compose --env-file .env up -d --wait
   254	  open http://localhost:${WEB_UI_HOST_PORT}/
   255	
   256	Re-running setup-experiment is safe; existing secrets are preserved.
   257	To pick up config changes, re-run setup-experiment + 'docker compose
   258	--env-file .env up -d' (recreates services on config drift).
   259	EOF

