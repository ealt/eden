    29	
    30	@pytest.fixture
    31	def schema_dsn() -> Iterator[str]:
    32	    """Yield a DSN scoped to a fresh schema; drop it on teardown.
    33	
    34	    Mirrors the per-test schema isolation in ``conftest.py`` so
    35	    these tests can construct ``PostgresStore`` directly without
    36	    going through the conformance-suite factory.
    37	    """
    38	    import psycopg
    39	    from psycopg import sql
    40	
    41	    schema = f"test_pg_{secrets.token_hex(8)}"
    42	    assert _DSN is not None
    43	    with psycopg.connect(_DSN, autocommit=True) as setup:
    44	        setup.execute(
    45	            sql.SQL("CREATE SCHEMA {}").format(sql.Identifier(schema))
    46	        )
    47	
    48	    sep = "&" if "?" in _DSN else "?"
    49	    scoped = f"{_DSN}{sep}options=-c%20search_path%3D{schema}"
    50	    try:
    51	        yield scoped
    52	    finally:
    53	        with psycopg.connect(_DSN, autocommit=True) as drop:
    54	            drop.execute(
    55	                sql.SQL("DROP SCHEMA IF EXISTS {} CASCADE").format(
    56	                    sql.Identifier(schema)
    57	                )
    58	            )
    59	
    60	
    61	def test_reopen_on_non_default_schema_does_not_re_run_migrations(
    62	    schema_dsn: str,
    63	) -> None:
    64	    """A second open against the same non-default schema must be a no-op.
    65	
    66	    Regression: before search-path-aware ``current_version``,
    67	    reopening an existing PostgresStore on a non-`public` schema
    68	    re-ran v1 migrations and failed on duplicate-table.
    69	    """
    70	    metrics = MetricsSchema.model_validate({"score": "real"})
    71	    store = PostgresStore("exp-1", schema_dsn, metrics_schema=metrics)
    72	    store.create_plan_task("plan-0001")
    73	    store.close()
    74	
    75	    # Reopen — must succeed and see the persisted task.
    76	    reopened = PostgresStore("exp-1", schema_dsn, metrics_schema=metrics)
    77	    try:
    78	        task = reopened.read_task("plan-0001")
    79	        assert task is not None
    80	        assert task.task_id == "plan-0001"
    81	    finally:
    82	        reopened.close()
    83	
    84	
    85	def test_reopen_with_different_experiment_id_rejected(schema_dsn: str) -> None:
    86	    """Chapter 8 §4.2 — experiment_id is part of the database identity."""
    87	    metrics = MetricsSchema.model_validate({"score": "real"})
    88	    PostgresStore("exp-A", schema_dsn, metrics_schema=metrics).close()
    89	
    90	    with pytest.raises(InvalidPrecondition):
    91	        PostgresStore("exp-B", schema_dsn, metrics_schema=metrics)
    92	
    93	
    94	def test_reopen_with_changed_metrics_schema_rejected(schema_dsn: str) -> None:
    95	    """Chapter 8 §4.2 — metrics_schema MUST NOT change for the lifetime of an experiment."""
    96	    PostgresStore(
    97	        "exp-1",
    98	        schema_dsn,
    99	        metrics_schema=MetricsSchema.model_validate({"score": "real"}),
   100	    ).close()
   101	
   102	    with pytest.raises(InvalidPrecondition):
   103	        PostgresStore(
   104	            "exp-1",
   105	            schema_dsn,
   106	            metrics_schema=MetricsSchema.model_validate(
   107	                {"score": "real", "extra": "integer"}
   108	            ),
   109	        )
   110	
   111	
   112	def test_reopen_inherits_persisted_metrics_schema(schema_dsn: str) -> None:
   113	    """Reopen with no schema arg inherits whatever was persisted."""
   114	    metrics = MetricsSchema.model_validate({"score": "real"})
   115	    PostgresStore("exp-1", schema_dsn, metrics_schema=metrics).close()
   116	
   117	    reopened = PostgresStore("exp-1", schema_dsn)
   118	    try:
   119	        # metrics validation should still work — the schema was
   120	        # rehydrated from the experiment row.
   121	        reopened.create_plan_task("plan-0001")
   122	    finally:
   123	        reopened.close()
   124	
   125	
   126	def test_event_id_counter_resumes_across_reopen(schema_dsn: str) -> None:
   127	    """The default event-id counter resumes from MAX(seq) + 1 on reopen.
   128	
   129	    Without resumption, two stores on the same database would emit
   130	    duplicate ``event_id`` values and violate the UNIQUE constraint.
   131	    """
   132	    metrics = MetricsSchema.model_validate({"score": "real"})
   133	    store = PostgresStore("exp-1", schema_dsn, metrics_schema=metrics)
   134	    store.create_plan_task("plan-0001")
   135	    first_event_count = len(list(store.events()))
   136	    store.close()
   137	
   138	    reopened = PostgresStore("exp-1", schema_dsn, metrics_schema=metrics)
   139	    try:
   140	        # Create another task — exercising another event insert. If
   141	        # the counter restarted from 1, the second store would
   142	        # collide on `evt-000001` (which the first store already
   143	        # used).
   144	        reopened.create_plan_task("plan-0002")
   145	        all_events = list(reopened.events())
   146	        assert len(all_events) > first_event_count
   147	    finally:
   148	        reopened.close()

