    39	            experiment_id=experiment_id,
    40	            token_factory=token_factory,
    41	            **kwargs,
    42	        )
    43	
    44	    return _make
    45	
    46	
    47	def _sqlite_factory(
    48	    token_factory: Callable[[], str],
    49	    tmp_path: Path,
    50	) -> Callable[..., Store]:
    51	    counter = itertools.count(1)
    52	
    53	    def _make(experiment_id: str = "exp-test", **kwargs: Any) -> Store:
    54	        # Each call gets its own database so the tests that create
    55	        # multiple stores (e.g. an AlreadyExists collision test)
    56	        # don't share state.
    57	        db_path = tmp_path / f"store-{next(counter):04d}.db"
    58	        return SqliteStore(
    59	            experiment_id,
    60	            db_path,
    61	            token_factory=token_factory,
    62	            **kwargs,
    63	        )
    64	
    65	    return _make
    66	
    67	
    68	def _postgres_factory(
    69	    token_factory: Callable[[], str],
    70	    tmp_path: Path,  # noqa: ARG001 - uniform factory signature
    71	    dsn: str,
    72	    cleanup: list[Callable[[], None]],
    73	) -> Callable[..., Store]:
    74	    """Build a factory that issues PostgresStores on a per-test schema.
    75	
    76	    Each call creates a fresh ``test_<rand>`` schema, sets it as the
    77	    sole entry on ``search_path``, runs the schema migration there,
    78	    and registers a teardown that drops the schema. Two factory
    79	    calls in the same test (e.g. AlreadyExists collision tests) get
    80	    distinct schemas, mirroring SqliteStore's per-call distinct
    81	    db-file behavior.
    82	    """
    83	    import psycopg
    84	    from psycopg import sql
    85	
    86	    counter = itertools.count(1)
    87	
    88	    def _make(experiment_id: str = "exp-test", **kwargs: Any) -> Store:
    89	        schema = f"test_{secrets.token_hex(8)}_{next(counter):04d}"
    90	        # Pre-create the schema. PostgresStore opens its own
    91	        # connection with `search_path` overridden so all DDL +
    92	        # DML lands inside it.
    93	        with psycopg.connect(dsn, autocommit=True) as setup:
    94	            setup.execute(
    95	                sql.SQL("CREATE SCHEMA {}").format(sql.Identifier(schema))
    96	            )
    97	
    98	        store_dsn = dsn
    99	        # psycopg honors `options=-csearch_path=...` in the libpq
   100	        # URL; appending it as a query keyword is ergonomic.
   101	        sep = "&" if "?" in store_dsn else "?"
   102	        store_dsn = (
   103	            f"{store_dsn}{sep}options="
   104	            f"-c%20search_path%3D{schema}"
   105	        )
   106	        store = PostgresStore(
   107	            experiment_id,
   108	            store_dsn,
   109	            token_factory=token_factory,
   110	            **kwargs,
   111	        )
   112	
   113	        def _drop() -> None:
   114	            store.close()
   115	            with psycopg.connect(dsn, autocommit=True) as drop:
   116	                drop.execute(
   117	                    sql.SQL("DROP SCHEMA IF EXISTS {} CASCADE").format(
   118	                        sql.Identifier(schema)
   119	                    )
   120	                )
   121	
   122	        cleanup.append(_drop)
   123	        return store
   124	
   125	    return _make
   126	
   127	
   128	def _postgres_dsn() -> str | None:
   129	    return os.environ.get("EDEN_TEST_POSTGRES_DSN") or None
   130	
   131	
   132	_BACKEND_NAMES: list[str] = ["memory", "sqlite", "postgres"]
   133	
   134	
   135	@pytest.fixture(params=_BACKEND_NAMES, ids=_BACKEND_NAMES)
   136	def make_store(
   137	    request: pytest.FixtureRequest,
   138	    token_sequence: Callable[[], str],
   139	    tmp_path: Path,
   140	) -> Iterator[Callable[..., Store]]:
   141	    """Factory fixture parametrized across every backend.
   142	
   143	    Tests that take ``make_store`` run once per backend. The
   144	    ``postgres`` parametrization skips when ``EDEN_TEST_POSTGRES_DSN``
   145	    is unset; CI sets it and runs the parametrized rows.
   146	    """
   147	    name = request.param
   148	    if name == "memory":
   149	        yield _memory_factory(token_sequence, tmp_path)
   150	        return
   151	    if name == "sqlite":
   152	        yield _sqlite_factory(token_sequence, tmp_path)
   153	        return
   154	    if name == "postgres":
   155	        dsn = _postgres_dsn()
   156	        if dsn is None:
   157	            pytest.skip("EDEN_TEST_POSTGRES_DSN not set")
   158	        cleanup: list[Callable[[], None]] = []
   159	        try:
   160	            yield _postgres_factory(token_sequence, tmp_path, dsn, cleanup)
   161	        finally:
   162	            for fn in reversed(cleanup):
   163	                with contextlib.suppress(Exception):
   164	                    fn()
   165	        return
   166	    raise AssertionError(f"unknown backend {name!r}")
   167	
   168	
   169	@pytest.fixture
