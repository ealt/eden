     1	"""Postgres schema + migrations for ``PostgresStore``.
     2	
     3	Same shape as [`_schema.py`](_schema.py) (the SQLite version) with
     4	type substitutions: ``TEXT`` → ``text``, ``AUTOINCREMENT`` →
     5	``BIGINT GENERATED ALWAYS AS IDENTITY``. ``data`` stays as ``text``
     6	(rather than ``jsonb``) so reads are byte-for-byte parallel to
     7	``SqliteStore``; the JSON validation that ``jsonb`` would add at
     8	write time isn't worth the dict-vs-string read-path divergence at
     9	this stage. Migrating columns to ``jsonb`` is a future concern.
    10	
    11	Migrations are linear; ``schema_version`` holds the single highest
    12	version applied. Adding a future migration appends to
    13	``_MIGRATIONS`` and lets ``ensure_schema`` run it.
    14	"""
    15	
    16	from __future__ import annotations
    17	
    18	from collections.abc import Callable
    19	from typing import Any
    20	
    21	_V1_STATEMENTS: list[str] = [
    22	    """
    23	    CREATE TABLE experiment (
    24	        experiment_id text NOT NULL PRIMARY KEY,
    25	        metrics_schema text
    26	    )
    27	    """,
    28	    """
    29	    CREATE TABLE task (
    30	        task_id text NOT NULL PRIMARY KEY,
    31	        kind text NOT NULL,
    32	        state text NOT NULL,
    33	        data text NOT NULL
    34	    )
    35	    """,
    36	    "CREATE INDEX task_by_kind_state ON task(kind, state)",
    37	    """
    38	    CREATE TABLE submission (
    39	        task_id text NOT NULL PRIMARY KEY,
    40	        kind text NOT NULL,
    41	        data text NOT NULL,
    42	        FOREIGN KEY(task_id) REFERENCES task(task_id)
    43	    )
    44	    """,
    45	    """
    46	    CREATE TABLE proposal (
    47	        proposal_id text NOT NULL PRIMARY KEY,
    48	        state text NOT NULL,
    49	        data text NOT NULL
    50	    )
    51	    """,
    52	    "CREATE INDEX proposal_by_state ON proposal(state)",
    53	    """
    54	    CREATE TABLE trial (
    55	        trial_id text NOT NULL PRIMARY KEY,
    56	        status text NOT NULL,
    57	        data text NOT NULL
    58	    )
    59	    """,
    60	    "CREATE INDEX trial_by_status ON trial(status)",
    61	    """
    62	    CREATE TABLE event (
    63	        seq BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    64	        event_id text NOT NULL UNIQUE,
    65	        type text NOT NULL,
    66	        occurred_at text NOT NULL,
    67	        experiment_id text NOT NULL,
    68	        data text NOT NULL
    69	    )
    70	    """,
    71	]
    72	
    73	
    74	def _apply_v1(cur: Any) -> None:
    75	    for stmt in _V1_STATEMENTS:
    76	        cur.execute(stmt)
    77	
    78	
    79	_MIGRATIONS: list[Callable[[Any], None]] = [_apply_v1]
    80	
    81	
    82	def current_version(cur: Any) -> int:
    83	    """Return the applied schema version, or 0 if uninitialized.
    84	
    85	    Resolves ``schema_version`` against the active ``search_path`` —
    86	    not hard-coded to ``public.schema_version`` — so a store opened
    87	    against a non-default schema (e.g. the per-test schema in
    88	    ``tests/conftest.py``) sees its own migrations table on reopen.
    89	    Hard-coding ``public.schema_version`` would always probe the
    90	    default schema and treat every reopen as a fresh database,
    91	    re-running v1 migrations and failing on duplicate-table errors.
    92	    """
    93	    cur.execute("SELECT to_regclass('schema_version') IS NOT NULL")
    94	    row = cur.fetchone()
    95	    if not row or not row[0]:
    96	        return 0
    97	    cur.execute("SELECT COALESCE(MAX(version), 0) FROM schema_version")
    98	    row = cur.fetchone()
    99	    return int(row[0] or 0)
   100	
   101	
   102	def ensure_schema(conn: Any) -> None:
   103	    """Apply every pending migration, in order, under one transaction.
   104	
   105	    ``conn`` must be a psycopg ``Connection``. Migrations run inside
   106	    an explicit BEGIN/COMMIT block so a partial DDL failure rolls
   107	    back cleanly regardless of the connection's autocommit setting.
   108	    Idempotent: re-running on an up-to-date database is a no-op.
   109	    """
   110	    with conn.cursor() as cur:
   111	        # Bootstrap table outside the transaction so re-running is
   112	        # cheap and the ``current_version`` probe never errors on a
   113	        # missing relation.
   114	        cur.execute(
   115	            "CREATE TABLE IF NOT EXISTS schema_version "
   116	            "(version INTEGER NOT NULL PRIMARY KEY)"
   117	        )
   118	        applied = current_version(cur)
   119	        target = len(_MIGRATIONS)
   120	        if applied >= target:
   121	            return
   122	        cur.execute("BEGIN")
   123	        try:
   124	            for version in range(applied + 1, target + 1):
   125	                _MIGRATIONS[version - 1](cur)
   126	                cur.execute(
   127	                    "INSERT INTO schema_version(version) VALUES (%s)",
   128	                    (version,),
   129	                )
   130	        except BaseException:
   131	            cur.execute("ROLLBACK")
   132	            raise
   133	        cur.execute("COMMIT")

