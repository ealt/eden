     1	"""Shared type aliases and validators for EDEN contract models.
     2	
     3	Every pattern here mirrors a pattern in the spec/v0 JSON Schemas. When a
     4	schema changes, the corresponding alias here changes in lockstep.
     5	"""
     6	
     7	from datetime import datetime
     8	from typing import Annotated, Any
     9	
    10	from pydantic import AfterValidator, BeforeValidator, StringConstraints
    11	from rfc3986_validator import validate_rfc3986
    12	
    13	DATETIME_PATTERN = r"^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\.[0-9]+)?Z$"
    14	
    15	COMMIT_SHA_PATTERN = r"^[0-9a-f]{40}([0-9a-f]{24})?$"
    16	
    17	
    18	def _check_datetime(value: str) -> str:
    19	    # The regex shape is a necessary pre-filter, but accepts impossible values
    20	    # like month 99. fromisoformat (3.11+) accepts trailing "Z" and parses the
    21	    # components strictly, so it catches non-real dates.
    22	    datetime.fromisoformat(value)
    23	    return value
    24	
    25	
    26	def _check_uri(value: str) -> str:
    27	    if not validate_rfc3986(value, rule="URI"):
    28	        raise ValueError(f"not a valid RFC 3986 URI: {value!r}")
    29	    return value
    30	
    31	
    32	def _reject_none(value: Any) -> Any:
    33	    if value is None:
    34	        raise ValueError(
    35	            "field may be absent but MUST NOT be null; JSON Schema "
    36	            "rejects explicit null for optional typed fields"
    37	        )
    38	    return value
    39	
    40	
    41	DateTimeStr = Annotated[
    42	    str,
    43	    StringConstraints(pattern=DATETIME_PATTERN),
    44	    AfterValidator(_check_datetime),
    45	]
    46	"""UTC ISO-8601 datetime string with a trailing ``Z``; must be a real datetime."""
    47	
    48	CommitSha = Annotated[str, StringConstraints(pattern=COMMIT_SHA_PATTERN)]
    49	"""Lowercase hex SHA-1 (40 chars) or SHA-256 (64 chars) commit identifier."""
    50	
    51	UriStr = Annotated[str, AfterValidator(_check_uri)]
    52	"""URI string — must have a scheme, per RFC 3986 (schema ``format: uri``)."""
    53	
    54	NotNone = BeforeValidator(_reject_none)
    55	"""Annotate optional fields to reject explicit ``null`` on input while allowing absence."""

