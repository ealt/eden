     1	"""Shared fixtures: schema registry, per-schema validators, model validators.
     2	
     3	The parity tests need to run each case twice — once against the Pydantic
     4	model and once against the hand-authored JSON Schema. This conftest wires
     5	up both paths over the same case corpus so they stay in sync.
     6	
     7	A custom ``FormatChecker`` enables ``uri`` and ``date-time`` format
     8	validation on the schema side; jsonschema's default does not enforce
     9	``format`` keywords unless a checker is supplied. The model side enforces
    10	the same semantics in :mod:`eden_contracts._common`.
    11	"""
    12	
    13	from __future__ import annotations
    14	
    15	import json
    16	from collections.abc import Callable
    17	from datetime import datetime
    18	from pathlib import Path
    19	from typing import Any
    20	
    21	from eden_contracts import (
    22	    Event,
    23	    ExperimentConfig,
    24	    MetricsSchema,
    25	    Proposal,
    26	    TaskAdapter,
    27	    Trial,
    28	)
    29	from jsonschema import Draft202012Validator, FormatChecker
    30	from referencing import Registry, Resource
    31	from referencing.jsonschema import DRAFT202012
    32	from rfc3986_validator import validate_rfc3986
    33	
    34	SCHEMAS_DIR: Path = Path(__file__).resolve().parents[4] / "spec" / "v0" / "schemas"
    35	"""Resolves to ``<repo>/spec/v0/schemas``."""
    36	
    37	BASE_URI: str = "https://eden.local/schemas/"
    38	"""Synthetic base URI so relative ``$ref``s between schema files resolve."""
    39	
    40	MODEL_NAMES: tuple[str, ...] = (
    41	    "experiment-config",
    42	    "task",
    43	    "event",
    44	    "proposal",
    45	    "trial",
    46	    "metrics-schema",
    47	)
    48	
    49	
    50	_FORMAT_CHECKER = FormatChecker()
    51	
    52	
    53	@_FORMAT_CHECKER.checks("uri", raises=ValueError)
    54	def _check_uri(instance: Any) -> bool:
    55	    if not isinstance(instance, str):
    56	        return True
    57	    if not validate_rfc3986(instance, rule="URI"):
    58	        raise ValueError(f"not a valid RFC 3986 URI: {instance!r}")
    59	    return True
    60	
    61	
    62	@_FORMAT_CHECKER.checks("date-time", raises=ValueError)
    63	def _check_datetime(instance: Any) -> bool:
    64	    if not isinstance(instance, str):
    65	        return True
    66	    datetime.fromisoformat(instance)
    67	    return True
    68	
    69	
    70	def _build_registry() -> Registry:
    71	    registry: Registry = Registry()
    72	    for path in SCHEMAS_DIR.glob("*.schema.json"):
    73	        schema = json.loads(path.read_text())
    74	        resource = Resource.from_contents(schema, default_specification=DRAFT202012)
    75	        registry = registry.with_resource(uri=f"{BASE_URI}{path.name}", resource=resource)
    76	    return registry
    77	
    78	
    79	_REGISTRY: Registry = _build_registry()
    80	
    81	
    82	def schema_validator(name: str) -> Draft202012Validator:
    83	    """Return a validator for ``<name>.schema.json`` with refs + formats enforced."""
    84	    return Draft202012Validator(
    85	        schema={"$ref": f"{BASE_URI}{name}.schema.json"},
    86	        registry=_REGISTRY,
    87	        format_checker=_FORMAT_CHECKER,
    88	    )
    89	
    90	
    91	_MODEL_VALIDATORS: dict[str, Callable[[Any], object]] = {
    92	    "experiment-config": ExperimentConfig.model_validate,
    93	    "task": TaskAdapter.validate_python,
    94	    "event": Event.model_validate,
    95	    "proposal": Proposal.model_validate,
    96	    "trial": Trial.model_validate,
    97	    "metrics-schema": MetricsSchema.model_validate,
    98	}
    99	
   100	
   101	def model_validate(name: str, data: Any) -> object:
   102	    """Validate ``data`` with the Pydantic model bound to schema ``name``."""
   103	    return _MODEL_VALIDATORS[name](data)

