     1	"""Shared type aliases and validators for EDEN contract models.
     2	
     3	Every pattern here mirrors a pattern in the spec/v0 JSON Schemas. When a
     4	schema changes, the corresponding alias here changes in lockstep.
     5	"""
     6	
     7	from datetime import datetime
     8	from typing import Annotated, Any
     9	from urllib.parse import urlparse
    10	
    11	from pydantic import AfterValidator, BeforeValidator, StringConstraints
    12	
    13	DATETIME_PATTERN = r"^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\.[0-9]+)?Z$"
    14	
    15	COMMIT_SHA_PATTERN = r"^[0-9a-f]{40}([0-9a-f]{24})?$"
    16	
    17	
    18	def _check_datetime(value: str) -> str:
    19	    # The regex shape is a necessary pre-filter, but accepts impossible values
    20	    # like month 99. fromisoformat (3.11+) accepts trailing "Z" and parses the
    21	    # components strictly, so it catches non-real dates.
    22	    datetime.fromisoformat(value)
    23	    return value
    24	
    25	
    26	def _check_uri(value: str) -> str:
    27	    parts = urlparse(value)
    28	    if not parts.scheme:
    29	        raise ValueError(f"not a valid URI: {value!r}")
    30	    return value
    31	
    32	
    33	def _reject_none(value: Any) -> Any:
    34	    if value is None:
    35	        raise ValueError(
    36	            "field may be absent but MUST NOT be null; JSON Schema "
    37	            "rejects explicit null for optional typed fields"
    38	        )
    39	    return value
    40	
    41	
    42	DateTimeStr = Annotated[
    43	    str,
    44	    StringConstraints(pattern=DATETIME_PATTERN),
    45	    AfterValidator(_check_datetime),
    46	]
    47	"""UTC ISO-8601 datetime string with a trailing ``Z``; must be a real datetime."""
    48	
    49	CommitSha = Annotated[str, StringConstraints(pattern=COMMIT_SHA_PATTERN)]
    50	"""Lowercase hex SHA-1 (40 chars) or SHA-256 (64 chars) commit identifier."""
    51	
    52	UriStr = Annotated[str, AfterValidator(_check_uri)]
    53	"""URI string — must have a scheme, per RFC 3986 (schema ``format: uri``)."""
    54	
    55	NotNone = BeforeValidator(_reject_none)
    56	"""Annotate optional fields to reject explicit ``null`` on input while allowing absence."""

