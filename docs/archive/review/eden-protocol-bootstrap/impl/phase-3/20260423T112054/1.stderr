     1	"""Shared fixtures: schema registry, per-schema validators, model validators.
     2	
     3	The parity tests need to run each case twice — once against the Pydantic
     4	model and once against the hand-authored JSON Schema. This conftest wires
     5	up both paths over the same case corpus so they stay in sync.
     6	
     7	A custom ``FormatChecker`` enables ``uri`` and ``date-time`` format
     8	validation on the schema side; jsonschema's default does not enforce
     9	``format`` keywords unless a checker is supplied. The model side enforces
    10	the same semantics in :mod:`eden_contracts._common`.
    11	"""
    12	
    13	from __future__ import annotations
    14	
    15	import json
    16	from collections.abc import Callable
    17	from datetime import datetime
    18	from pathlib import Path
    19	from typing import Any
    20	from urllib.parse import urlparse
    21	
    22	from eden_contracts import (
    23	    Event,
    24	    ExperimentConfig,
    25	    MetricsSchema,
    26	    Proposal,
    27	    TaskAdapter,
    28	    Trial,
    29	)
    30	from jsonschema import Draft202012Validator, FormatChecker
    31	from referencing import Registry, Resource
    32	from referencing.jsonschema import DRAFT202012
    33	
    34	SCHEMAS_DIR: Path = Path(__file__).resolve().parents[4] / "spec" / "v0" / "schemas"
    35	"""Resolves to ``<repo>/spec/v0/schemas``."""
    36	
    37	BASE_URI: str = "https://eden.local/schemas/"
    38	"""Synthetic base URI so relative ``$ref``s between schema files resolve."""
    39	
    40	MODEL_NAMES: tuple[str, ...] = (
    41	    "experiment-config",
    42	    "task",
    43	    "event",
    44	    "proposal",
    45	    "trial",
    46	    "metrics-schema",
    47	)
    48	
    49	
    50	_FORMAT_CHECKER = FormatChecker()
    51	
    52	
    53	@_FORMAT_CHECKER.checks("uri", raises=ValueError)
    54	def _check_uri(instance: Any) -> bool:
    55	    if not isinstance(instance, str):
    56	        return True
    57	    parts = urlparse(instance)
    58	    if not parts.scheme:
    59	        raise ValueError(f"not a valid URI: {instance!r}")
    60	    return True
    61	
    62	
    63	@_FORMAT_CHECKER.checks("date-time", raises=ValueError)
    64	def _check_datetime(instance: Any) -> bool:
    65	    if not isinstance(instance, str):
    66	        return True
    67	    datetime.fromisoformat(instance)
    68	    return True
    69	
    70	
    71	def _build_registry() -> Registry:
    72	    registry: Registry = Registry()
    73	    for path in SCHEMAS_DIR.glob("*.schema.json"):
    74	        schema = json.loads(path.read_text())
    75	        resource = Resource.from_contents(schema, default_specification=DRAFT202012)
    76	        registry = registry.with_resource(uri=f"{BASE_URI}{path.name}", resource=resource)
    77	    return registry
    78	
    79	
    80	_REGISTRY: Registry = _build_registry()
    81	
    82	
    83	def schema_validator(name: str) -> Draft202012Validator:
    84	    """Return a validator for ``<name>.schema.json`` with refs + formats enforced."""
    85	    return Draft202012Validator(
    86	        schema={"$ref": f"{BASE_URI}{name}.schema.json"},
    87	        registry=_REGISTRY,
    88	        format_checker=_FORMAT_CHECKER,
    89	    )
    90	
    91	
    92	_MODEL_VALIDATORS: dict[str, Callable[[Any], object]] = {
    93	    "experiment-config": ExperimentConfig.model_validate,
    94	    "task": TaskAdapter.validate_python,
    95	    "event": Event.model_validate,
    96	    "proposal": Proposal.model_validate,
    97	    "trial": Trial.model_validate,
    98	    "metrics-schema": MetricsSchema.model_validate,
    99	}
   100	
   101	
   102	def model_validate(name: str, data: Any) -> object:
   103	    """Validate ``data`` with the Pydantic model bound to schema ``name``."""
   104	    return _MODEL_VALIDATORS[name](data)

