import json
from pathlib import Path
from jsonschema import Draft202012Validator, FormatChecker
from referencing import Registry, Resource
from referencing.jsonschema import DRAFT202012
from urllib.parse import urlparse
from datetime import datetime

schemas_dir = Path('spec/v0/schemas')
registry = Registry()
for path in schemas_dir.glob('*.schema.json'):
    registry = registry.with_resource(uri=f'https://eden.local/schemas/{path.name}', resource=Resource.from_contents(json.loads(path.read_text()), default_specification=DRAFT202012))
fc = FormatChecker()
@fc.checks('uri', raises=ValueError)
def _check_uri(instance):
    if not isinstance(instance, str):
        return True
    parts = urlparse(instance)
    if not parts.scheme:
        raise ValueError('bad')
    return True
validator = Draft202012Validator(schema={'"'$ref'"':'https://eden.local/schemas/proposal.schema.json'}, registry=registry, format_checker=fc)
for uri in ['http://exa mple.com/path', 'http:', 'mailto:test@example.com']:
    data = {'proposal_id':'p','experiment_id':'e','slug':'x','priority':1,'parent_commits':['a'*40],'artifacts_uri':uri,'state':'drafting','created_at':'2026-04-23T12:00:00Z'}
    try:
        validator.validate(data)
    except Exception as e:
        print(uri, 'ERR', type(e).__name__, e)
    else:
        print(uri, 'OK')
