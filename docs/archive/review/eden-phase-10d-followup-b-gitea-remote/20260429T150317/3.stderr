    36	def run_orchestrator_loop(
    37	    *,
    38	    store: Store,
    39	    integrator: Integrator,
    40	    plan_task_ids: list[str],
    41	    implement_task_prefix: str,
    42	    evaluate_task_prefix: str,
    43	    poll_interval: float,
    44	    max_quiescent_iterations: int,
    45	    stop: StopFlag,
    46	) -> None:
    47	    """Seed plan tasks, then loop finalize + dispatch + integrate to quiescence.
    48	
    49	    Returns when either ``stop`` is set or the orchestrator has observed
    50	    ``max_quiescent_iterations`` consecutive iterations with no progress.
    51	    """
    52	    for task_id in plan_task_ids:
    53	        try:
    54	            store.create_plan_task(task_id)
    55	        except AlreadyExists as exc:
    56	            # Restart-safe: a previous orchestrator already seeded this
    57	            # task. Anything else (transport, auth, illegal-transition)
    58	            # surfaces immediately.
    59	            log.info("plan_task_seed_skip", task_id=task_id, reason=str(exc))
    60	
    61	    implement_factory = make_id_factory(implement_task_prefix)
    62	    evaluate_factory = make_id_factory(evaluate_task_prefix)
