    24	def make_id_factory(prefix: str) -> Callable[[], str]:
    25	    """Return a factory that produces ``<prefix><short-uuid>`` IDs.
    26	
    27	    UUIDs avoid cross-restart collisions on orchestrator-generated IDs.
    28	    """
