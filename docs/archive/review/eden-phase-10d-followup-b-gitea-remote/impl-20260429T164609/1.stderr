   193	def test_integrate_rolls_back_local_on_remote_rejection(tmp_path: Path) -> None:
   194	    """Push race: another integrator already wrote a different SHA at the same trial ref."""
   195	    store, remote, clone, base = _setup(tmp_path)
   196	    trial = _seed_success_trial(store=store, repo=clone, base_sha=base)
   197	    integrator = _make_integrator(store, clone)
   198	
   199	    # Pre-publish a different commit at the trial ref on the remote so
   200	    # our --force-with-lease=zero push is rejected.
   201	    blob = remote.write_blob(b"intruder\n")
   202	    tree = remote.write_tree_from_entries(
   203	        [TreeEntry(mode="100644", type="blob", sha=blob, path="THEIRS")]
   204	    )
   205	    intruder = remote.commit_tree(
   206	        tree,
   207	        parents=[base],
   208	        message="intruder",
   209	        author=TEST_AUTHOR,
   210	        author_date=FIXED_DATE,
   211	        committer_date=FIXED_DATE,
   212	    )
   213	    branch_ref = f"refs/heads/trial/{trial.trial_id}-p0"
   214	    remote.create_ref(branch_ref, intruder)
   215	
   216	    with pytest.raises(RefRefused):
   217	        integrator.integrate(trial.trial_id)
   218	
   219	    # Local ref rolled back; remote untouched.
   220	    assert clone.resolve_ref(branch_ref) is None
   221	    assert remote.resolve_ref(branch_ref) == intruder
   222	    # Store still has trial as `success` (no integrate_trial happened).
   223	    after = store.read_trial(trial.trial_id)
   224	    assert after.trial_commit_sha is None
