   379	def test_integrate_indeterminate_push_remote_landed_runs_4a_and_4b(
   380	    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
   381	) -> None:
   382	    """Step 2 transport-fails AFTER the remote applied the ref → 4a + 4b.
   383	
   384	    Drives `_reconcile_indeterminate_push`'s "remote == our SHA"
   385	    branch: push raises GitTransportError but the remote actually
   386	    accepted the ref before the ack was lost. The ladder must
   387	    detect this via ls_remote and run BOTH compensating deletes
   388	    when the subsequent store.integrate_trial fails.
   389	    """
   390	    store, remote, clone, base = _setup(tmp_path)
   391	    trial = _seed_success_trial(store=store, repo=clone, base_sha=base)
   392	    integrator = _make_integrator(store, clone)
   393	
   394	    real_push = clone.push_ref
   395	    real_lsremote = clone.ls_remote
   396	
   397	    def _push_then_transport_fail(ref, *args, **kwargs):
   398	        # Actually do the push (so the remote DID apply the ref)
   399	        # then raise as if the ack was lost.
   400	        real_push(ref, *args, **kwargs)
   401	        raise GitTransportError(
   402	            ["push", "origin", ref], 128, "", "fatal: unable to access (simulated)"
   403	        )
   404	
   405	    monkeypatch.setattr(clone, "push_ref", _push_then_transport_fail)
   406	
   407	    def _boom(*args: object, **kwargs: object) -> None:
   408	        raise DispatchError("simulated store outage")
   409	    monkeypatch.setattr(store, "integrate_trial", _boom)
   410	
   411	    # When 4a + 4b both succeed, the integrator re-raises the
   412	    # original store error (DispatchError) — AtomicityViolation
   413	    # is only raised when one of the compensating deletes ITSELF
   414	    # fails. This proves the integrator detected the push had
   415	    # landed (via ls_remote) and ran BOTH deletes successfully.
   416	    with pytest.raises(DispatchError):
   417	        integrator.integrate(trial.trial_id)
   418	
   419	    branch_ref = f"refs/heads/trial/{trial.trial_id}-p0"
   420	    # Local AND remote must both be cleaned up: 4a deleted the
   421	    # remote (the integrator detected the push had landed via
   422	    # ls_remote), 4b deleted the local.
   423	    assert clone.resolve_ref(branch_ref) is None
   424	    assert remote.resolve_ref(branch_ref) is None
   425	
   426	    # Restore so monkeypatch's teardown cleanup works.
   427	    monkeypatch.setattr(clone, "push_ref", real_push)
   428	    monkeypatch.setattr(clone, "ls_remote", real_lsremote)
   429	
