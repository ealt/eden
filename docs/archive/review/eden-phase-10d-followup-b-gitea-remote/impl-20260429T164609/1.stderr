   675	def _classify_work_refs(repo: Any, store: Any) -> dict[str, list[dict[str, Any]]]:
   676	    """Group ``refs/heads/work/*`` refs by GC eligibility.
   677	
   678	    Ownership is keyed off exact ``trial.branch`` equality (chunk 9e
   679	    plan §A.7), not by parsing the ref name.
   680	    """
   681	    trials = store.list_trials()
   682	    branch_index: dict[str, Trial] = {
   683	        tr.branch: tr for tr in trials if tr.branch is not None
   684	    }
   685	    pairs = repo.list_refs("refs/heads/work/*")
   686	    eligible: list[dict[str, Any]] = []
   687	    not_eligible: list[dict[str, Any]] = []
   688	    orphan: list[dict[str, Any]] = []
   689	    for refname, current_sha in pairs:
   690	        branch_name = refname.removeprefix("refs/heads/")

