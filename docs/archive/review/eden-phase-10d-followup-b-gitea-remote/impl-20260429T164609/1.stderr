   295	def test_reconcile_remote_orphans_deletes_orphan_with_no_store_record(
   296	    tmp_path: Path,
   297	) -> None:
   298	    """An orphan remote trial/* with no Store.read_trial → deleted."""
   299	    store, remote, clone, base = _setup(tmp_path)
   300	    # Forge an orphan: a commit whose tree contains
   301	    # .eden/trials/orphan-trial-id/eval.json, pushed to a trial/* ref,
   302	    # with NO matching trial in the store.
   303	    blob = clone.write_blob(b'{"trial_id": "orphan-trial-id"}\n')
   304	    eval_path = ".eden/trials/orphan-trial-id/eval.json"
   305	    worker_blob = clone.write_blob(b"worker\n")
   306	    worker_tree = clone.write_tree_from_entries(
   307	        [TreeEntry(mode="100644", type="blob", sha=worker_blob, path="WORK")]
   308	    )
   309	    full_tree = clone.write_tree_with_file(
   310	        worker_tree, eval_path, blob, mode="100644"
   311	    )
   312	    orphan_commit = clone.commit_tree(
   313	        full_tree,
   314	        parents=[base],
   315	        message="trial: orphan-trial-id porphan\n",
   316	        author=TEST_AUTHOR,
   317	        author_date=FIXED_DATE,
   318	        committer_date=FIXED_DATE,
   319	    )
   320	    branch_ref = "refs/heads/trial/orphan-trial-id-porphan"
   321	    clone.create_ref(branch_ref, orphan_commit)
   322	    clone.push_ref(branch_ref)
