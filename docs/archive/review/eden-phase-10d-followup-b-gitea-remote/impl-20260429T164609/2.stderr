   590	def test_reconcile_skips_orphan_when_store_read_fails_indeterminately(
   591	    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
   592	) -> None:
   593	    """Indeterminate Store.read_trial → leave the remote ref alone.
   594	
   595	    Reviewer round-0 finding: the original code treated ANY
   596	    Store.read_trial exception as 'trial missing' and deleted
   597	    the remote ref. Under the wire client, transport failures are
   598	    indistinguishable from NotFound — so a transient store outage
   599	    during startup reconciliation could destroy a valid integrated
   600	    ref. Only NotFound authorizes deletion now.
   601	    """
   602	    store, remote, clone, base = _setup(tmp_path)
   603	    trial = _seed_success_trial(store=store, repo=clone, base_sha=base)
   604	    integrator = _make_integrator(store, clone)
   605	    integrator.integrate(trial.trial_id)
   606	    branch_ref = f"refs/heads/trial/{trial.trial_id}-p0"
   607	    assert remote.resolve_ref(branch_ref) is not None
   608	
   609	    # Simulate a transport-level Store failure (e.g., the
   610	    # task-store-server is briefly down at orchestrator startup).
   611	    # NOT NotFound — so the integrator must NOT delete the ref.
   612	    def _boom(*args: object, **kwargs: object) -> None:
   613	        raise DispatchError("store transport hiccup")
   614	    monkeypatch.setattr(store, "read_trial", _boom)
   615	
   616	    deleted = integrator.reconcile_remote_orphans()
   617	    assert deleted == []
   618	    # The valid integrated ref MUST still be on the remote.
   619	    assert remote.resolve_ref(branch_ref) is not None
   620	
   621	
   622	def test_integrate_without_origin_skips_remote_publish(tmp_path: Path) -> None:
   623	    """Repos with no `origin` remote use the local-only flow (back-compat
   624	    for pre-cutover tests). All existing eden-git tests exercise this
   625	    path; this test pins it explicitly."""
   626	    store, _, repo, base = _setup(tmp_path, register_origin=False)
   627	    # repo here is the bare repo itself (no origin).
