   547	def test_integrate_indeterminate_push_remote_diverged_runs_4b_only(
   548	    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
   549	) -> None:
   550	    """Step 2 transport-fails AND remote has a different SHA → 4b only.
   551	
   552	    Drives `_reconcile_indeterminate_push`'s "remote at different
   553	    SHA" branch: another integrator integrated a different commit
   554	    on the same trial id, our push (which would have failed
   555	    `--force-with-lease=zero` anyway) racially encountered a
   556	    transport failure, ls_remote shows a different SHA. Mapped
   557	    to RefRefused semantics: 4b only.
   558	    """
   559	    store, remote, clone, base = _setup(tmp_path)
   560	    trial = _seed_success_trial(store=store, repo=clone, base_sha=base)
   561	    integrator = _make_integrator(store, clone)
   562	
   563	    branch_ref = f"refs/heads/trial/{trial.trial_id}-p0"
   564	    # Pre-publish a different SHA on the remote.
   565	    blob = remote.write_blob(b"intruder\n")
   566	    tree = remote.write_tree_from_entries(
   567	        [TreeEntry(mode="100644", type="blob", sha=blob, path="THEIRS")]
   568	    )
   569	    intruder = remote.commit_tree(
   570	        tree, parents=[base], message="intruder",
   571	        author=TEST_AUTHOR, author_date=FIXED_DATE, committer_date=FIXED_DATE,
   572	    )
   573	    remote.create_ref(branch_ref, intruder)
   574	
   575	    def _push_transport_fail(ref, *args, **kwargs):
   576	        raise GitTransportError(
   577	            ["push", "origin", ref], 128, "", "fatal: unable to access (simulated)"
   578	        )
   579	
   580	    monkeypatch.setattr(clone, "push_ref", _push_transport_fail)
   581	
   582	    with pytest.raises(RefRefused):
   583	        integrator.integrate(trial.trial_id)
   584	
   585	    # Local rolled back; remote untouched.
   586	    assert clone.resolve_ref(branch_ref) is None
   587	    assert remote.resolve_ref(branch_ref) == intruder
