         )
         resp = signed_in_client.post(
             "/planner/t-skip/submit",
             content=body,
             headers={"content-type": "application/x-www-form-urlencoded"},
         )
         assert resp.status_code == 200
         ready = store.list_proposals(state="ready")
         assert len(ready) == 1
         assert ready[0].slug == "feat-only"
 
