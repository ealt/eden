    16	def htmx_aware_redirect(request: Request, url: str) -> Response:
    17	    """Redirect appropriately for both htmx and no-JS clients.
    18	
    19	    HTMX does not process 3xx responses — it follows the redirect
    20	    transparently and swaps the redirected target's HTML into the
    21	    configured target. For an ``add_row`` button targeted at
    22	    ``#proposal-rows`` that produces a full ``<html>`` document
    23	    inside the rows container. The fix is to send back ``HX-Redirect``
    24	    on a 200/204 instead; htmx intercepts that header and does a
    25	    full client-side navigation.
    26	    """
    27	    if is_htmx_request(request):
    28	        return Response(status_code=204, headers={"hx-redirect": url})
    29	    return RedirectResponse(url=url, status_code=303)
    30	
    31	
    32	def get_session(request: Request) -> Session | None:
    33	    """Return the decoded session for ``request``, or ``None`` if missing/invalid."""
    34	    raw = request.cookies.get(SESSION_COOKIE_NAME)
    35	    if raw is None:
    36	        return None
    37	    codec: SessionCodec = request.app.state.session_codec
    38	    return codec.decode(raw)
