   140	@router.post("/{task_id}/add_row", response_model=None)
   141	async def add_row(task_id: str, request: Request):
   142	    """Append one empty proposal row to the draft form.
   143	
   144	    Two transports, same end state:
   145	
   146	    - With JS, htmx posts here with ``HX-Request: true``. We respond
   147	      with the rendered ``_proposal_row.html`` fragment for the new
   148	      row only; htmx swaps it as ``beforeend`` of ``#proposal-rows``
   149	      so the user's existing input is untouched. Redirect/error
   150	      branches send ``HX-Redirect`` on a 204 so htmx does a full
   151	      client-side navigation rather than swapping a redirected page
   152	      into the rows container.
   153	    - Without JS, the same button submits the form normally and we
   154	      re-render the whole ``planner_claim.html`` with the
   155	      collected state plus one more empty row, or 303 to the
   156	      sign-in / planner list on auth/claim failures.
   157	    """
   158	    session = get_session(request)
   159	    if session is None:
   160	        return htmx_aware_redirect(request, "/signin")
   161	    form = await request.form()
   162	    if not csrf_ok(session, form.get("csrf_token")):  # type: ignore[arg-type]
   163	        return _csrf_failure_response()
   164	    if _CLAIMS.get(_claim_key(session.csrf, task_id)) is None:
   165	        return htmx_aware_redirect(
   166	            request, "/planner/?banner=claim+missing+from+session"
   167	        )
   168	
   169	    if is_htmx_request(request):
   170	        # The htmx-enhanced path: figure out where the new row goes
   171	        # by counting existing rows in the form, then render only
   172	        # the partial. The user's existing rows are already on the
   173	        # page; htmx appends ours to ``#proposal-rows``.
   174	        existing = max(
   175	            len(form.getlist("slug")),
   176	            len(form.getlist("priority")),
   177	            len(form.getlist("parent_commits")),
   178	            len(form.getlist("rationale")),
   179	        )
   180	        return request.app.state.templates.TemplateResponse(
   181	            request,
   182	            "_proposal_row.html",
   183	            {"i": existing, "row_state": _empty_row(), "row_errs": {}},
   184	        )
