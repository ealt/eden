     1	"""Real-subprocess end-to-end test.
     2	
     3	Forks five processes (task-store-server + planner + implementer +
     4	evaluator + orchestrator) on an ephemeral port and drives a 3-trial
     5	experiment to quiescence over real HTTP.
     6	
     7	The test passes if the orchestrator exits 0 and the final DB + repo
     8	state match the expected shape. On failure, every subprocess's stderr
     9	is captured into the pytest failure report.
    10	"""
    11	
    12	from __future__ import annotations
    13	
    14	import signal
    15	import subprocess
    16	import sys
    17	import time
    18	from pathlib import Path
    19	
    20	import pytest
    21	from eden_contracts import MetricsSchema
    22	from eden_git import GitRepo
    23	from eden_service_common import seed_bare_repo
    24	from eden_storage import SqliteStore
    25	
    26	pytestmark = pytest.mark.skipif(
    27	    sys.platform == "win32",
    28	    reason="subprocess signal handling is POSIX-only for 8b",
    29	)
    30	
    31	FIXTURE_CONFIG = (
    32	    Path(__file__).resolve().parents[4]
    33	    / "tests"
    34	    / "fixtures"
    35	    / "experiment"
    36	    / ".eden"
    37	    / "config.yaml"
    38	)
    39	
    40	
    41	def _spawn(args: list[str]) -> subprocess.Popen:
    42	    return subprocess.Popen(
    43	        [sys.executable, "-m", *args],
    44	        stdout=subprocess.PIPE,
    45	        stderr=subprocess.PIPE,
    46	        text=True,
    47	    )
    48	
    49	
    50	def _read_port_announcement(proc: subprocess.Popen, timeout: float = 10.0) -> int:
    51	    """Read task-store-server's EDEN_TASK_STORE_LISTENING line and return the port."""
    52	    deadline = time.monotonic() + timeout
    53	    assert proc.stdout is not None
    54	    while time.monotonic() < deadline:
    55	        line = proc.stdout.readline()
    56	        if not line:
    57	            # Process may have died before listening.
    58	            if proc.poll() is not None:
    59	                raise RuntimeError(
    60	                    f"task-store-server exited early with code {proc.returncode}"
    61	                )
    62	            continue
    63	        if line.startswith("EDEN_TASK_STORE_LISTENING"):
    64	            parts = dict(p.split("=", 1) for p in line.strip().split()[1:])
    65	            return int(parts["port"])
    66	    raise RuntimeError("task-store-server did not announce its port in time")
    67	
    68	
    69	def _terminate(proc: subprocess.Popen, timeout: float = 5.0) -> None:
    70	    if proc.poll() is not None:
    71	        return
    72	    try:
    73	        proc.send_signal(signal.SIGTERM)
    74	        proc.wait(timeout=timeout)
    75	    except subprocess.TimeoutExpired:
    76	        proc.kill()
    77	        proc.wait(timeout=2)
    78	
    79	
    80	def _dump_stderr(procs: dict[str, subprocess.Popen]) -> str:
    81	    parts = []
    82	    for name, p in procs.items():
    83	        stderr = ""
    84	        if p.stderr is not None:
    85	            try:
    86	                stderr = p.stderr.read() or ""
    87	            except Exception as exc:  # noqa: BLE001
    88	                stderr = f"<failed to read stderr: {exc!r}>"
    89	        parts.append(
    90	            f"--- {name} (pid={p.pid}, rc={p.returncode}) ---\n{stderr}\n"
    91	        )
    92	    return "\n".join(parts)
    93	
    94	
    95	@pytest.mark.e2e
    96	def test_three_trial_experiment_over_subprocesses(tmp_path: Path) -> None:
    97	    """Spawn 5 processes, run to quiescence, assert final state."""
    98	    bare_repo = tmp_path / "bare-repo.git"
    99	    subprocess.run(
   100	        [
   101	            "git",
   102	            "init",
   103	            "--bare",
   104	            "--initial-branch",
   105	            "main",
   106	            str(bare_repo),
   107	        ],
   108	        check=True,
   109	        capture_output=True,
   110	    )
   111	    base_sha = seed_bare_repo(str(bare_repo))
   112	
   113	    db_path = tmp_path / "eden.sqlite"
   114	    experiment_id = "exp-e2e"
   115	    token = "test-token"
   116	
   117	    server = _spawn(
   118	        [
   119	            "eden_task_store_server",
   120	            "--db-path",
   121	            str(db_path),
   122	            "--experiment-id",
   123	            experiment_id,
   124	            "--experiment-config",
   125	            str(FIXTURE_CONFIG),
   126	            "--host",
   127	            "127.0.0.1",
   128	            "--port",
   129	            "0",
   130	            "--shared-token",
   131	            token,
   132	            "--subscribe-timeout",
   133	            "1.0",
   134	        ]
   135	    )
   136	    port = _read_port_announcement(server)
   137	    base_url = f"http://127.0.0.1:{port}"
   138	
   139	    planner = _spawn(
   140	        [
   141	            "eden_planner_host",
   142	            "--task-store-url",
   143	            base_url,
   144	            "--experiment-id",
   145	            experiment_id,
   146	            "--shared-token",
   147	            token,
   148	            "--worker-id",
   149	            "planner-1",
   150	            "--base-commit-sha",
   151	            base_sha,
   152	        ]
   153	    )
   154	    implementer = _spawn(
   155	        [
   156	            "eden_implementer_host",
   157	            "--task-store-url",
   158	            base_url,
   159	            "--experiment-id",
   160	            experiment_id,
   161	            "--shared-token",
   162	            token,
   163	            "--worker-id",
   164	            "implementer-1",
   165	            "--repo-path",
   166	            str(bare_repo),
   167	        ]
   168	    )
   169	    evaluator = _spawn(
   170	        [
   171	            "eden_evaluator_host",
   172	            "--task-store-url",
   173	            base_url,
   174	            "--experiment-id",
   175	            experiment_id,
   176	            "--shared-token",
   177	            token,
   178	            "--worker-id",
   179	            "evaluator-1",
   180	            "--experiment-config",
   181	            str(FIXTURE_CONFIG),
   182	        ]
   183	    )
   184	    orchestrator = _spawn(
   185	        [
   186	            "eden_orchestrator",
   187	            "--task-store-url",
   188	            base_url,
   189	            "--experiment-id",
   190	            experiment_id,
   191	            "--shared-token",
   192	            token,
   193	            "--repo-path",
   194	            str(bare_repo),
   195	            "--plan-tasks",
   196	            "plan-1,plan-2,plan-3",
   197	        ]
   198	    )
   199	
   200	    procs = {
   201	        "task-store-server": server,
   202	        "planner": planner,
   203	        "implementer": implementer,
   204	        "evaluator": evaluator,
   205	        "orchestrator": orchestrator,
   206	    }
   207	
   208	    try:
   209	        try:
   210	            rc = orchestrator.wait(timeout=60)
   211	        except subprocess.TimeoutExpired:
   212	            # Tear workers + server down before reading stderr so any
   213	            # buffered output flushes; then dump everything.
   214	            for p in procs.values():
   215	                _terminate(p)
   216	            pytest.fail(
   217	                "orchestrator did not exit within 60s. Subprocess stderr:\n"
   218	                + _dump_stderr(procs)
   219	            )
   220	        if rc != 0:
   221	            for p in procs.values():
   222	                _terminate(p)
   223	            pytest.fail(
   224	                f"orchestrator exited {rc}. Subprocess stderr:\n"
   225	                + _dump_stderr(procs)
   226	            )
   227	
   228	        # Tear down workers + server so the SqliteStore's file is released.
   229	        for name in ("planner", "implementer", "evaluator", "task-store-server"):
   230	            _terminate(procs[name])
   231	
   232	        # Inspect final state.
   233	        store = SqliteStore(
   234	            experiment_id=experiment_id,
   235	            path=str(db_path),
   236	            metrics_schema=MetricsSchema({"score": "real"}),
