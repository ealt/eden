   130	                experiment_id=store.experiment_id,
   131	                slug=tpl.slug,
   132	                priority=tpl.priority,
   133	                parent_commits=list(tpl.parent_commits),
   134	                artifacts_uri=tpl.artifacts_uri,
   135	                state="drafting",
   136	                created_at=self._now(),
   137	            )
   138	            store.create_proposal(proposal)
   139	            store.mark_proposal_ready(proposal_id)
   140	            proposal_ids.append(proposal_id)
   141	        store.submit(
   142	            task.task_id,
   143	            claim.token,
   144	            PlanSubmission(status="success", proposal_ids=tuple(proposal_ids)),
   145	        )
