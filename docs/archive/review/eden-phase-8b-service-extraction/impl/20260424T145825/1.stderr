    69	class ScriptedPlanner:
    70	    """Poll-and-run planner worker.
    71	
    72	    Discovers pending ``plan`` tasks, claims each in turn, drafts its
    73	    scripted proposals (one by one, marking each ``ready`` before
    74	    submitting), and submits with ``status=success``. Multi-proposal
    75	    drafting per plan is supported; zero-proposal plans also submit
    76	    with success per ``03-roles.md`` §2.4.
    77	    """
    78	
    79	    def __init__(
    80	        self,
    81	        worker_id: str,
    82	        plan_fn: PlanFn,
    83	        *,
    84	        proposal_id_factory: Callable[[], str],
    85	        now: Callable[[], str],
    86	    ) -> None:
    87	        self._worker_id = worker_id
    88	        self._plan_fn = plan_fn
    89	        self._proposal_id_factory = proposal_id_factory
    90	        self._now = now
    91	
    92	    @property
    93	    def worker_id(self) -> str:
    94	        """Opaque worker identifier this planner claims tasks under."""
    95	        return self._worker_id
    96	
    97	    def run_pending(
    98	        self,
    99	        store: Store,
   100	        *,
   101	        stop: Callable[[], bool] | None = None,
   102	    ) -> int:
   103	        """Claim and process every pending plan task. Returns count processed.
   104	
   105	        If ``stop`` is provided, it is consulted before each task; the loop
   106	        returns early when it returns ``True``. This lets a host running
   107	        in a SIGTERM-aware loop break mid-drain instead of finishing the
   108	        whole queue first.
   109	        """
   110	        count = 0
   111	        while True:
   112	            if stop is not None and stop():
   113	                return count
   114	            pending = store.list_tasks(kind="plan", state="pending")
   115	            if not pending:
   116	                return count
   117	            task = pending[0]
   118	            assert isinstance(task, PlanTask)
   119	            self._handle(store, task)
   120	            count += 1
   121	
   122	    def _handle(self, store: Store, task: PlanTask) -> None:
   123	        claim = store.claim(task.task_id, self._worker_id)
   124	        templates = self._plan_fn(task)
   125	        proposal_ids: list[str] = []
   126	        for tpl in templates:
   127	            proposal_id = self._proposal_id_factory()
   128	            proposal = Proposal(
