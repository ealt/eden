   239	            trials = store.list_trials(status="success")
   240	            if len(trials) != 3:
   241	                pytest.fail(
   242	                    f"expected 3 success trials, got {len(trials)}. Stderr:\n"
   243	                    + _dump_stderr(procs)
   244	                )
   245	            repo = GitRepo(str(bare_repo))
   246	            for trial in trials:
   247	                assert trial.trial_commit_sha is not None
   248	                assert trial.parent_commits == [base_sha]
   249	                parents = repo.commit_parents(trial.trial_commit_sha)
   250	                assert parents == list(trial.parent_commits)
   251	
   252	            # Every plan/implement/evaluate task terminal.
   253	            for kind in ("plan", "implement", "evaluate"):
   254	                tasks = store.list_tasks(kind=kind)
   255	                completed = [t for t in tasks if t.state == "completed"]
   256	                assert len(completed) == 3, (
   257	                    f"expected 3 completed {kind} tasks, got {len(completed)}"
   258	                )
   259	
   260	            # Event-log assertions (codex-review feedback): a 3-trial
   261	            # experiment must emit one task.completed per role per trial
   262	            # and one trial.integrated per trial. The full transcript is
   263	            # richer (drafting, claimed, submitted, succeeded, …); this
   264	            # test pins the must-have terminal events without freezing
   265	            # the exact count of every intermediate event.
   266	            events = list(store.read_range())
   267	            event_types = [e.type for e in events]
   268	            assert event_types.count("task.completed") == 9, (
