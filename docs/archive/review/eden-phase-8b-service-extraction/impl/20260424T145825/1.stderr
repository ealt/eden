   270	                f"{event_types.count('task.completed')}; full sequence: {event_types}"
   271	            )
   272	            assert event_types.count("trial.integrated") == 3, (
   273	                f"expected 3 trial.integrated events, got "
   274	                f"{event_types.count('trial.integrated')}"
   275	            )
   276	            assert event_types.count("trial.succeeded") == 3, (
   277	                f"expected 3 trial.succeeded events, got "
   278	                f"{event_types.count('trial.succeeded')}"
   279	            )
   280	        finally:
   281	            store.close()
   282	    finally:
   283	        for p in procs.values():
