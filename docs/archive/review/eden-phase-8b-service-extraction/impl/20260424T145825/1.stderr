   148	class ScriptedImplementer:
   149	    """Poll-and-run implementer worker.
   150	
   151	    Discovers pending ``implement`` tasks, reads the referenced
   152	    proposal, creates a ``starting`` trial on a scripted ``work/*``
   153	    branch, and submits with the scripted outcome. A successful
   154	    outcome carries ``commit_sha``; an errored outcome submits with
   155	    ``status=error``.
   156	    """
   157	
   158	    def __init__(
   159	        self,
   160	        worker_id: str,
   161	        implement_fn: ImplementFn,
   162	        *,
   163	        trial_id_factory: Callable[[], str],
   164	        now: Callable[[], str],
   165	    ) -> None:
   166	        self._worker_id = worker_id
   167	        self._implement_fn = implement_fn
   168	        self._trial_id_factory = trial_id_factory
   169	        self._now = now
   170	
   171	    @property
   172	    def worker_id(self) -> str:
   173	        """Opaque worker identifier this implementer claims tasks under."""
   174	        return self._worker_id
   175	
   176	    def run_pending(
   177	        self,
   178	        store: Store,
   179	        *,
   180	        stop: Callable[[], bool] | None = None,
   181	    ) -> int:
   182	        """Claim and process every pending implement task. Returns count processed.
   183	
   184	        ``stop`` lets a host break mid-drain on SIGTERM. See
   185	        :meth:`ScriptedPlanner.run_pending`.
   186	        """
   187	        count = 0
   188	        while True:
   189	            if stop is not None and stop():
   190	                return count
   191	            pending = store.list_tasks(kind="implement", state="pending")
   192	            if not pending:
   193	                return count
   194	            task = pending[0]
   195	            assert isinstance(task, ImplementTask)
   196	            self._handle(store, task)
   197	            count += 1
   198	
   199	    def _handle(self, store: Store, task: ImplementTask) -> None:
   200	        proposal = store.read_proposal(task.payload.proposal_id)
   201	        claim = store.claim(task.task_id, self._worker_id)
   202	
   203	        trial_id = self._trial_id_factory()
   204	        outcome = self._implement_fn(task, proposal)
   205	        branch = outcome.branch or f"work/{proposal.slug}-{trial_id}"
   206	        trial_kwargs: dict[str, Any] = {
   207	            "trial_id": trial_id,
   208	            "experiment_id": store.experiment_id,
   209	            "proposal_id": proposal.proposal_id,
   210	            "status": "starting",
   211	            "parent_commits": list(proposal.parent_commits),
   212	            "branch": branch,
   213	            "started_at": self._now(),
   214	        }
   215	        if outcome.description is not None:
   216	            trial_kwargs["description"] = outcome.description
   217	        trial = Trial(**trial_kwargs)
   218	        store.create_trial(trial)
   219	        store.submit(
   220	            task.task_id,
   221	            claim.token,
   222	            ImplementSubmission(
   223	                status=outcome.status,
   224	                trial_id=trial_id,
   225	                commit_sha=outcome.commit_sha,
   226	            ),
   227	        )
   228	
   229	
