   319	            store.submit(task_id, token, submission)
   320	            return True, None
   321	        except (
   322	            WrongToken,
   323	            ConflictingResubmission,
   324	            InvalidPrecondition,
   325	            IllegalTransition,
   326	        ) as exc:
   327	            return False, _wire_error_banner(exc)
   328	        except Exception as exc:  # noqa: BLE001 — transport-shaped or unknown
