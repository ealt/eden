   242	class TestRetryBeforeOrphan:
   243	    def test_transport_exception_retries_then_orphan(
   244	        self,
   245	        signed_in_client: TestClient,
   246	        store: InMemoryStore,
   247	        monkeypatch,
   248	    ) -> None:
   249	        """Raw transport exceptions (httpx-style, not DispatchError) are retried."""
   250	        store.create_plan_task("t-trans")
   251	        token = get_csrf(signed_in_client)
   252	        signed_in_client.post(
   253	            "/planner/t-trans/claim",
   254	            data={"csrf_token": token},
   255	            follow_redirects=False,
   256	        )
   257	
   258	        attempts = {"n": 0}
   259	
   260	        class TransportError(Exception):
   261	            pass
   262	
   263	        def transport_fail(*args, **kwargs):
   264	            attempts["n"] += 1
   265	            raise TransportError("connect timeout")
   266	
   267	        monkeypatch.setattr(store, "submit", transport_fail)
   268	        resp = signed_in_client.post(
   269	            "/planner/t-trans/submit",
   270	            data={
   271	                "csrf_token": token,
   272	                "status": "success",
   273	                "slug": "feat-trans",
   274	                "priority": "1.0",
   275	                "parent_commits": "a" * 40,
   276	                "rationale": "rationale",
   277	            },
   278	        )
   279	        assert resp.status_code == 502
   280	        # Retried 3 times.
   281	        assert attempts["n"] == 3
   282	        # Banner names the transport error class.
   283	        assert "TransportError" in resp.text
   284	
