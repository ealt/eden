    43	
    44	def _spawn(args: list[str]) -> subprocess.Popen:
    45	    return subprocess.Popen(
    46	        [sys.executable, "-m", *args],
    47	        stdout=subprocess.PIPE,
    48	        stderr=subprocess.PIPE,
    49	        text=True,
    50	    )
    51	
    52	
    53	_TASK_STORE_RE = re.compile(r"^EDEN_TASK_STORE_LISTENING\s+(.*)$")
    54	_WEB_UI_RE = re.compile(r"^EDEN_WEB_UI_LISTENING\s+(.*)$")
    55	
    56	
    57	def _read_announcement(
    58	    proc: subprocess.Popen, pattern: re.Pattern[str], timeout: float = 10.0
    59	) -> int:
    60	    deadline = time.monotonic() + timeout
    61	    assert proc.stdout is not None
    62	    while time.monotonic() < deadline:
    63	        line = proc.stdout.readline()
    64	        if not line:
    65	            if proc.poll() is not None:
    66	                raise RuntimeError(
    67	                    f"subprocess exited early with code {proc.returncode}"
    68	                )
    69	            continue
    70	        m = pattern.match(line.strip())
    71	        if m is not None:
    72	            kv = dict(p.split("=", 1) for p in m.group(1).split())
    73	            return int(kv["port"])
    74	    raise RuntimeError("subprocess did not announce its port in time")
    75	
    76	
    77	def _terminate(proc: subprocess.Popen, timeout: float = 5.0) -> None:
    78	    if proc.poll() is not None:
    79	        return
    80	    try:
    81	        proc.send_signal(signal.SIGTERM)
    82	        proc.wait(timeout=timeout)
    83	    except subprocess.TimeoutExpired:
    84	        proc.kill()
    85	        proc.wait(timeout=2)
    86	
    87	
    88	def _dump_stderr(procs: dict[str, subprocess.Popen]) -> str:
    89	    parts = []
    90	    for name, p in procs.items():
    91	        stderr = ""
    92	        if p.stderr is not None:
    93	            try:
    94	                stderr = p.stderr.read() or ""
    95	            except Exception as exc:  # noqa: BLE001
    96	                stderr = f"<failed to read stderr: {exc!r}>"
    97	        parts.append(f"--- {name} (pid={p.pid}, rc={p.returncode}) ---\n{stderr}\n")
    98	    return "\n".join(parts)
    99	
