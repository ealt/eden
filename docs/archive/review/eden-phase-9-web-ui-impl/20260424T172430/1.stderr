   253	@pytest.mark.e2e
   254	def test_stranded_claim_recovered_by_orchestrator_loop(tmp_path: Path) -> None:
   255	    """End-to-end: UI claims with TTL, orchestrator's loop sweeps + reclaims.
   256	
   257	    Spawns three real processes (task-store-server + web-ui +
   258	    orchestrator) and proves the operational path the plan
   259	    promised: the orchestrator's per-iteration sweep is what
   260	    actually reclaims an abandoned claim. The orchestrator is
   261	    launched with no plan tasks so it does the sweep, sees no
   262	    other progress, and quiesces.
   263	    """
   264	    from eden_service_common import seed_bare_repo
   265	
   266	    db_path = tmp_path / "eden.sqlite"
   267	    artifacts_dir = tmp_path / "artifacts"
   268	    bare_repo = tmp_path / "bare-repo.git"
   269	    subprocess.run(
   270	        ["git", "init", "--bare", "--initial-branch", "main", str(bare_repo)],
   271	        check=True,
   272	        capture_output=True,
   273	    )
   274	    seed_bare_repo(str(bare_repo))
   275	
   276	    experiment_id = "exp-strand"
   277	    token = "strand-token"
   278	
   279	    server = _spawn(
   280	        [
   281	            "eden_task_store_server",
   282	            "--db-path",
   283	            str(db_path),
   284	            "--experiment-id",
   285	            experiment_id,
   286	            "--experiment-config",
   287	            str(FIXTURE_CONFIG),
   288	            "--host",
   289	            "127.0.0.1",
   290	            "--port",
   291	            "0",
   292	            "--shared-token",
   293	            token,
   294	            "--subscribe-timeout",
   295	            "1.0",
   296	        ]
   297	    )
   298	    server_port = _read_announcement(server, _TASK_STORE_RE)
   299	    task_store_url = f"http://127.0.0.1:{server_port}"
   300	
   301	    web_ui = _spawn(
   302	        [
   303	            "eden_web_ui",
   304	            "--task-store-url",
   305	            task_store_url,
   306	            "--experiment-id",
   307	            experiment_id,
   308	            "--shared-token",
   309	            token,
   310	            "--experiment-config",
   311	            str(FIXTURE_CONFIG),
   312	            "--session-secret",
   313	            "x" * 32,
   314	            "--worker-id",
   315	            "ui-w",
   316	            "--artifacts-dir",
   317	            str(artifacts_dir),
   318	            "--host",
