   278	
   279	_RETRY_DELAYS_S = (0.05, 0.2, 0.5)
   280	
   281	
   282	def _retry_submit(
   283	    store: Any, task_id: str, token: str, submission: PlanSubmission
   284	) -> tuple[bool, str | None]:
   285	    """Resubmit on transport-only failures up to 3 times.
   286	
   287	    Per chapter 07 §2.4 / §8.1, a content-equivalent resubmit is
   288	    idempotent. Returns ``(ok, banner)``:
   289	
   290	    - ``(True, None)`` on success (including a same-content
   291	      resubmit that returns 200).
   292	    - ``(False, banner)`` on a definitive divergent response or
   293	      after 3 indeterminate failures. ``banner`` is the canonical
   294	      ``eden://error/<name>`` (or a transport summary) suitable for
   295	      surfacing to the user.
   296	
   297	    Definitive store-domain errors (``WrongToken``,
   298	    ``ConflictingResubmission``, ``InvalidPrecondition``,
   299	    ``IllegalTransition``) are not retried — retrying any of them
   300	    cannot change the outcome and any further attempt would just
   301	    return the same error or hide an actually-committed prior
   302	    attempt. Anything else (``DispatchError`` without a known
   303	    subclass, or a raw transport exception from the wire client
   304	    such as ``httpx.HTTPError``) is treated as transport-shaped
   305	    and retried.
   306	    """
   307	    last_exc: BaseException | None = None
   308	    for delay in _RETRY_DELAYS_S:
   309	        try:
   310	            store.submit(task_id, token, submission)
   311	            return True, None
   312	        except (
   313	            WrongToken,
   314	            ConflictingResubmission,
   315	            InvalidPrecondition,
   316	            IllegalTransition,
   317	        ) as exc:
   318	            return False, _wire_error_banner(exc)
   319	        except Exception as exc:  # noqa: BLE001 — transport-shaped or unknown
   320	            last_exc = exc
   321	            time.sleep(delay)
   322	    if last_exc is None:
   323	        return True, None
   324	    return False, f"transport failure after retries: {last_exc.__class__.__name__}"
   325	
   326	
   327	def _make_proposal(
   328	    *,
   329	    proposal_id: str,
   330	    experiment_id: str,
   331	    draft: ProposalDraft,
   332	    artifacts_uri: str,
   333	    now_iso: str,
   334	) -> Proposal:
   335	    return Proposal(
   336	        proposal_id=proposal_id,
   337	        experiment_id=experiment_id,
   338	        slug=draft.slug,
   339	        priority=draft.priority,
   340	        parent_commits=list(draft.parent_commits),
   341	        artifacts_uri=artifacts_uri,
   342	        state="drafting",
   343	        created_at=now_iso,
   344	    )
   345	
   346	
   347	def _iso(dt: Any) -> str:
   348	    """Emit Zulu-suffixed ISO 8601: ``YYYY-MM-DDTHH:MM:SS(.sss)?Z``."""
   349	    s = dt.isoformat()
   350	    if s.endswith("+00:00"):
   351	        s = s[: -len("+00:00")] + "Z"
   352	    return s
   353	
   354	
