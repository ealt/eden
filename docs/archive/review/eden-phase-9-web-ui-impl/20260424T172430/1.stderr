   286	class TestStrandedClaim:
   287	    def test_expired_claim_reclaims_via_sweeper(
   288	        self,
   289	        store: InMemoryStore,
   290	        artifacts_dir,
   291	        tmp_path,
   292	    ) -> None:
   293	        """Setting expires_at + sweeping returns a stranded task to pending."""
   294	        # Build an app whose `now()` advances on each call so the second
   295	        # tick is past the claim's expires_at.
   296	        instants = iter([
   297	            datetime(2026, 4, 24, 12, 0, tzinfo=UTC),
   298	            datetime(2026, 4, 24, 14, 0, tzinfo=UTC),  # +2h
   299	        ])
   300	
   301	        def fake_now() -> datetime:
   302	            try:
   303	                return next(instants)
   304	            except StopIteration:
   305	                return datetime(2026, 4, 24, 14, 0, tzinfo=UTC)
   306	
   307	        app = make_app(
   308	            store=store,
   309	            experiment_id=EXPERIMENT_ID,
   310	            experiment_config=_config(),
   311	            worker_id=WORKER_ID,
   312	            session_secret=SESSION_SECRET,
   313	            claim_ttl_seconds=60,  # 1 minute
   314	            artifacts_dir=artifacts_dir,
   315	            secure_cookies=False,
   316	            now=fake_now,
   317	        )
   318	        with TestClient(app) as c:
   319	            c.post("/signin", follow_redirects=False)
   320	            store.create_plan_task("t-strand")
   321	            csrf = get_csrf(c)
   322	            c.post(
   323	                "/planner/t-strand/claim",
   324	                data={"csrf_token": csrf},
   325	                follow_redirects=False,
   326	            )
   327	            assert store.read_task("t-strand").state == "claimed"
   328	
   329	        # Sweep using a now that's well past the expiry.
   330	        n = sweep_expired_claims(
   331	            store, now=datetime(2026, 4, 24, 12, 5, tzinfo=UTC)
   332	        )
   333	        assert n == 1
   334	        assert store.read_task("t-strand").state == "pending"

