   213	class TestPerSessionClaimIsolation:
   214	    def test_other_session_with_same_worker_id_cannot_use_first_session_claim(
   215	        self, app, store: InMemoryStore
   216	    ) -> None:
   217	        """Two browser sessions with the same worker_id must not share claims."""
   218	        store.create_plan_task("t-iso")
   219	        with TestClient(app) as a:
   220	            a.post("/signin", follow_redirects=False)
   221	            csrf_a = get_csrf(a)
   222	            resp = a.post(
   223	                "/planner/t-iso/claim",
   224	                data={"csrf_token": csrf_a},
   225	                follow_redirects=False,
   226	            )
   227	            assert resp.status_code == 303
   228	            # First session can see its own draft form.
   229	            resp = a.get("/planner/t-iso/draft")
   230	            assert resp.status_code == 200
   231	
   232	        # Second session — fresh sign-in (fresh CSRF) — cannot reach
   233	        # the draft page, which means it cannot reuse the first
   234	        # session's claim.
   235	        with TestClient(app) as b:
   236	            b.post("/signin", follow_redirects=False)
   237	            resp = b.get("/planner/t-iso/draft", follow_redirects=False)
   238	            assert resp.status_code == 303
   239	            assert "claim+missing" in resp.headers["location"]
