   172	        finally:
   173	            seed.close()
   174	
   175	        with httpx.Client(base_url=web_url, timeout=10.0) as ui:
   176	            # Sign in.
   177	            resp = ui.post("/signin", follow_redirects=False)
   178	            assert resp.status_code == 303
   179	
   180	            # GET /planner/ to render and parse out the CSRF token.
   181	            resp = ui.get("/planner/")
   182	            assert resp.status_code == 200
   183	            assert "t-ui-1" in resp.text
   184	            m = re.search(
   185	                r'name="csrf_token"\s+value="([^"]+)"', resp.text
   186	            )
   187	            assert m is not None, "csrf token not found in planner list"
   188	            csrf = m.group(1)
   189	
   190	            # Claim.
