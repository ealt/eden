     1	"""Real-subprocess end-to-end test for the Web UI.
     2	
     3	Two scenarios:
     4	
     5	1. ``test_planner_full_flow_through_ui`` — forks task-store-server
     6	   and web-ui, drives a one-task plan flow through the UI's HTTP
     7	   surface, asserts the resulting task-store state.
     8	2. ``test_stranded_claim_recovered_by_orchestrator_loop`` — adds
     9	   a real orchestrator subprocess to prove that the per-iteration
    10	   ``sweep_expired_claims`` call wired into ``run_orchestrator_loop``
    11	   is what actually reclaims an abandoned UI claim.
    12	"""
    13	
    14	from __future__ import annotations
    15	
    16	import re
    17	import signal
    18	import subprocess
    19	import sys
    20	import time
    21	from pathlib import Path
    22	from urllib.parse import urlencode
    23	
    24	import httpx
    25	import pytest
    26	from eden_contracts import MetricsSchema
    27	from eden_storage import SqliteStore
    28	
    29	pytestmark = pytest.mark.skipif(
    30	    sys.platform == "win32",
    31	    reason="subprocess signal handling is POSIX-only",
    32	)
    33	
    34	FIXTURE_CONFIG = (
    35	    Path(__file__).resolve().parents[4]
    36	    / "tests"
    37	    / "fixtures"
    38	    / "experiment"
    39	    / ".eden"
    40	    / "config.yaml"
    41	)
