   242	class TestDefinitiveSubmitErrors:
   243	    """Each chapter-07 §7 error name surfaces on the orphan page.
   244	
   245	    Note on operational semantics: by the time Phase 3 submit runs,
   246	    Phase 1 has already created proposals (drafting) and Phase 2 has
   247	    marked them ready. A definitive wire error at submit means those
   248	    proposals are orphaned — the form-input preservation that
   249	    applies to *validation* errors does not apply here, because the
   250	    work product (the proposals themselves) is what needs recovery,
   251	    not the form inputs. The orphan page lists the orphaned
   252	    proposal IDs and surfaces the canonical error type so an
   253	    operator can decide whether to reclaim the plan task or
   254	    garbage-collect.
   255	    """
   256	
   257	    def _setup_claim(
   258	        self, client: TestClient, store: InMemoryStore, task_id: str
   259	    ) -> str:
   260	        store.create_plan_task(task_id)
   261	        token = get_csrf(client)
   262	        resp = client.post(
   263	            f"/planner/{task_id}/claim",
   264	            data={"csrf_token": token},
   265	            follow_redirects=False,
   266	        )
   267	        assert resp.status_code == 303
   268	        return token
   269	
   270	    def _submit(
   271	        self, client: TestClient, task_id: str, csrf: str
   272	    ):
