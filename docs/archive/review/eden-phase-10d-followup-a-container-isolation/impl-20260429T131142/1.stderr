        original_command="trap '' TERM; sleep 600",
        image=_TEST_IMAGE,
        cwd_target="/work",
        cidfile=cidfile,
        role="kill-test",
        task_id="kill-probe",
        host_id=socket.gethostname(),
        volumes=[],
        binds=[BindMount(source=str(tmp_path), target="/work")],
        env_keys=[],
    )
