    content: |
      EDEN_BASE_COMMIT_SHA=${EDEN_BASE_COMMIT_SHA:?}
      EDEN_PROPOSALS_PER_PLAN=${EDEN_PROPOSALS_PER_PLAN:-1}
  # Implementer / evaluator env files default to empty bodies so the
  # `--*-env-file` flags resolve against a real path. Operators
  # extend these (typically with API keys for an LLM-driven
  # implement_command / evaluate_command) by editing the overlay or
  # mounting a different source.
  eden-implement-env:
    content: |
      # implementer subprocess env — extend with API keys etc.
  eden-evaluate-env:
    content: |
      # evaluator subprocess env — extend with API keys etc.

volumes:
  # Same `name:` discipline as the bare-repo + artifacts volumes in
  # compose.yaml — needed for --exec-mode docker volume forwarding
  # (compose.docker-exec.yaml). Pinning the name in this overlay
  # keeps host-mode and docker-mode using the same volume name.
  eden-worktrees:
    name: eden-worktrees

