      - ${EDEN_EXPERIMENT_ID:?}
      - --shared-token
      - ${EDEN_SHARED_TOKEN:?}
      - --worker-id
      - planner-1
      - --mode
      - subprocess
      - --experiment-config
      - /etc/eden/experiment-config.yaml
      - --experiment-dir
      - /etc/eden/experiment-dir
      - --artifacts-dir
      - /var/lib/eden/artifacts
      - --plan-env-file
      - /etc/eden/planner.env
      - --exec-mode
      - docker
      - --exec-image
      - ${EDEN_EXEC_IMAGE:?}
      - --exec-bind
      - ${EDEN_EXPERIMENT_DIR_HOST:?}:/etc/eden/experiment-dir:ro
