# Phase 10d follow-up A — docker-exec overlay.
#
# Layered ON TOP of compose.subprocess.yaml:
#
#   docker compose -f compose.yaml \
#                  -f compose.subprocess.yaml \
#                  -f compose.docker-exec.yaml \
#                  --env-file .env up -d --wait
#
# Activates Docker outside of Docker (DooD): every spawn of the
# user's `*_command` runs in a sibling container the worker host
# starts via the host docker daemon (mounted at /var/run/docker.sock).
# Worker-side soft isolation (chunk-10d host mode) is preserved when
# this overlay is NOT layered on; the docker socket is bind-mounted
# only here.
#
# Required env (set by `setup-experiment.sh --exec-mode docker`):
#   EDEN_EXEC_IMAGE          tag of the image used for spawned children
#   EDEN_DOCKER_GID          gid of /var/run/docker.sock as seen
#                            from inside a probe container
#                            (probe-from-inside, NOT host-side stat)
#   EDEN_CIDFILES_DIR_HOST   host-side dir mounted into worker hosts
#                            so cidfiles survive worker restart
#
# See spec/v0/reference-bindings/worker-host-subprocess.md §7 for the
# full design rationale and the soft-boundary security caveat.

name: eden-reference

services:
  planner-host:
    command:
      - python
      - -m
      - eden_planner_host
      - --task-store-url
      - http://task-store-server:8080
