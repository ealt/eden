   141	    healthcheck:
   142	      # Authenticated GET against an experiment-scoped endpoint
   143	      # confirms both that the process is up and that auth wiring
   144	      # works. CMD argv form (NOT CMD-SHELL) so Compose interpolates
   145	      # `.env` values exactly once; no shell re-parses them, so
   146	      # quotes / spaces / shell metacharacters in the token or
   147	      # experiment id can't break or alter the command.
   148	      test:
   149	        - CMD
   150	        - curl
   151	        - -fsS
   152	        - -H
   153	        - "Authorization: Bearer ${EDEN_SHARED_TOKEN}"
   154	        - -H
   155	        - "X-Eden-Experiment-Id: ${EDEN_EXPERIMENT_ID}"
   156	        - http://localhost:8080/v0/experiments/${EDEN_EXPERIMENT_ID}/events
   157	      interval: 5s
   158	      timeout: 3s
   159	      retries: 20
