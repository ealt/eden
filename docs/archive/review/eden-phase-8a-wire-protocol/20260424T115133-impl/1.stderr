   478	    @app.get(f"{base}/events/subscribe")
   479	    async def _subscribe(
   480	        experiment_id: str,
   481	        cursor: int = Query(0, ge=0),
   482	        timeout: float | None = Query(None, ge=0),
   483	        x_eden_experiment_id: str | None = Header(None),
   484	    ) -> dict[str, Any]:
   485	        # §6.2 long-poll: hold the connection open until at least one
   486	        # event is available after `cursor` or ``timeout`` (default
   487	        # ``subscribe_timeout``) elapses. The underlying ``Store`` is
   488	        # a synchronous in-process object, so we poll ``read_range``
   489	        # in a loop with a short interval. An asyncio.sleep yields to
   490	        # the event loop, so other requests (e.g. the write that
   491	        # unblocks us) progress concurrently.
   492	        _check_experiment(
   493	            experiment_id,
   494	            x_eden_experiment_id,
   495	            f"/v0/experiments/{experiment_id}/events/subscribe",
   496	        )
   497	        effective_timeout = timeout if timeout is not None else subscribe_timeout
   498	        deadline = time.monotonic() + effective_timeout
   499	        events = store.read_range(cursor=cursor if cursor > 0 else None)
   500	        while not events and time.monotonic() < deadline:
   501	            await asyncio.sleep(subscribe_poll_interval)
   502	            events = store.read_range(cursor=cursor if cursor > 0 else None)
   503	        resp = EventsResponse(events=events, cursor=cursor + len(events))
   504	        return resp.model_dump(mode="json", exclude_none=True)
   505	
   506	    # ------------------------------------------------------------------
   507	    # Reference-only helpers (non-normative)
   508	    # ------------------------------------------------------------------
   509	
   510	    ref_base = "/_reference/experiments/{experiment_id}"
   511	
   512	    @app.get(f"{ref_base}/tasks/{{task_id}}/validate-terminal")
   513	    async def _validate_terminal(
   514	        experiment_id: str,
   515	        task_id: str,
   516	        x_eden_experiment_id: str | None = Header(None),
   517	    ) -> dict[str, Any]:
   518	        _check_experiment(
   519	            experiment_id,
   520	            x_eden_experiment_id,
   521	            f"/_reference/experiments/{experiment_id}/tasks/{task_id}/validate-terminal",
   522	        )
   523	        decision, reason = store.validate_terminal(task_id)
   524	        return ValidateTerminalResponse(
   525	            decision=decision, reason=reason
   526	        ).model_dump(mode="json", exclude_none=True)
   527	
   528	    @app.post(f"{ref_base}/validate/metrics")
   529	    async def _validate_metrics(
   530	        experiment_id: str,
   531	        body: ValidateMetricsRequest,
   532	        x_eden_experiment_id: str | None = Header(None),
   533	    ) -> Response:
   534	        _check_experiment(
   535	            experiment_id,
   536	            x_eden_experiment_id,
   537	            f"/_reference/experiments/{experiment_id}/validate/metrics",
   538	        )
   539	        store.validate_metrics(body.metrics)
   540	        return Response(status_code=204)
   541	
   542	    return app
   543	
   544	
   545	def _submission_to_wire(submission: Submission) -> dict[str, Any]:
   546	    if isinstance(submission, PlanSubmission):
   547	        return {
   548	            "kind": "plan",
   549	            "status": submission.status,
   550	            "proposal_ids": list(submission.proposal_ids),
   551	        }
   552	    if isinstance(submission, ImplementSubmission):
   553	        body: dict[str, Any] = {
   554	            "kind": "implement",
   555	            "status": submission.status,
   556	            "trial_id": submission.trial_id,
   557	        }
   558	        if submission.commit_sha is not None:
   559	            body["commit_sha"] = submission.commit_sha
   560	        return body

