     1	"""Schema-parity check for the wire models.
     2	
     3	Every Pydantic model in ``eden_wire.models`` has a corresponding JSON
     4	Schema under ``spec/v0/schemas/wire/``. The parity test asserts that
     5	a valid instance of the Pydantic model serializes to something that
     6	the schema also accepts, and — where the schemas list mandatory
     7	fields — that the model rejects inputs missing them.
     8	
     9	This is the wire-side analog of the ``eden-contracts`` schema-parity
    10	tests. Drift between the model and the schema (seen concretely on
    11	``claim-response.schema.json`` where an earlier draft permitted
    12	``null`` on a ``NotNone`` field) surfaces here rather than in
    13	production.
    14	"""
    15	
    16	from __future__ import annotations
    17	
    18	import json
    19	from pathlib import Path
    20	from typing import Any
    21	
    22	import jsonschema
    23	import pytest
    24	from eden_wire.errors import ProblemJson
    25	from eden_wire.models import (
    26	    ClaimRequest,
    27	    ClaimResponse,
    28	    EventsResponse,
    29	    IntegrateRequest,
    30	    ReclaimRequest,
    31	    RejectRequest,
    32	    SubmitRequest,
    33	)
    34	from pydantic import ValidationError
    35	
    36	SCHEMA_DIR = Path(__file__).resolve().parents[4] / "spec" / "v0" / "schemas" / "wire"
    37	
    38	
    39	def _load_schema(name: str) -> dict[str, Any]:
    40	    return json.loads((SCHEMA_DIR / name).read_text())
    41	
    42	
    43	def _validate_against(schema_name: str, instance: dict[str, Any]) -> None:
    44	    schema = _load_schema(schema_name)
    45	    jsonschema.validate(
    46	        instance,
    47	        schema,
    48	        cls=jsonschema.Draft202012Validator,
    49	        format_checker=jsonschema.Draft202012Validator.FORMAT_CHECKER,
    50	    )
    51	
    52	
    53	class TestClaimRequestParity:
    54	    def test_accept_minimum(self) -> None:
    55	        model = ClaimRequest(worker_id="worker-1")
    56	        dumped = model.model_dump(mode="json", exclude_none=True)
    57	        _validate_against("claim-request.schema.json", dumped)
    58	
    59	    def test_accept_with_expires_at(self) -> None:
    60	        model = ClaimRequest(worker_id="w", expires_at="2026-04-24T00:00:00Z")
    61	        _validate_against(
    62	            "claim-request.schema.json", model.model_dump(mode="json", exclude_none=True)
    63	        )
    64	
    65	    def test_reject_missing_worker(self) -> None:
    66	        with pytest.raises(ValidationError):
    67	            ClaimRequest.model_validate({})
    68	
    69	
