   487	    def test_confirmed_divergence(self, store: InMemoryStore) -> None:
   488	        """Server committed a *different* SHA previously; transport fails on
   489	        the new attempt; read-back surfaces the different SHA →
   490	        InvalidPrecondition, no compensation."""
   491	        app = make_app(
   492	            store,
   493	            subscribe_timeout=SHORT_SUBSCRIBE_TIMEOUT,
   494	            subscribe_poll_interval=0.02,
   495	        )
   496	        seed = TestClient(app, base_url="http://wire.test")
   497	        seed_client = StoreClient("http://wire.test", EXPERIMENT_ID, client=seed)
   498	        _run_trial_to_success(
   499	            seed_client, task_prefix="dv", proposal_id="dv-prop", trial_id="dv-t"
   500	        )
   501	        seed_client.integrate_trial("dv-t", "d" * 40)  # pre-commit a different SHA
   502	
   503	        flaky = Client(
   504	            transport=_transport_that_loses(
   505	                app,
   506	                lose_path_substring="/trials/dv-t/integrate",
   507	                after_commit=False,
   508	            ),
   509	            base_url="http://wire.test",
   510	        )
   511	        with (
   512	            StoreClient("http://wire.test", EXPERIMENT_ID, client=flaky) as flaky_sc,
   513	            pytest.raises(InvalidPrecondition),
   514	        ):
   515	            flaky_sc.integrate_trial("dv-t", "c" * 40)
   516	        # The pre-existing SHA is untouched; the client did not compensate.
   517	        assert store.read_trial("dv-t").trial_commit_sha == "d" * 40
