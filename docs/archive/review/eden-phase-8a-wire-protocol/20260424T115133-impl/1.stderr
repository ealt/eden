   356	
   357	def _transport_that_loses(
   358	    app: Any, *, lose_path_substring: str, after_commit: bool
   359	) -> MockTransport:
   360	    """A composite transport that defers to the ASGI app except for one
   361	    specific request path, which it handles specially.
   362	
   363	    - ``after_commit=True``: the "server" commits the write first by
   364	      issuing the equivalent request through a ``TestClient`` (which
   365	      runs the ASGI app fully), then raises ``httpx.ConnectError`` on
   366	      the original — simulating the response being lost after durable
   367	      commit.
   368	    - ``after_commit=False``: raises ``httpx.ConnectError`` without
   369	      touching the app — simulates "request never arrived" or
   370	      "server aborted before commit."
   371	
   372	    All other requests pass through a real ``TestClient`` wrapping the
   373	    same ASGI app. ``TestClient`` handles the sync-over-async bridge
   374	    internally so we never have to nest event loops ourselves.
   375	    """
   376	    import httpx
   377	
   378	    passthrough = TestClient(app, base_url="http://wire.test")
   379	
   380	    def _relay(request: Request) -> Response:
   381	        result = passthrough.request(
   382	            request.method,
   383	            str(request.url),
   384	            content=request.content,
   385	            headers=dict(request.headers),
   386	        )
   387	        return Response(
   388	            status_code=result.status_code,
   389	            headers=dict(result.headers),
   390	            content=result.content,
   391	        )
   392	
   393	    def handler(request: Request) -> Response:
   394	        if lose_path_substring in str(request.url) and request.method == "POST":
   395	            if after_commit:
   396	                response = _relay(request)
   397	                assert 200 <= response.status_code < 300, (
   398	                    f"simulated server commit expected 2xx, got {response.status_code}"
   399	                )
   400	            raise httpx.ConnectError("simulated transport loss")
   401	        return _relay(request)
   402	
   403	    return MockTransport(handler)
   404	
   405	
