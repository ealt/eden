    97	def _run_trial_to_success(
    98	    store_client: StoreClient,
    99	    *,
   100	    task_prefix: str,
   101	    proposal_id: str,
   102	    trial_id: str,
   103	) -> None:
   104	    """Drive a trial to ``status="success"`` via the real Store API.
   105	
   106	    This is the seed routine for integrate_trial tests. It goes
   107	    through the full plan → implement → evaluate → accept pipeline
   108	    over HTTP, matching what the real dispatch driver would do.
   109	    No internal-state mutation; no ``model_copy(update=...)``.
   110	    """
   111	    # Plan phase — produces a ready proposal.
   112	    store_client.create_plan_task(f"{task_prefix}-plan")
   113	    claim = store_client.claim(f"{task_prefix}-plan", "planner")
   114	    store_client.create_proposal(Proposal.model_validate(_make_proposal_body(proposal_id)))
   115	    store_client.mark_proposal_ready(proposal_id)
   116	    store_client.submit(
   117	        f"{task_prefix}-plan",
   118	        claim.token,
   119	        PlanSubmission(status="success", proposal_ids=(proposal_id,)),
   120	    )
   121	    store_client.accept(f"{task_prefix}-plan")
   122	
   123	    # Implement phase — produces a trial with commit_sha.
   124	    store_client.create_implement_task(f"{task_prefix}-impl", proposal_id)
   125	    claim = store_client.claim(f"{task_prefix}-impl", "implementer")
   126	    store_client.create_trial(Trial.model_validate(_make_trial_body(trial_id, proposal_id)))
   127	    store_client.submit(
   128	        f"{task_prefix}-impl",
   129	        claim.token,
   130	        ImplementSubmission(status="success", trial_id=trial_id, commit_sha="b" * 40),
   131	    )
   132	    store_client.accept(f"{task_prefix}-impl")
   133	
   134	    # Evaluate phase — transitions trial to success with metrics.
   135	    store_client.create_evaluate_task(f"{task_prefix}-eval", trial_id)
   136	    claim = store_client.claim(f"{task_prefix}-eval", "evaluator")
   137	    store_client.submit(
   138	        f"{task_prefix}-eval",
   139	        claim.token,
   140	        EvaluateSubmission(
   141	            status="success",
   142	            trial_id=trial_id,
   143	            metrics={"loss": 0.1, "acc": 0.9},
   144	            artifacts_uri="file:///tmp/artifacts",
   145	        ),
   146	    )
   147	    store_client.accept(f"{task_prefix}-eval")
