   155	def submit_evaluate(
   156	    client: WireClient,
   157	    task_id: str,
   158	    *,
   159	    token: str,
   160	    trial_id: str,
   161	    status: str = "success",
   162	    metrics: dict[str, Any] | None = None,
   163	    artifacts_uri: str | None = None,
   164	) -> Any:
   165	    payload: dict[str, Any] = {
   166	        "kind": "evaluate",
   167	        "status": status,
   168	        "trial_id": trial_id,
   169	    }
   170	    # status=success defaults a metrics object so well-formed
   171	    # successes don't need to repeat the boilerplate. Other statuses
   172	    # only get metrics when the caller explicitly passes them, so
   173	    # eval_error/error tests can drive the §4.4 "discard
   174	    # submission-carried metrics" rule with a real wire payload.
   175	    if metrics is not None:
   176	        payload["metrics"] = metrics
   177	    elif status == "success":
   178	        payload["metrics"] = {"score": 1.0, "retries": 0}
   179	    if artifacts_uri is not None:
   180	        payload["artifacts_uri"] = artifacts_uri
   181	    return client.post(
   182	        client.tasks_path(task_id, "/submit"),
   183	        json={"token": token, "payload": payload},
   184	    )
