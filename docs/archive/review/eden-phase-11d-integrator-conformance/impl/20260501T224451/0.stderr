     1	"""Integrator atomicity (wire projection) — chapter 06 §3.4 + §5.3."""
     2	
     3	from __future__ import annotations
     4	
     5	import pytest
     6	from conformance.harness import _seed
     7	from conformance.harness.event_cursor import EventLog
     8	from conformance.harness.wire_client import WireClient
     9	
    10	pytestmark = pytest.mark.conformance
    11	
    12	CONFORMANCE_GROUP = 'Integrator atomicity'
    13	
    14	
    15	def test_cross_artifact_consistency_on_success(
    16	    wire_client: WireClient, event_log: EventLog
    17	) -> None:
    18	    """spec/v0/06-integrator.md §3.4 — field, event MUST reference the same SHA.
    19	
    20	    The atomic-three invariant says "a reader of any one of the three
    21	    artifacts (ref, field, event) MUST observe the other two." The
    22	    chapter-7 binding exposes only the field
    23	    (``read_trial.trial_commit_sha``) and the event
    24	    (``trial.integrated`` in the log); the git ref is off-wire. This
    25	    test pins the wire-observable projection: after a successful
    26	    ``POST /trials/{T}/integrate``, the field and the event both
    27	    exist AND reference the same SHA. The cross-equality is the new
    28	    delta over the v1 ``Integrate idempotency`` group, which asserts
    29	    each artifact independently but not their cross-consistency.
    30	    """
    31	    trial_id = _seed.drive_to_success_trial(wire_client)
    32	    sha = "a" * 40
    33	    r = _seed.integrate_trial(wire_client, trial_id, trial_commit_sha=sha)
    34	    assert 200 <= r.status_code < 300, r.text
    35	    trial = _seed.read_trial(wire_client, trial_id)
    36	    field_sha = trial.get("trial_commit_sha")
    37	    integrated = [
    38	        e
    39	        for e in event_log.find_by_type(event_log.replay_all(), "trial.integrated")
    40	        if e["data"].get("trial_id") == trial_id
    41	    ]
    42	    assert len(integrated) == 1, (
    43	        f"expected exactly one trial.integrated event; got {len(integrated)}"
    44	    )
    45	    event_sha = integrated[0]["data"].get("trial_commit_sha")
    46	    assert field_sha == sha, (
    47	        f"trial.trial_commit_sha mismatch: expected {sha!r}, got {field_sha!r}"
    48	    )
    49	    assert event_sha == sha, (
    50	        f"event.data.trial_commit_sha mismatch: expected {sha!r}, "
    51	        f"got {event_sha!r}"
    52	    )
    53	    assert field_sha == event_sha, (
    54	        f"cross-artifact-consistency violated: field={field_sha!r} "
    55	        f"!= event={event_sha!r}"
    56	    )
    57	
    58	
    59	def test_divergent_resubmit_leaves_no_second_event(
    60	    wire_client: WireClient, event_log: EventLog
    61	) -> None:
    62	    """spec/v0/06-integrator.md §5.3 — repeat promotion with different SHA MUST NOT overwrite.
    63	
    64	    §5.3 says "the integrator MUST NOT silently overwrite" if the
    65	    trial already has ``trial_commit_sha`` set with a different value;
    66	    the wire-projection is that a divergent retry returns 409 AND
    67	    leaves the event log with exactly one ``trial.integrated`` event
    68	    AND leaves the field unchanged. The existing v1
    69	    ``test_different_sha_returns_409`` asserts the field is
    70	    unchanged; this test additionally pins the event-side
    71	    cardinality (no second event) and re-asserts the field via the
    72	    chapter-06 citation rather than chapter-07.
    73	    """
    74	    trial_id = _seed.drive_to_success_trial(wire_client)
    75	    first = "b" * 40
    76	    second = "c" * 40
    77	    r1 = _seed.integrate_trial(wire_client, trial_id, trial_commit_sha=first)
    78	    r1.raise_for_status()
    79	    r2 = _seed.integrate_trial(wire_client, trial_id, trial_commit_sha=second)
    80	    assert r2.status_code == 409, r2.text
    81	    assert r2.json().get("type") == "eden://error/invalid-precondition"
    82	    trial = _seed.read_trial(wire_client, trial_id)
    83	    assert trial.get("trial_commit_sha") == first
    84	    integrated = [
    85	        e
    86	        for e in event_log.find_by_type(event_log.replay_all(), "trial.integrated")
    87	        if e["data"].get("trial_id") == trial_id
    88	    ]
    89	    assert len(integrated) == 1
    90	    assert integrated[0]["data"]["trial_commit_sha"] == first

