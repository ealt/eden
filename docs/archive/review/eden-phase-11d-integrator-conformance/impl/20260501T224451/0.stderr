   281	def drive_to_starting_trial(
   282	    client: WireClient,
   283	    *,
   284	    proposal_id: str | None = None,
   285	    commit_sha: str = "1" * 40,
   286	) -> str:
   287	    """Drive a fresh proposal through implement-accept; trial is `starting` with commit_sha.
   288	
   289	    The trial is NOT in `success` yet — that requires the evaluator
   290	    cycle to also complete. Returns trial_id.
   291	    """
   292	    pid = proposal_id or create_proposal(client)
   293	    mark_proposal_ready(client, pid)
   294	    impl_tid = create_implement_task(client, proposal_id=pid)
   295	    impl_claim = claim(client, impl_tid, worker_id="impl-worker")
   296	    trial_id = fresh_trial_id()
   297	    # Implementer creates the starting trial before submitting (chapter 3 §3.2 step 1).
   298	    create_trial(
   299	        client,
   300	        trial_id=trial_id,
   301	        proposal_id=pid,
   302	        status="starting",
   303	    )
   304	    r = submit_implement(
   305	        client,
   306	        impl_tid,
   307	        token=impl_claim["token"],
   308	        trial_id=trial_id,
   309	        commit_sha=commit_sha,
   310	    )
   311	    r.raise_for_status()
   312	    accepted = accept(client, impl_tid)
   313	    accepted.raise_for_status()
   314	    # Sanity-check that the accept actually wrote commit_sha onto the
   315	    # trial — a setup regression that silently leaves the trial in an
   316	    # unexpected shape would otherwise surface as a misleading
   317	    # downstream test failure.
   318	    trial = read_trial(client, trial_id)
   319	    assert trial.get("commit_sha") == commit_sha, (
   320	        f"setup precondition: trial {trial_id!r} should carry "
   321	        f"commit_sha={commit_sha!r} after implement /accept; got "
   322	        f"{trial.get('commit_sha')!r}"
   323	    )
   324	    return trial_id
   325	
   326	
   327	def drive_to_error_trial(
   328	    client: WireClient,
   329	    *,
   330	    proposal_id: str | None = None,
   331	) -> str:
   332	    """Drive a fresh proposal through implement-status-error.
   333	
   334	    Returns trial_id of a trial that landed at ``status="error"`` via
   335	    the chapter-3 §3.4 implementer status=error path: implementer
   336	    creates the starting trial, submits ``status="error"``, then the
   337	    orchestrator's reject path terminalizes the trial as error
   338	    atomically with the task.failed event (chapter 05 §2.2 composite
   339	    commit).
   340	    """
   341	    pid = proposal_id or create_proposal(client)
   342	    mark_proposal_ready(client, pid)
   343	    impl_tid = create_implement_task(client, proposal_id=pid)
   344	    impl_claim = claim(client, impl_tid, worker_id="impl-worker")
   345	    trial_id = fresh_trial_id()
   346	    create_trial(
   347	        client,
   348	        trial_id=trial_id,
   349	        proposal_id=pid,
   350	        status="starting",
   351	    )
   352	    r = submit_implement(
   353	        client,
   354	        impl_tid,
   355	        token=impl_claim["token"],
   356	        trial_id=trial_id,
   357	        status="error",
   358	    )
   359	    r.raise_for_status()
   360	    rejected = reject(client, impl_tid, reason="worker_error")
   361	    rejected.raise_for_status()
   362	    trial = read_trial(client, trial_id)
   363	    assert trial.get("status") == "error", (
   364	        f"setup precondition: trial {trial_id!r} should be 'error' after "
   365	        f"implement /reject with status=error; got {trial.get('status')!r}"
   366	    )
   367	    return trial_id
   368	
   369	
   370	def drive_to_eval_error_trial(
   371	    client: WireClient,
   372	    *,
   373	    proposal_id: str | None = None,
   374	    commit_sha: str = "1" * 40,
   375	) -> str:
   376	    """Drive a fresh proposal through to ``status="eval_error"``.
   377	
   378	    Drives implement-accept (so the trial reaches ``starting`` with
   379	    ``commit_sha``) and then calls ``declare_trial_eval_error`` to
   380	    terminalize the trial as ``eval_error`` per chapter 04 §4.3 retry-
   381	    exhaustion / chapter 05 §3.3 ``trial.eval_errored``. Returns
   382	    trial_id.
   383	    """
   384	    trial_id = drive_to_starting_trial(
   385	        client, proposal_id=proposal_id, commit_sha=commit_sha
   386	    )
   387	    declared = declare_trial_eval_error(client, trial_id)
   388	    declared.raise_for_status()
   389	    trial = read_trial(client, trial_id)
   390	    assert trial.get("status") == "eval_error", (
   391	        f"setup precondition: trial {trial_id!r} should be 'eval_error' "
   392	        f"after declare-eval-error; got {trial.get('status')!r}"
   393	    )
   394	    return trial_id
   395	
   396	
   397	def drive_to_success_trial(
   398	    client: WireClient,
   399	    *,
   400	    proposal_id: str | None = None,
   401	    commit_sha: str = "1" * 40,
   402	    metrics: dict[str, Any] | None = None,
   403	) -> str:
   404	    """Drive a fresh proposal through full implement → evaluate cycle.
   405	
   406	    Returns trial_id of a trial in `status="success"` (the evaluator
   407	    accept-step transitions the trial atomically per chapter 05 §2.2).
   408	    """
   409	    trial_id = drive_to_starting_trial(
   410	        client, proposal_id=proposal_id, commit_sha=commit_sha
   411	    )
   412	    eval_tid = create_evaluate_task(client, trial_id=trial_id)
   413	    eval_claim = claim(client, eval_tid, worker_id="eval-worker")
   414	    r = submit_evaluate(
   415	        client,
   416	        eval_tid,
   417	        token=eval_claim["token"],
   418	        trial_id=trial_id,
   419	        metrics=metrics,
   420	    )

