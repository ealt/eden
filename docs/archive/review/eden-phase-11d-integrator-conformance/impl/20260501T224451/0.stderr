     1	"""Promotion preconditions (wire projection) — chapter 06 §2."""
     2	
     3	from __future__ import annotations
     4	
     5	import pytest
     6	from conformance.harness import _seed
     7	from conformance.harness.event_cursor import EventLog
     8	from conformance.harness.wire_client import WireClient
     9	
    10	pytestmark = pytest.mark.conformance
    11	
    12	CONFORMANCE_GROUP = 'Promotion preconditions'
    13	
    14	
    15	def _assert_no_promotion_artifacts(
    16	    wire_client: WireClient,
    17	    event_log: EventLog,
    18	    trial_id: str,
    19	) -> None:
    20	    """End-state assertion: trial has no commit_sha and no event.
    21	
    22	    Pins the §2 promotion-trigger MUST plus the §3.4 rollback-half:
    23	    a rejected ``integrate_trial`` produces neither field nor event.
    24	    """
    25	    trial = _seed.read_trial(wire_client, trial_id)
    26	    assert trial.get("trial_commit_sha") in (None, ""), (
    27	        f"trial {trial_id!r} should have no trial_commit_sha after "
    28	        f"rejected integrate; got {trial.get('trial_commit_sha')!r}"
    29	    )
    30	    integrated = [
    31	        e
    32	        for e in event_log.find_by_type(event_log.replay_all(), "trial.integrated")
    33	        if e["data"].get("trial_id") == trial_id
    34	    ]
    35	    assert integrated == [], (
    36	        f"trial {trial_id!r} should have no trial.integrated event after "
    37	        f"rejected integrate; got {integrated!r}"
    38	    )
    39	
    40	
    41	def test_integrate_against_error_trial_rejected(
    42	    wire_client: WireClient, event_log: EventLog
    43	) -> None:
    44	    """spec/v0/06-integrator.md §2 — `error` trial MUST NOT be promoted.
    45	
    46	    §2 says "trials in `error`, `eval_error`, and `starting` MUST NOT
    47	    receive a `trial/*` commit." Wire-projection: ``integrate_trial``
    48	    against an errored trial returns 409 ``invalid-precondition``,
    49	    leaves no ``trial_commit_sha`` on the trial, and emits no
    50	    ``trial.integrated`` event. The composite end-state pins the §3.4
    51	    rollback-half "a failed write produces neither field nor event."
    52	    """
    53	    trial_id = _seed.drive_to_error_trial(wire_client)
    54	    r = _seed.integrate_trial(wire_client, trial_id, trial_commit_sha="d" * 40)
    55	    assert r.status_code == 409, r.text
    56	    assert r.json().get("type") == "eden://error/invalid-precondition"
    57	    _assert_no_promotion_artifacts(wire_client, event_log, trial_id)
    58	
    59	
    60	def test_integrate_against_eval_error_trial_rejected(
    61	    wire_client: WireClient, event_log: EventLog
    62	) -> None:
    63	    """spec/v0/06-integrator.md §2 — `eval_error` trial MUST NOT be promoted.
    64	
    65	    Same MUST as the `error` case, different status. The §2 status
    66	    vocabulary ban applies to all three non-`success` states; the
    67	    existing v1 ``test_integrate_against_non_success_trial_returns_409``
    68	    covers `starting`, this test covers `eval_error`, and the sibling
    69	    ``test_integrate_against_error_trial_rejected`` covers `error`.
    70	    Together they exercise the full status precondition surface.
    71	    """
    72	    trial_id = _seed.drive_to_eval_error_trial(wire_client)
    73	    r = _seed.integrate_trial(wire_client, trial_id, trial_commit_sha="e" * 40)
    74	    assert r.status_code == 409, r.text
    75	    assert r.json().get("type") == "eden://error/invalid-precondition"
    76	    _assert_no_promotion_artifacts(wire_client, event_log, trial_id)

