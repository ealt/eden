   318	    for chapter in sorted(coverage):
   319	        if not coverage[chapter]:
   320	            continue
   321	        sections = sorted({s for (_p, _n, s) in coverage[chapter]})
   322	        print(f"  {chapter}: §§ {', '.join(sections)}")
   323	    return 0
