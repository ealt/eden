   309	
   310	_RETRY_DELAYS_S = (0.05, 0.2, 0.5)
   311	
   312	
   313	def _retry_submit_with_readback(
   314	    *,
   315	    store: Any,
   316	    task_id: str,
   317	    token: str,
   318	    submission: EvaluateSubmission,
   319	) -> tuple[str, str | None]:
   320	    """Submit with retry; reconcile transport / IllegalTransition via read-back.
   321	
   322	    Returns one of:
   323	
   324	    - ``("ok", None)`` — submit committed (clean call, retry, or
   325	      read-back found an equivalent prior submission).
   326	    - ``("auto", banner)`` — orphan page; auto-recovers via
   327	      reclaim. Used for ``WrongToken`` short-circuit, transport
   328	      retry exhaustion with claim still ours, and the read-back
   329	      branch where the task has been reclaimed.
   330	    - ``("conflict", banner)`` — orphan page; a different
   331	      submission won the race
   332	      (``ConflictingResubmission`` short-circuit, or read-back
   333	      saw a non-equivalent committed payload).
   334	    - ``("transport", banner)`` — orphan page; an
   335	      implementation-illegal store state was observed during
   336	      read-back (``read_submission`` returned ``None`` for a
   337	      ``submitted`` / ``completed`` / ``failed`` task) or the
   338	      read-back probe itself failed.
   339	    - ``("invalid-precondition", banner)`` — form re-render; the
   340	      server rejected the metrics shape. Fixable.
   341	    """
   342	    last_exc: BaseException | None = None
   343	    needs_readback = False
   344	    for delay in _RETRY_DELAYS_S:
   345	        try:
   346	            store.submit(task_id, token, submission)
   347	            return "ok", None
   348	        except WrongToken as exc:
   349	            return "auto", _wire_error_banner(exc)
   350	        except ConflictingResubmission as exc:
   351	            return "conflict", _wire_error_banner(exc)
   352	        except InvalidPrecondition as exc:
   353	            return "invalid-precondition", _wire_error_banner(exc)
   354	        except IllegalTransition as exc:
   355	            # Could be: state==pending (we lost) | completed/failed
   356	            # (we won, orchestrator terminalized) | submitted by
   357	            # someone else (conflict). Read-back resolves it.
   358	            last_exc = exc
   359	            needs_readback = True
   360	            break
   361	        except Exception as exc:  # noqa: BLE001 — transport-shaped
   362	            last_exc = exc
   363	            time.sleep(delay)
   364	
   365	    if not needs_readback and last_exc is None:
   366	        # All retries returned cleanly is impossible (we'd return
   367	        # "ok" inside the loop). Defensive.
   368	        return "transport", "submit returned without exception or commit"
   369	
   370	    return _readback(
   371	        store=store, task_id=task_id, token=token, submission=submission, last_exc=last_exc
   372	    )
   373	
   374	
   375	def _readback(
   376	    *,
   377	    store: Any,
   378	    task_id: str,
   379	    token: str,
   380	    submission: EvaluateSubmission,
   381	    last_exc: BaseException | None,
   382	) -> tuple[str, str | None]:
   383	    last_name = last_exc.__class__.__name__ if last_exc else "unknown"
   384	    try:
   385	        task = store.read_task(task_id)
   386	    except Exception as exc:  # noqa: BLE001
   387	        return (
   388	            "transport",
   389	            f"transport failure after retries; read-back failed: {exc.__class__.__name__}",
   390	        )
   391	    state = task.state
   392	    if state == "claimed":
   393	        if task.claim is not None and task.claim.token == token:
   394	            return ("auto", f"transport failure after retries: {last_name}")
   395	        return "auto", "eden://error/wrong-token"
   396	    if state in {"submitted", "completed", "failed"}:
   397	        try:
   398	            prior = store.read_submission(task_id)
   399	        except Exception as exc:  # noqa: BLE001
   400	            return (
   401	                "transport",
   402	                (
   403	                    "transport failure after retries; "
   404	                    f"read-submission failed: {exc.__class__.__name__}"
   405	                ),
   406	            )
   407	        if prior is None:
   408	            return (
   409	                "transport",
   410	                "store invariant violation: submission missing for terminal/submitted task",
   411	            )
   412	        if submissions_equivalent(prior, submission):
   413	            return "ok", None
   414	        return "conflict", "eden://error/conflicting-resubmission"
   415	    # state == "pending"
   416	    return ("auto", f"transport failure after retries; task reclaimed: {last_name}")
