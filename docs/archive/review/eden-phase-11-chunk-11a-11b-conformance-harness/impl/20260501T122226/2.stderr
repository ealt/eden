    32	            experiment_config_path=experiment_config_path,
    33	            experiment_id=experiment_id,
    34	        )
    35	        # Defensive: if proxy creation/start raises after the upstream
    36	        # subprocess has been spawned (or after the proxy itself
    37	        # partially started threads/sockets), tear down BOTH the proxy
    38	        # and the upstream so we don't leak the eden-task-store-server
    39	        # process or the proxy thread/listener.
    40	        proxy: MisbehaveProxy | None = None
    41	        try:
    42	            proxy = MisbehaveProxy(
    43	                upstream_base_url=real.base_url,
    44	                hit_counter_path=hit_counter_path_from_env(),
    45	            )
    46	            proxy.start()
    47	        except BaseException:
    48	            if proxy is not None:
    49	                try:
    50	                    proxy.stop()
    51	                except Exception:  # noqa: BLE001
    52	                    pass
    53	            super().stop()
    54	            raise
    55	        self._proxy = proxy
    56	        return IutHandle(
    57	            base_url=proxy.base_url,
    58	            experiment_id=real.experiment_id,
    59	            extra_headers=real.extra_headers,
    60	        )
    61	
    62	    def stop(self) -> None:
    63	        if self._proxy is not None:
    64	            try:
    65	                self._proxy.stop()
    66	            except Exception:  # noqa: BLE001
    67	                pass
    68	            self._proxy = None
    69	        super().stop()

