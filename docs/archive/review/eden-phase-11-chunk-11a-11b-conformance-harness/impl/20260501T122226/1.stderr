   240	def test_implement_reclaim_with_starting_trial(
   241	    wire_client: WireClient, event_log: EventLog
   242	) -> None:
   243	    """spec/v0/05-event-protocol.md §2.2 — implement reclaim + trial.errored atomic."""
   244	    pid = _seed.create_proposal(wire_client)
   245	    _seed.mark_proposal_ready(wire_client, pid)
   246	    impl_tid = _seed.create_implement_task(wire_client, proposal_id=pid)
   247	    _seed.claim(wire_client, impl_tid)
   248	    trial_id = _seed.create_trial(wire_client, proposal_id=pid, status="starting")
   249	    _seed.reclaim(wire_client, impl_tid, cause="operator")
   250	    events = event_log.replay_all()
   251	    [_reclaimed] = [
   252	        e
   253	        for e in event_log.find_by_type(events, "task.reclaimed")
   254	        if e["data"].get("task_id") == impl_tid
   255	    ]
   256	    [_errored] = [
   257	        e
   258	        for e in event_log.find_by_type(events, "trial.errored")
   259	        if e["data"].get("trial_id") == trial_id
   260	    ]

