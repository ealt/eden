     1	"""Verify every conformance scenario cites a real spec MUST.
     2	
     3	Walks every test under ``conformance/scenarios/`` (excluding ``_meta/``),
     4	extracts the first docstring line, parses out
     5	``spec/v0/<chapter>.md §<sec>``, and asserts:
     6	
     7	1. The cited section exists in the target chapter.
     8	2. The cited section (or any ancestor section in the same chapter)
     9	   contains a normative MUST. Per chapter 9 §3, the suite asserts
    10	   MUSTs only; SHOULDs and MAYs are interop guidance, not interop
    11	   contracts. The hierarchy walk lets a §3.2-level citation inherit
    12	   from a §3-level MUST.
    13	3. Every chapter-9 §5 scenario-index group has at least one citing test.
    14	
    15	Exit 0 on clean, 1 on unresolved citations, 2 on setup errors.
    16	"""
    17	
    18	from __future__ import annotations
    19	
    20	import ast
    21	import re
    22	import sys
    23	from pathlib import Path
    24	
    25	REPO_ROOT = Path(__file__).resolve().parents[4]
    26	SPEC_DIR = REPO_ROOT / "spec" / "v0"
    27	SCENARIOS_DIR = REPO_ROOT / "conformance" / "scenarios"
    28	
    29	CITATION_RE = re.compile(
    30	    r"spec/v0/(?P<chapter>[0-9]{2}-[a-z-]+\.md)\s+§(?P<section>\d+(?:\.\d+)*)"
    31	)
    32	HEADING_RE = re.compile(r"^(?P<hashes>#{2,4})\s+(?P<num>\d+(?:\.\d+)*)(?:[.\s]|$)")
    33	MUST_RE = re.compile(r"\bMUST\b")
    34	
    35	# Index groups from spec/v0/09-conformance.md §5. Each group MUST have
    36	# at least one citing test in conformance/scenarios/.
    37	INDEX_FILE_PATTERNS = {
    38	    "Task lifecycle": "test_task_lifecycle.py",
    39	    "Claim tokens": "test_claim_tokens.py",
    40	    "Submit idempotency": "test_submit_idempotency.py",
    41	    "Reclamation": "test_reclamation.py",
    42	    "Atomicity (regression test)": "test_atomicity.py",
    43	    "Event envelope": "test_event_envelope.py",
    44	    "Per-type event payloads": "test_event_payloads.py",
    45	    "Composite commits": "test_composite_commits.py",
    46	    "Event delivery": "test_event_delivery.py",
    47	    "Status codes": "test_status_codes.py",
    48	    "Problem+json envelope": "test_problem_json.py",
    49	    "Error vocabulary closure": "test_error_vocabulary.py",
    50	    "Experiment-id header disagreement": "test_experiment_id_header.py",
    51	    "Integrate idempotency": "test_integrate_idempotency.py",
    52	}
    53	
    54	
    55	def _heading_depth(num: str) -> int:
    56	    return num.count(".") + 1
    57	
    58	
    59	def _section_or_ancestor_has_must(
    60	    sections: dict[str, str], section: str
    61	) -> bool:
    62	    r"""Check that the section, or any ancestor in the same chapter, has MUST.
    63	
    64	    Walks from the cited section up to its top-level parent; returns
    65	    True if any of those texts contains a `\bMUST\b` token.
    66	    """
    67	    parts = section.split(".")
    68	    while parts:
    69	        candidate = ".".join(parts)
    70	        text = sections.get(candidate)
    71	        if text and MUST_RE.search(text):
    72	            return True
    73	        parts.pop()
    74	    return False
    75	
    76	
    77	def build_section_text_index() -> dict[str, dict[str, str]]:
    78	    """Return ``{filename: {section_num: text}}`` for every spec heading.
    79	
    80	    The "text" is everything from the heading line through (but not
    81	    including) the next heading whose depth is the same or shallower.
    82	    This lets the MUST-check examine the full section body.
    83	    """
    84	    index: dict[str, dict[str, str]] = {}
    85	    for f in sorted(SPEC_DIR.glob("*.md")):
    86	        sections: dict[str, str] = {}
    87	        lines = f.read_text().splitlines()
    88	        # Pre-extract heading positions.
    89	        positions: list[tuple[int, str, int]] = []
    90	        for i, line in enumerate(lines):
    91	            m = HEADING_RE.match(line)
    92	            if m:
    93	                positions.append((i, m.group("num"), _heading_depth(m.group("num"))))
    94	        for idx, (start, num, depth) in enumerate(positions):
    95	            end = len(lines)
    96	            for j in range(idx + 1, len(positions)):
    97	                _next_start, _next_num, next_depth = positions[j]
    98	                if next_depth <= depth:
    99	                    end = positions[j][0]
   100	                    break
   101	            sections[num] = "\n".join(lines[start:end])
   102	        index[f.name] = sections
   103	    return index
   104	
   105	
   106	def iter_test_functions(path: Path):
   107	    """Yield (path, function_name, first_docstring_line) for every test_*."""
   108	    tree = ast.parse(path.read_text())
   109	    for node in ast.walk(tree):
   110	        if isinstance(node, ast.FunctionDef) and node.name.startswith("test_"):
   111	            doc = ast.get_docstring(node)
   112	            first_line = doc.splitlines()[0] if doc else ""
   113	            yield (path, node.name, first_line)
   114	
   115	
   116	def main() -> int:
   117	    """Run the citation check and report findings."""
   118	    if not SCENARIOS_DIR.is_dir():
   119	        print(f"FAIL: {SCENARIOS_DIR} not found", file=sys.stderr)
   120	        return 2
   121	    spec_index = build_section_text_index()
   122	    failures: list[str] = []
   123	    coverage: dict[str, list[tuple[Path, str, str]]] = {
   124	        chapter: [] for chapter in spec_index
   125	    }
   126	    file_to_tests: dict[str, list[str]] = {}
   127	    for test_file in sorted(SCENARIOS_DIR.glob("test_*.py")):
   128	        for path, name, first_line in iter_test_functions(test_file):
   129	            file_to_tests.setdefault(test_file.name, []).append(name)
   130	            m = CITATION_RE.search(first_line)
   131	            if not m:
   132	                failures.append(
   133	                    f"{path.relative_to(REPO_ROOT)}::{name}: docstring "
   134	                    f"first line missing 'spec/v0/<chapter>.md §<sec>' citation:\n"
   135	                    f"    {first_line!r}"
   136	                )
   137	                continue
   138	            chapter = m.group("chapter")
   139	            section = m.group("section")
   140	            sections = spec_index.get(chapter)
   141	            if sections is None:
   142	                failures.append(
   143	                    f"{path.relative_to(REPO_ROOT)}::{name}: cites unknown "
   144	                    f"chapter {chapter}"
   145	                )
   146	                continue
   147	            text = sections.get(section)
   148	            if text is None:
   149	                failures.append(
   150	                    f"{path.relative_to(REPO_ROOT)}::{name}: cites "
   151	                    f"{chapter} §{section} (no such section in target)"
   152	                )
   153	                continue
   154	            if not _section_or_ancestor_has_must(sections, section):
   155	                failures.append(
   156	                    f"{path.relative_to(REPO_ROOT)}::{name}: cites "
   157	                    f"{chapter} §{section}, but neither that section nor "
   158	                    f"any ancestor contains a normative MUST. Per "
   159	                    f"chapter 9 §3 the suite asserts MUSTs only; either "
   160	                    f"cite a different section or strengthen the spec."
   161	                )
   162	                continue
   163	            coverage[chapter].append((path, name, section))
   164	    # Index-group coverage check.
   165	    for group, file_pattern in INDEX_FILE_PATTERNS.items():
   166	        if not file_to_tests.get(file_pattern):
   167	            failures.append(
   168	                f"chapter 9 §5 index group {group!r}: no tests in expected "
   169	                f"file conformance/scenarios/{file_pattern}"
   170	            )
   171	    if failures:
   172	        print("Citation-check FAILURES:")
   173	        for f in failures:
   174	            print(f"  - {f}")
   175	        return 1
   176	    total = sum(len(v) for v in coverage.values())
   177	    print(f"OK: {total} scenarios cite valid spec MUSTs.")
   178	    for chapter in sorted(coverage):
   179	        if not coverage[chapter]:
   180	            continue
   181	        sections = sorted({s for (_p, _n, s) in coverage[chapter]})
   182	        print(f"  {chapter}: §§ {', '.join(sections)}")
   183	    return 0
   184	
   185	
   186	if __name__ == "__main__":
   187	    raise SystemExit(main())

