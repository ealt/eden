   140	        if e["data"].get("trial_id") == trial_id
   141	    ]
   142	    eval_completed = [
   143	        e
   144	        for e in event_log.find_by_type(events, "task.completed")
   145	        if e["data"].get("task_id", "").startswith("eval-")
   146	    ]
