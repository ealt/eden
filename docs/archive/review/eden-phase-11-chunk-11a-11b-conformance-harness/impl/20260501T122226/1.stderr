     1	"""Event delivery semantics — chapter 05 §4 + chapter 07 §6.2."""
     2	
     3	from __future__ import annotations
     4	
     5	import threading
     6	import time
     7	
     8	import pytest
     9	from conformance.harness import _seed
    10	from conformance.harness.event_cursor import EventLog
    11	from conformance.harness.wire_client import WireClient
    12	
    13	pytestmark = pytest.mark.conformance
    14	
    15	
    16	def _drive_some(client: WireClient) -> None:
    17	    tid = _seed.create_plan_task(client)
    18	    c = _seed.claim(client, tid)
    19	    _seed.submit_plan(client, tid, token=c["token"])
    20	    _seed.accept(client, tid)
    21	
    22	
    23	def test_total_order_per_experiment(
    24	    wire_client: WireClient, event_log: EventLog
    25	) -> None:
    26	    """spec/v0/05-event-protocol.md §4.1 — repeated reads observe the same total order."""
    27	    _drive_some(wire_client)
    28	    e1 = event_log.replay_all()
    29	    e2 = event_log.replay_all()
    30	    assert [e["event_id"] for e in e1] == [e["event_id"] for e in e2]
    31	
    32	
    33	def test_replay_from_cursor_zero_returns_all_events(
    34	    wire_client: WireClient, event_log: EventLog
    35	) -> None:
    36	    """spec/v0/05-event-protocol.md §4.4 — replay from cursor=0 returns the full stream."""
    37	    _drive_some(wire_client)
    38	    events = event_log.replay_all()
    39	    assert len(events) >= 4  # task.created, task.claimed, task.submitted, task.completed
    40	
    41	
    42	def test_replay_repeatable(
    43	    wire_client: WireClient, event_log: EventLog
    44	) -> None:
    45	    """spec/v0/05-event-protocol.md §4.4 — replay is deterministic across reads."""
    46	    _drive_some(wire_client)
    47	    e1, _ = event_log.replay_from(0)
    48	    e2, _ = event_log.replay_from(0)
    49	    assert e1 == e2
    50	
    51	
    52	def test_subscribe_at_least_once_via_reconnect(
    53	    wire_client: WireClient, event_log: EventLog
    54	) -> None:
    55	    """spec/v0/05-event-protocol.md §4.3 — at-least-once delivery to active subscribers.
    56	
    57	    Subscribe and consume one batch, then reconnect to the subscribe
    58	    endpoint with the same prior cursor; the IUT MUST redeliver the
    59	    events from that point. The §4.3 MUST is "deliver every appended
    60	    event to every active subscriber at least once"; reconnect-with-
    61	    prior-cursor on the subscribe endpoint is the testable consequence.
    62	    """
    63	    _drive_some(wire_client)
    64	    # First subscribe pass from cursor=0; pulls everything that's there.
    65	    events_a, _cursor_after = event_log.subscribe(cursor=0, timeout=10.0)
    66	    assert events_a, "subscribe should return existing events when cursor=0"
    67	    # Reconnect with the SAME prior cursor; subscribe MUST redeliver.
    68	    events_b, _ = event_log.subscribe(cursor=0, timeout=10.0)
    69	    ids_a = [e["event_id"] for e in events_a]
    70	    ids_b = [e["event_id"] for e in events_b]
    71	    assert ids_a == ids_b, (
    72	        "subscribe redelivery: same prior cursor must yield the same events"
    73	    )
    74	
    75	
    76	def test_subscribe_long_poll_yields_event(
    77	    wire_client: WireClient, event_log: EventLog
    78	) -> None:
    79	    """spec/v0/05-event-protocol.md §4.3 — subscribe MUST deliver appended events.
    80	
    81	    The chapter-5 §4.3 MUST is "deliver every appended event to every
    82	    active subscriber at least once". The §6.2 long-poll wiring is
    83	    the binding through which we observe that delivery.
    84	    """
    85	    # Get current cursor.
    86	    events_before, cursor = event_log.replay_from(0)
    87	    started_count = len(events_before)
    88	    yielded: list[dict] = []
    89	
    90	    def _poll() -> None:
    91	        ev, _ = event_log.subscribe(cursor=started_count, timeout=10.0)
    92	        yielded.extend(ev)
    93	
    94	    t = threading.Thread(target=_poll)
    95	    t.start()
    96	    time.sleep(0.2)  # ensure subscribe is in-flight before transition
    97	    _drive_some(wire_client)
    98	    t.join(timeout=10.0)
    99	    assert not t.is_alive(), "subscribe poll did not return in time"
   100	    assert yielded, "long-poll should yield at least the new events"
   101	
   102	
   103	# NOTE: An earlier draft of this file had `test_subscribe_empty_batch_after_timeout`,
   104	# which asserted that subscribe against a quiescent log returns the empty-batch
   105	# shape `{events: [], cursor: <unchanged>}` on the server-chosen timeout. Chapter
   106	# 7 §6.2 makes both the timeout (RECOMMENDED 30s, a SHOULD) and the empty-batch
   107	# shape descriptive rather than MUST. With no normative MUST backing the
   108	# assertion, that test was dropped per the citation-check rule.

