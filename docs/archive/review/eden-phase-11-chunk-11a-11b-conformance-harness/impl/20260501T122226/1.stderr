     1	"""RFC 7807 problem+json envelope shape — chapter 07 §7."""
     2	
     3	from __future__ import annotations
     4	
     5	import re
     6	
     7	import pytest
     8	from conformance.harness import _seed
     9	from conformance.harness.wire_client import WireClient
    10	
    11	pytestmark = pytest.mark.conformance
    12	
    13	_TYPE_URI_PATTERN = re.compile(r"^eden://error/[a-z][a-z0-9-]*$")
    14	
    15	
    16	def _assert_problem_envelope(resp_status: int, body: dict, instance_url: str) -> None:
    17	    """Common envelope-shape check applied to each error response.
    18	
    19	    Verifies all five §7 envelope fields, and asserts `instance`
    20	    matches the URL the client requested (a server that returned a
    21	    canned `instance` value would fail this check).
    22	    """
    23	    assert isinstance(body.get("type"), str), body
    24	    assert _TYPE_URI_PATTERN.match(body["type"]), body
    25	    assert isinstance(body.get("title"), str) and body["title"], body
    26	    assert isinstance(body.get("status"), int) and body["status"] == resp_status, body
    27	    assert isinstance(body.get("detail"), str) and body["detail"], body
    28	    assert isinstance(body.get("instance"), str) and body["instance"], body
    29	    assert body["instance"] == instance_url, (
    30	        f"problem+json `instance` should equal request URL "
    31	        f"{instance_url!r}, got {body['instance']!r}"
    32	    )
    33	
    34	
    35	def _assert_content_type(resp_headers) -> None:
    36	    ctype = resp_headers.get("content-type", "")
    37	    assert "application/problem+json" in ctype, ctype
    38	
    39	
    40	def test_problem_json_400_bad_request(wire_client: WireClient) -> None:
    41	    """spec/v0/07-wire-protocol.md §7 — 400 returns problem+json envelope."""
    42	    r = wire_client.post(wire_client.tasks_path(), json={"bogus": True})
    43	    assert r.status_code == 400
    44	    _assert_content_type(r.headers)
    45	    _assert_problem_envelope(400, r.json(), str(r.request.url))
    46	
    47	
    48	def test_problem_json_403_wrong_token(wire_client: WireClient) -> None:
    49	    """spec/v0/07-wire-protocol.md §7 — 403 wrong-token returns problem+json envelope."""
    50	    tid = _seed.create_plan_task(wire_client)
    51	    _seed.claim(wire_client, tid)
    52	    r = _seed.submit_plan(wire_client, tid, token="WRONG")
    53	    assert r.status_code == 403
    54	    _assert_content_type(r.headers)
    55	    _assert_problem_envelope(403, r.json(), str(r.request.url))
    56	
    57	
    58	def test_problem_json_404_not_found(wire_client: WireClient) -> None:
    59	    """spec/v0/07-wire-protocol.md §7 — 404 returns problem+json envelope."""
    60	    r = wire_client.get(wire_client.tasks_path("nope"))
    61	    assert r.status_code == 404
    62	    _assert_content_type(r.headers)
    63	    _assert_problem_envelope(404, r.json(), str(r.request.url))
    64	
    65	
    66	def test_problem_json_409_illegal_transition(wire_client: WireClient) -> None:
    67	    """spec/v0/07-wire-protocol.md §7 — 409 illegal-transition returns problem+json."""
    68	    tid = _seed.create_plan_task(wire_client)
    69	    r = _seed.accept(wire_client, tid)
    70	    assert r.status_code == 409
    71	    _assert_content_type(r.headers)
    72	    _assert_problem_envelope(409, r.json(), str(r.request.url))

