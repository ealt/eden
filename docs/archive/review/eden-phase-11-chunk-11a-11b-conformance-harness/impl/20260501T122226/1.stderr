     1	"""Atomicity (best-effort regression test).
     2	
     3	Per spec/v0/09-conformance.md §3, this is a regression-style test, NOT a
     4	certification of the chapter-04 §1.3 atomicity invariant. Black-box
     5	testing cannot prove the absence of a sufficiently-narrow window.
     6	"""
     7	
     8	from __future__ import annotations
     9	
    10	import threading
    11	import time
    12	
    13	import pytest
    14	from conformance.harness import _seed
    15	from conformance.harness.event_cursor import EventLog
    16	from conformance.harness.wire_client import WireClient
    17	
    18	pytestmark = pytest.mark.conformance
    19	
    20	
    21	def test_task_state_change_visible_only_after_event_appended(
    22	    wire_client: WireClient, event_log: EventLog
    23	) -> None:
    24	    """spec/v0/04-task-protocol.md §1.3 — every state change is accompanied by its event.
    25	
    26	    NOTE: best-effort regression test, not a certification of §1.3
    27	    linearizability. Black-box testing cannot prove the absence of a
    28	    sufficiently-narrow window where the IUT briefly exposed a state
    29	    without its event.
    30	
    31	    The test drives one transition (`pending → claimed`) while
    32	    concurrently long-poll-subscribing to the event log. When subscribe
    33	    yields the `task.claimed` event, an immediate task read MUST show
    34	    `state == "claimed"` (not `pending`); a follow-up read MUST also
    35	    be consistent. A regression that advanced state ahead of the event
    36	    would be visible if the poller saw the new state before its event.
    37	    """
    38	    tid = _seed.create_plan_task(wire_client)
    39	    # Drain the events from task creation so the subscribe waits past them.
    40	    initial_events, cursor = event_log.replay_from(0)
    41	    assert len(initial_events) >= 1, "task.created event expected"
    42	
    43	    yielded: list[dict] = []
    44	    poll_done = threading.Event()
    45	
    46	    def _poll() -> None:
    47	        try:
    48	            ev, _ = event_log.subscribe(cursor=cursor, timeout=10.0)
    49	            yielded.extend(ev)
    50	        finally:
    51	            poll_done.set()
    52	
    53	    poller = threading.Thread(target=_poll, daemon=True)
    54	    poller.start()
    55	    # Give subscribe a moment to land on the wire before transitioning.
    56	    time.sleep(0.1)
    57	
    58	    _seed.claim(wire_client, tid, worker_id="atomic-w")
    59	    poll_done.wait(timeout=10.0)
    60	    assert poll_done.is_set(), "long-poll did not return after transition"
    61	
    62	    claimed_in_yield = [
    63	        e
    64	        for e in yielded
    65	        if e.get("type") == "task.claimed" and e["data"].get("task_id") == tid
    66	    ]
    67	    assert claimed_in_yield, (
    68	        f"subscribe should have yielded task.claimed for {tid}; "
    69	        f"got {[e.get('type') for e in yielded]}"
    70	    )
    71	
    72	    # Once the event has been observed, the task MUST be in `claimed`
    73	    # state. A regression that exposed `claimed` to readers WITHOUT
    74	    # appending the event would not be observable here directly, but
    75	    # one that exposed the event without committing the state would be.
    76	    task = _seed.read_task(wire_client, tid)
    77	    assert task["state"] == "claimed", (
    78	        f"observed task.claimed event but task state is {task['state']!r}"
    79	    )
    80	    # And the state must not regress on a follow-up read.
    81	    task_followup = _seed.read_task(wire_client, tid)
    82	    assert task_followup["state"] == "claimed"

