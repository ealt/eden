     1	"""Composite-commit invariants — chapter 05 §2.2.
     2	
     3	Covers the §2.2 composite-commit cases observable through task-store
     4	wire endpoints (implement-dispatch, implement-terminal,
     5	evaluate-terminal cases, retry-exhausted eval_error terminalization,
     6	implement-reclaim with starting trial). The trial-promotion §2.2 case
     7	is covered separately in test_integrate_idempotency.py because the
     8	wire endpoint binding it lives in chapter 7 §5.
     9	
    10	Includes one non-composite control case
    11	(`test_evaluate_terminal_eval_error_keeps_trial_starting`): the
    12	worker-side eval_error per-attempt path explicitly does NOT compose
    13	with a trial state change, per chapter 4 §4.3.
    14	"""
    15	
    16	from __future__ import annotations
    17	
    18	import pytest
    19	from conformance.harness import _seed
    20	from conformance.harness.event_cursor import EventLog
    21	from conformance.harness.wire_client import WireClient
    22	
    23	pytestmark = pytest.mark.conformance
    24	
    25	
    26	def _types_for(events: list[dict], task_or_trial_id: str) -> set[str]:
    27	    return {
    28	        e["type"]
    29	        for e in events
    30	        if e["data"].get("task_id") == task_or_trial_id
    31	        or e["data"].get("trial_id") == task_or_trial_id
    32	        or e["data"].get("proposal_id") == task_or_trial_id
    33	    }
    34	
    35	
    36	def test_implement_dispatch_atomic(
    37	    wire_client: WireClient, event_log: EventLog
    38	) -> None:
    39	    """spec/v0/05-event-protocol.md §2.2 — implement create + proposal dispatch atomic."""
    40	    pid = _seed.create_proposal(wire_client)
    41	    _seed.mark_proposal_ready(wire_client, pid)
    42	    impl_tid = _seed.create_implement_task(wire_client, proposal_id=pid)
    43	    events = event_log.replay_all()
    44	    created = [
    45	        e
    46	        for e in event_log.find_by_type(events, "task.created")
    47	        if e["data"].get("task_id") == impl_tid
    48	    ]
    49	    dispatched = [
    50	        e
    51	        for e in event_log.find_by_type(events, "proposal.dispatched")
    52	        if e["data"].get("proposal_id") == pid
    53	    ]
    54	    assert len(created) == 1
    55	    assert len(dispatched) == 1
    56	    proposal = _seed.read_proposal(wire_client, pid)
    57	    assert proposal["state"] == "dispatched"
    58	
    59	
    60	def test_implement_terminal_completes_proposal(
    61	    wire_client: WireClient, event_log: EventLog
    62	) -> None:
    63	    """spec/v0/05-event-protocol.md §2.2 — implement terminal + proposal completed atomic.
    64	
    65	    Asserts BOTH `task.completed` (on the implement task) AND
    66	    `proposal.completed` (on the referenced proposal) appear; per
    67	    §2.2 the composite commit is required.
    68	    """
    69	    trial_id = _seed.drive_to_starting_trial(wire_client)
    70	    trial = _seed.read_trial(wire_client, trial_id)
    71	    pid = trial["proposal_id"]
    72	    events = event_log.replay_all()
    73	    impl_completed = [
    74	        e
    75	        for e in event_log.find_by_type(events, "task.completed")
    76	        if e["data"].get("task_id", "").startswith("impl-")
    77	    ]
    78	    completed_props = [
    79	        e
    80	        for e in event_log.find_by_type(events, "proposal.completed")
    81	        if e["data"].get("proposal_id") == pid
    82	    ]
    83	    assert len(impl_completed) == 1, (
    84	        "expected exactly one task.completed for the implement task"
    85	    )
    86	    assert len(completed_props) == 1
    87	    proposal = _seed.read_proposal(wire_client, pid)
    88	    assert proposal["state"] == "completed"
    89	
    90	
    91	def test_implement_terminal_fails_proposal(
    92	    wire_client: WireClient, event_log: EventLog
    93	) -> None:
    94	    """spec/v0/05-event-protocol.md §2.2 — implement task.failed + proposal.completed atomic.
    95	
    96	    Per chapter 4 §7 the proposal lifecycle reaches completed regardless
    97	    of whether the implement task ended in completed or failed.
    98	    """
    99	    pid = _seed.create_proposal(wire_client)
   100	    _seed.mark_proposal_ready(wire_client, pid)
   101	    impl_tid = _seed.create_implement_task(wire_client, proposal_id=pid)
   102	    impl_claim = _seed.claim(wire_client, impl_tid)
   103	    trial_id = _seed.create_trial(wire_client, proposal_id=pid, status="starting")
   104	    _seed.submit_implement(
   105	        wire_client,
   106	        impl_tid,
   107	        token=impl_claim["token"],
   108	        trial_id=trial_id,
   109	        status="error",
   110	    )
   111	    _seed.reject(wire_client, impl_tid, reason="worker_error")
   112	    events = event_log.replay_all()
   113	    failed = [
   114	        e
   115	        for e in event_log.find_by_type(events, "task.failed")
   116	        if e["data"].get("task_id") == impl_tid
   117	    ]
   118	    assert len(failed) == 1
   119	    completed_props = [
   120	        e
   121	        for e in event_log.find_by_type(events, "proposal.completed")
   122	        if e["data"].get("proposal_id") == pid
   123	    ]
   124	    assert len(completed_props) == 1
   125	
