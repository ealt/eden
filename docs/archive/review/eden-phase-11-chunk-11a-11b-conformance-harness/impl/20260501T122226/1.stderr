   152	def test_evaluate_terminal_error_emits_trial_errored(
   153	    wire_client: WireClient, event_log: EventLog
   154	) -> None:
   155	    """spec/v0/05-event-protocol.md §2.2 — evaluate error + trial.errored atomic."""
   156	    trial_id = _seed.drive_to_starting_trial(wire_client)
   157	    eval_tid = _seed.create_evaluate_task(wire_client, trial_id=trial_id)
   158	    eval_claim = _seed.claim(wire_client, eval_tid)
