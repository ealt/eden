   127	def test_evaluate_terminal_success_emits_trial_succeeded(
   128	    wire_client: WireClient, event_log: EventLog
   129	) -> None:
   130	    """spec/v0/05-event-protocol.md §2.2 — evaluate success + trial.succeeded atomic.
   131	
   132	    Asserts BOTH `task.completed` (on the evaluate task) AND
   133	    `trial.succeeded` (on the referenced trial) appear.
   134	    """
