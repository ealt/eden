   219	    wire_client: WireClient, event_log: EventLog
   220	) -> None:
   221	    """spec/v0/05-event-protocol.md §2.2 — retry-exhausted trial.eval_errored composite.
   222	
   223	    The chapter-7 §4 `declare-eval-error` endpoint binds the chapter 4
   224	    §4.3 retry-exhausted decision: it atomically transitions trial.status
   225	    `starting → eval_error` and emits trial.eval_errored.
   226	    """
   227	    trial_id = _seed.drive_to_starting_trial(wire_client)
   228	    r = _seed.declare_trial_eval_error(wire_client, trial_id)
   229	    assert 200 <= r.status_code < 300, r.text
   230	    trial = _seed.read_trial(wire_client, trial_id)
   231	    assert trial["status"] == "eval_error"
   232	    events = event_log.replay_all()
   233	    [_event] = [
   234	        e
   235	        for e in event_log.find_by_type(events, "trial.eval_errored")
   236	        if e["data"].get("trial_id") == trial_id
   237	    ]
