   181	    failures: list[str] = []
   182	    coverage: dict[str, list[tuple[Path, str, str]]] = {
   183	        chapter: [] for chapter in spec_index
   184	    }
   185	    # Group identity per scenario file: tests are matched to chapter-9
   186	    # Â§5 groups via this explicit mapping rather than citation overlap.
   187	    group_to_valid_tests: dict[str, list[tuple[Path, str]]] = {}
   188	    file_groups: dict[Path, str | None] = {}
   189	    for test_file in sorted(SCENARIOS_DIR.glob("test_*.py")):
   190	        file_group = read_module_conformance_group(test_file)
   191	        file_groups[test_file] = file_group
