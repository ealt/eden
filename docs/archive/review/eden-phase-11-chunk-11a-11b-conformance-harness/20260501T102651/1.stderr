   209	## Design
   210	
   211	### A. Layout
   212	
   213	```text
   214	conformance/
   215	├── README.md                      # Updated: "v1 ships with chunk 11a+11b"
   216	├── pyproject.toml                 # NEW — separate uv workspace member
   217	├── conftest.py                    # imports harness.plugin
   218	├── harness/
   219	│   ├── __init__.py
   220	│   ├── adapter.py                 # IutAdapter Protocol + IutHandle dataclass
   221	│   ├── plugin.py                  # pytest plugin: fixtures + marker
   222	│   ├── wire_client.py             # Thin httpx wrapper, talks /v0/ only
   223	│   └── event_cursor.py            # Helper: poll subscribe; assert event order
   224	├── adapters/
   225	│   └── reference/
   226	│       ├── __init__.py
   227	│       └── adapter.py             # Spawns task-store-server subprocess
   228	├── scenarios/
   229	│   ├── test_task_lifecycle.py
   230	│   ├── test_claim_tokens.py
   231	│   ├── test_submit_idempotency.py
   232	│   ├── test_reclamation.py
   233	│   ├── test_event_envelope.py
   234	│   ├── test_event_payloads.py
   235	│   ├── test_composite_commits.py
   236	│   ├── test_event_delivery.py     # Total order, replay, at-least-once
   237	│   ├── test_atomicity.py          # Best-effort regression test
   238	│   ├── test_status_codes.py
   239	│   ├── test_problem_json.py
   240	│   ├── test_error_vocabulary.py
   241	│   ├── test_experiment_id_header.py
