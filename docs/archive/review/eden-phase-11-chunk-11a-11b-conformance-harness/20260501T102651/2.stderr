   231	│   ├── plugin.py                  # pytest plugin: fixtures + marker
   232	│   ├── wire_client.py             # Thin httpx wrapper, talks /v0/ only
   233	│   └── event_cursor.py            # Helper: poll subscribe; assert event order
   234	├── adapters/
   235	│   └── reference/
   236	│       ├── __init__.py
