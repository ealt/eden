   382	@pytest.fixture
   383	def iut(iut_adapter_factory, tmp_path) -> IutHandle:
   384	    adapter: IutAdapter = iut_adapter_factory()
   385	    config_path = _write_minimal_experiment_config(tmp_path)
   386	    experiment_id = f"test-{uuid.uuid4().hex[:8]}"
   387	    handle = adapter.start(
   388	        experiment_config_path=config_path,
   389	        experiment_id=experiment_id,
   390	    )
