   240	│   ├── test_claim_tokens.py
   241	│   ├── test_submit_idempotency.py
   242	│   ├── test_reclamation.py
   243	│   ├── test_event_envelope.py
   244	│   ├── test_event_payloads.py
   245	│   ├── test_composite_commits.py
   246	│   ├── test_event_delivery.py     # Total order, replay, at-least-once
   247	│   ├── test_atomicity.py          # Best-effort regression test
   248	│   ├── test_status_codes.py
   249	│   ├── test_problem_json.py
   250	│   ├── test_error_vocabulary.py
   251	│   ├── test_experiment_id_header.py
   252	│   ├── test_integrate_idempotency.py
   253	│   └── _meta/
   254	│       ├── __init__.py
   255	│       └── test_self_validation.py
   256	├── tools/
