   417	
   418	```yaml
   419	  compose-smoke:
   420	    name: compose-smoke
   421	    runs-on: ubuntu-latest
   422	    steps:
   423	      - uses: actions/checkout@v4
   424	      - name: Verify docker compose is available
   425	        run: docker compose version
