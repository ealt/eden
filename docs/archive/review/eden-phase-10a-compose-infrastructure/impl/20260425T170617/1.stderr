name: eden-reference
services:
  blob-init:
    command:
      - sh
      - -c
      - mkdir -p /var/lib/eden/blobs && echo blob-volume ready
    container_name: eden-blob-init
    image: busybox:1.36.1
    networks:
      default: null
    restart: "no"
    volumes:
      - type: volume
        source: eden-blob-data
        target: /var/lib/eden/blobs
        volume: {}
  gitea:
    container_name: eden-gitea
    depends_on:
      blob-init:
        condition: service_completed_successfully
        required: true
    environment:
      GITEA__database__DB_TYPE: sqlite3
      GITEA__database__PATH: /var/lib/gitea/data/gitea.db
      GITEA__log__LEVEL: Warn
      GITEA__metrics__ENABLED: "false"
      GITEA__security__INSTALL_LOCK: "true"
      GITEA__security__INTERNAL_TOKEN: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcd
      GITEA__security__SECRET_KEY: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcd
      GITEA__server__DOMAIN: localhost
      GITEA__server__HTTP_PORT: "3000"
      GITEA__server__ROOT_URL: http://localhost:3001/
      GITEA__server__SSH_LISTEN_PORT: "2222"
      GITEA__server__SSH_PORT: "2222"
      GITEA__service__DISABLE_REGISTRATION: "true"
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - --spider
        - http://localhost:3000/api/v1/version
      timeout: 3s
      interval: 5s
      retries: 20
      start_period: 30s
    image: gitea/gitea:1.22.6-rootless
    networks:
      default: null
    ports:
      - mode: ingress
        target: 3000
        published: "3001"
        protocol: tcp
      - mode: ingress
        target: 2222
        published: "2222"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: eden-gitea-data
        target: /var/lib/gitea
        volume: {}
  postgres:
    container_name: eden-postgres
    depends_on:
      blob-init:
        condition: service_completed_successfully
        required: true
    environment:
      POSTGRES_DB: eden
      POSTGRES_PASSWORD: eden-dev-password-change-me
      POSTGRES_USER: eden
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U eden -d eden
      timeout: 3s
      interval: 5s
      retries: 10
      start_period: 10s
    image: postgres:16.6-alpine
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5433"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: eden-postgres-data
        target: /var/lib/postgresql/data
        volume: {}
networks:
  default:
    name: eden-reference_default
volumes:
  eden-blob-data:
    name: eden-reference_eden-blob-data
  eden-gitea-data:
    name: eden-reference_eden-gitea-data
  eden-postgres-data:
    name: eden-reference_eden-postgres-data

