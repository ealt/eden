     1	"""Orchestrator main loop.
     2	
     3	Drives ``run_orchestrator_iteration`` from ``eden_dispatch`` against
     4	a ``StoreClient`` (HTTP) plus an ``Integrator`` bound to a local bare
     5	git repo. Exits cleanly when quiescent or when the ``stopping`` flag
     6	is set.
     7	"""
     8	
     9	from __future__ import annotations
    10	
    11	import uuid
    12	from collections.abc import Callable
    13	
    14	from eden_dispatch import run_orchestrator_iteration
    15	from eden_git import Identity, Integrator
    16	from eden_service_common import StopFlag, get_logger
    17	from eden_storage import Store
    18	from eden_storage.errors import AlreadyExists
    19	
    20	log = get_logger(__name__)
    21	
    22	
    23	def make_id_factory(prefix: str) -> Callable[[], str]:
    24	    """Return a factory that produces ``<prefix><short-uuid>`` IDs.
    25	
    26	    UUIDs avoid cross-restart collisions on orchestrator-generated IDs.
    27	    """
    28	
    29	    def _next() -> str:
    30	        return f"{prefix}{uuid.uuid4().hex[:12]}"
    31	
    32	    return _next
    33	
    34	
    35	def run_orchestrator_loop(
    36	    *,
    37	    store: Store,
    38	    integrator: Integrator,
    39	    plan_task_ids: list[str],
    40	    implement_task_prefix: str,
    41	    evaluate_task_prefix: str,
    42	    poll_interval: float,
    43	    max_quiescent_iterations: int,
    44	    stop: StopFlag,
    45	) -> None:
    46	    """Seed plan tasks, then loop finalize + dispatch + integrate to quiescence.
    47	
    48	    Returns when either ``stop`` is set or the orchestrator has observed
    49	    ``max_quiescent_iterations`` consecutive iterations with no progress.
    50	    """
    51	    for task_id in plan_task_ids:
    52	        try:
    53	            store.create_plan_task(task_id)
    54	        except AlreadyExists as exc:
    55	            # Restart-safe: a previous orchestrator already seeded this
    56	            # task. Anything else (transport, auth, illegal-transition)
    57	            # surfaces immediately.
    58	            log.info("plan_task_seed_skip", task_id=task_id, reason=str(exc))
    59	
    60	    implement_factory = make_id_factory(implement_task_prefix)
    61	    evaluate_factory = make_id_factory(evaluate_task_prefix)
    62	
    63	    def integrate(trial_id: str) -> None:
    64	        integrator.integrate(trial_id)
    65	
    66	    quiescent = 0
    67	    while not stop.is_set():
    68	        progress = run_orchestrator_iteration(
    69	            store,
    70	            implement_task_id_factory=implement_factory,
    71	            evaluate_task_id_factory=evaluate_factory,
    72	            integrate_trial=integrate,
    73	        )
    74	        if progress:
    75	            quiescent = 0
    76	        else:
    77	            quiescent += 1
    78	            if quiescent >= max_quiescent_iterations:
    79	                log.info("quiescent", iterations=quiescent)
    80	                return
    81	        if stop.wait(poll_interval):
    82	            return
    83	
    84	
    85	_INTEGRATOR_IDENTITY = Identity(
    86	    name="EDEN Integrator",
    87	    email="integrator@eden.invalid",
    88	)
    89	
    90	
    91	def integrator_identity() -> Identity:
    92	    """Return the fixed identity used for integrator commits."""
    93	    return _INTEGRATOR_IDENTITY

