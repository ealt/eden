   164	def _drive_trial_to_success(store: InMemoryStore) -> str:
   165	    """Drive one trial through the real store API to ``status=success``.
   166	
   167	    Returns the trial_id. Uses legitimate state transitions so
   168	    internal invariants hold.
   169	    """
   170	    now = _now_factory()
   171	    # Plan task
   172	    store.create_plan_task("t-plan-1")
   173	    claim = store.claim("t-plan-1", "planner-1")
   174	    proposal = Proposal(
   175	        proposal_id="p-1",
   176	        experiment_id=store.experiment_id,
   177	        slug="feat-1",
   178	        priority=1.0,
   179	        parent_commits=["a" * 40],
   180	        artifacts_uri="file:///tmp/artifacts",
   181	        state="drafting",
   182	        created_at=now(),
   183	    )
   184	    store.create_proposal(proposal)
   185	    store.mark_proposal_ready("p-1")
   186	    store.submit(
   187	        "t-plan-1", claim.token, PlanSubmission(status="success", proposal_ids=("p-1",))
   188	    )
   189	    store.accept("t-plan-1")
   190	    # Implement task
   191	    store.create_implement_task("t-impl-1", "p-1")
   192	    claim = store.claim("t-impl-1", "implementer-1")
   193	    trial = Trial(
   194	        trial_id="tr-1",
   195	        experiment_id=store.experiment_id,
   196	        proposal_id="p-1",
   197	        status="starting",
   198	        parent_commits=["a" * 40],
   199	        branch="work/feat-1-tr-1",
   200	        started_at=now(),
   201	    )
   202	    store.create_trial(trial)
   203	    store.submit(
   204	        "t-impl-1",
   205	        claim.token,
   206	        ImplementSubmission(status="success", trial_id="tr-1", commit_sha="b" * 40),
   207	    )
   208	    store.accept("t-impl-1")
   209	    # Evaluate task
   210	    store.create_evaluate_task("t-eval-1", "tr-1")
   211	    claim = store.claim("t-eval-1", "evaluator-1")
   212	    store.submit(
   213	        "t-eval-1",
   214	        claim.token,
   215	        EvaluateSubmission(status="success", trial_id="tr-1", metrics={"loss": 0.5}),
   216	    )
   217	    store.accept("t-eval-1")
   218	    return "tr-1"
