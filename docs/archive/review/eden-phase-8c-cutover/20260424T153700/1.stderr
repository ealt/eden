     1	"""Shared fixtures for the ``Store`` conformance suite.
     2	
     3	Every test that takes ``make_store`` runs against **both** backends —
     4	``InMemoryStore`` and ``SqliteStore`` — via pytest parametrization.
     5	This is what makes "passes the conformance suite" mean something:
     6	adding a future backend (Postgres, a remote driver) requires it to
     7	pass every scenario here before being considered conforming.
     8	"""
     9	
    10	from __future__ import annotations
    11	
    12	import itertools
    13	from collections.abc import Callable, Iterator
    14	from pathlib import Path
    15	from typing import Any
    16	
    17	import pytest
    18	from eden_storage import InMemoryStore, SqliteStore, Store
    19	
    20	
    21	@pytest.fixture
    22	def token_sequence() -> Callable[[], str]:
    23	    """Deterministic claim-token factory for token-comparison assertions."""
    24	    counter = itertools.count(1)
    25	    return lambda: f"tok-{next(counter):06d}"
    26	
    27	
    28	def _memory_factory(
    29	    token_factory: Callable[[], str],
    30	    tmp_path: Path,  # noqa: ARG001 - accepted for uniform factory signature
    31	) -> Callable[..., Store]:
    32	    def _make(experiment_id: str = "exp-test", **kwargs: Any) -> Store:
    33	        return InMemoryStore(
    34	            experiment_id=experiment_id,
    35	            token_factory=token_factory,
    36	            **kwargs,
    37	        )
    38	
    39	    return _make
    40	
    41	
    42	def _sqlite_factory(
    43	    token_factory: Callable[[], str],
    44	    tmp_path: Path,
    45	) -> Callable[..., Store]:
    46	    counter = itertools.count(1)
    47	
    48	    def _make(experiment_id: str = "exp-test", **kwargs: Any) -> Store:
    49	        # Each call gets its own database so the tests that create
    50	        # multiple stores (e.g. an AlreadyExists collision test)
    51	        # don't share state.
    52	        db_path = tmp_path / f"store-{next(counter):04d}.db"
    53	        return SqliteStore(
    54	            experiment_id,
    55	            db_path,
    56	            token_factory=token_factory,
    57	            **kwargs,
    58	        )
    59	
    60	    return _make
    61	
    62	
    63	_BACKENDS: list[tuple[str, Callable[..., Callable[..., Store]]]] = [
    64	    ("memory", _memory_factory),
    65	    ("sqlite", _sqlite_factory),
    66	]
    67	
    68	
    69	@pytest.fixture(params=[name for name, _ in _BACKENDS], ids=[name for name, _ in _BACKENDS])
    70	def make_store(
    71	    request: pytest.FixtureRequest,
    72	    token_sequence: Callable[[], str],
    73	    tmp_path: Path,
    74	) -> Callable[..., Store]:
    75	    """Factory fixture parametrized across every backend.
    76	
    77	    Tests that take ``make_store`` run once per backend. Backend
    78	    implementations that drift silently from the Protocol surface
    79	    here rather than in production.
    80	    """
    81	    for name, builder in _BACKENDS:
    82	        if name == request.param:
    83	            return builder(token_sequence, tmp_path)
    84	    raise AssertionError(f"unknown backend {request.param!r}")
    85	
    86	
