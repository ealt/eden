    75	    store.create_implement_task("t-impl", "p-1")
    76	    claim = store.claim("t-impl", "impl-w")
    77	    _starting_trial(store, "tr-1", "p-1")
    78	    # Malformed: claims success but omits commit_sha.
    79	    store.submit(
    80	        "t-impl",
    81	        claim.token,
    82	        ImplementSubmission(status="success", trial_id="tr-1", commit_sha=None),
    83	    )
    84	
    85	    progress = run_orchestrator_iteration(
    86	        store,
    87	        implement_task_id_factory=lambda: "unused",
    88	        evaluate_task_id_factory=lambda: "unused",
    89	    )
    90	
    91	    assert progress is True
    92	    impl_task = store.read_task("t-impl")
    93	    assert impl_task.state == "failed"
    94	    failed = [e for e in store.events() if e.type == "task.failed"]
    95	    assert any(e.data["reason"] == "validation_error" for e in failed)
    96	```
