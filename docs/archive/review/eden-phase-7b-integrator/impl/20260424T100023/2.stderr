from datetime import UTC, datetime
from pathlib import Path
import tempfile, subprocess
from eden_git import GitRepo, Identity, Integrator, TreeEntry
from eden_storage import InMemoryStore
from eden_contracts import Proposal, Trial
from eden_storage._base import _validated_update

AUTHOR = Identity('Integrator','integrator@eden.example')
FIXED_CLOCK = datetime(2026,4,24,12,0,0,tzinfo=UTC)

td = tempfile.TemporaryDirectory()
repo = GitRepo.init(Path(td.name)/'repo')
blob = repo.write_blob(b'initial\\n')
tree = repo.write_tree_from_entries([TreeEntry(mode='100644', type='blob', sha=blob, path='README')])
seed = repo.commit_tree(tree, parents=[], message='initial\\n', author=AUTHOR, author_date='2026-04-23T00:00:00+00:00', committer_date='2026-04-23T00:00:00+00:00')
repo.update_ref('refs/heads/main', seed)
store = InMemoryStore(experiment_id='exp-1')
store.create_proposal(Proposal(proposal_id='p-1', experiment_id='exp-1', slug='speedup', priority=1.0, parent_commits=[seed], artifacts_uri='file:///tmp/art/', state='drafting', created_at='2026-04-23T00:00:00Z'))
store.create_trial(Trial(trial_id='tr-1', experiment_id='exp-1', proposal_id='p-1', status='starting', parent_commits=[seed], branch='work/tr-1', started_at='2026-04-23T00:30:00Z'))
base_tree = repo.commit_tree_sha(seed)
blob = repo.write_blob(b\"print('hi')\\n\")
new_tree = repo.write_tree_with_file(base_tree, 'work.py', blob)
work = repo.commit_tree(new_tree, parents=[seed], message='work\\n', author=AUTHOR, author_date='2026-04-23T01:00:00+00:00', committer_date='2026-04-23T01:00:00+00:00')
repo.update_ref('refs/heads/work/tr-1', work)
store._trials['tr-1'] = _validated_update(store.read_trial('tr-1'), status='success', commit_sha=work, metrics={'score':1.0}, completed_at='2026-04-23T02:00:00Z')
integ = Integrator(store=store, repo=repo, author=AUTHOR, clock=lambda: FIXED_CLOCK)
res = integ.integrate('tr-1')
trial_tree = repo.commit_tree_sha(res.trial_commit_sha)
extra_blob = repo.write_blob(b'evil\\n')
bad_tree = repo.write_tree_with_file(trial_tree, 'extra.txt', extra_blob)
bad_commit = repo.commit_tree(bad_tree, parents=[seed], message='trial: tr-1 speedup\\n', author=AUTHOR, author_date='2026-04-24T12:00:00+00:00', committer_date='2026-04-24T12:00:00+00:00')
repo.update_ref('refs/heads/trial/tr-1-speedup', bad_commit, expected_old_sha=res.trial_commit_sha)
store._trials['tr-1'] = _validated_update(store.read_trial('tr-1'), trial_commit_sha=bad_commit)
repo.delete_ref('refs/heads/work/tr-1')
subprocess.run(['git','-C',str(repo.path),'gc','--prune=now','--quiet'], check=True, capture_output=True)
print('worker commit exists?', repo.commit_exists(work))
try:
    integ.integrate('tr-1')
    print('accepted')
except Exception as e:
    print(type(e).__name__, str(e))
