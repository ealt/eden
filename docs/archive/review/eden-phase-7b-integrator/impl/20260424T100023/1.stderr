     2	
     3	The integrator writes one eval-manifest file per ``trial/*`` commit
     4	at ``.eden/trials/<trial_id>/eval.json``. This module produces the
     5	manifest bytes from a ``Trial`` object.
     6	
     7	Required-field values come directly from the trial per §4.2; the
     8	builder MUST NOT synthesize or transform them. Optional fields
     9	(``description``, ``artifacts_uri``) are emitted only when present on
    10	the trial.
    11	
    12	Byte stability is load-bearing: the integrator's idempotency check in
    13	``integrator.py`` step 2 re-derives the manifest from the replayed
    14	trial and compares byte-for-byte against the committed blob. Any
    15	non-determinism here produces false ``CorruptIntegrationState``
    16	errors on re-invocation.
    17	"""
    18	
    19	from __future__ import annotations
    20	
    21	import json
    22	
    23	from eden_contracts import Trial
    24	
    25	
    26	class ManifestFieldMissing(ValueError):
    27	    """A required §4.2 field is absent from the trial."""
    28	
    29	
    30	def build_manifest(trial: Trial) -> bytes:
    31	    """Serialize ``trial`` as the §4.2 eval manifest.
    32	
    33	    The output is UTF-8 JSON with ``sort_keys=True``, ``indent=2``,
    34	    and a trailing newline. Required-field absences raise
    35	    ``ManifestFieldMissing``; callers translate these into
    36	    ``NotReadyForIntegration`` at the integrator layer.
    37	    """
    38	    if trial.commit_sha is None:
    39	        raise ManifestFieldMissing("trial.commit_sha is required (§4.2)")
    40	    if trial.metrics is None:
    41	        raise ManifestFieldMissing("trial.metrics is required (§4.2)")
    42	    if trial.completed_at is None:
    43	        raise ManifestFieldMissing("trial.completed_at is required (§4.2)")
    44	
    45	    payload: dict[str, object] = {
    46	        "trial_id": trial.trial_id,
    47	        "proposal_id": trial.proposal_id,
    48	        "commit_sha": trial.commit_sha,
    49	        "parent_commits": list(trial.parent_commits),
    50	        "metrics": dict(trial.metrics),
    51	        "completed_at": trial.completed_at,
    52	    }
    53	    if trial.artifacts_uri is not None:
    54	        payload["artifacts_uri"] = trial.artifacts_uri
    55	    if trial.description is not None:
    56	        payload["description"] = trial.description
    57	
    58	    # allow_nan=False rejects NaN / +-inf — those are not valid JSON and
    59	    # the spec requires eval.json to be a JSON file. Defense in depth
    60	    # behind Store.validate_metrics's finite-float check.
    61	    serialized = json.dumps(
    62	        payload, sort_keys=True, indent=2, ensure_ascii=False, allow_nan=False
    63	    )
    64	    return (serialized + "\n").encode("utf-8")

