   764	    def test_committer_defaults_to_author(
   765	        self,
   766	        store: Store,
   767	        repo: GitRepo,
   768	        seed_sha: str,
   769	    ) -> None:
   770	        commit = _make_work_branch(repo, branch="work/tr-1", parent=seed_sha)
   771	        _seed_success_trial(
   772	            store,
   773	            trial_id="tr-1",
