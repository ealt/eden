    66	class AtomicityViolation(IntegratorError):
    67	    """§3.4 compensating delete failed after the store-side write also failed."""
    68	
    69	    def __init__(
    70	        self,
    71	        message: str,
    72	        *,
    73	        original: BaseException,
    74	        rollback: BaseException,
    75	    ) -> None:
    76	        super().__init__(message)
    77	        self.original = original
    78	        self.rollback = rollback
