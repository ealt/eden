   806	            commit_sha=commit,
   807	        )
   808	        committer = Identity("CI Bot", "ci@eden.example")
   809	        integ = Integrator(
   810	            store=store,
   811	            repo=repo,
   812	            author=AUTHOR,
   813	            committer=committer,
   814	            clock=lambda: FIXED_CLOCK,
   815	        )
   816	        result = integ.integrate("tr-1")
   817	        raw = _raw_commit(repo, result.trial_commit_sha)
