   721	    def test_compensating_delete_failure_surfaces_atomicity_violation(
   722	        self,
   723	        integrator: Integrator,
   724	        store: Store,
   725	        repo: GitRepo,
   726	        seed_sha: str,
   727	        monkeypatch: pytest.MonkeyPatch,
