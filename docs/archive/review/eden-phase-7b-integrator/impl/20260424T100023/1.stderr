    91	class Integrator:
    92	    """Phase 7b reference integrator.
    93	
    94	    Instances are light-weight and safe to reuse across trials. The
    95	    ``store`` and ``repo`` are held by reference; callers are
    96	    expected to scope them to the same experiment.
    97	    """
    98	
    99	    def __init__(
   100	        self,
   101	        *,
   102	        store: Store,
   103	        repo: GitRepo,
   104	        author: Identity,
   105	        committer: Identity | None = None,
   106	        clock: Callable[[], datetime] | None = None,
   107	    ) -> None:
   108	        self._store = store
   109	        self._repo = repo
   110	        self._author = author
   111	        self._committer = committer if committer is not None else author
   112	        self._clock = clock if clock is not None else _default_clock
   113	
   114	    def integrate(self, trial_id: str) -> IntegrationResult:
   115	        """Promote ``trial_id`` per §3.2 / §3.4.
   116	
   117	        Returns ``already_integrated=True`` on the idempotent no-op
   118	        path (§5.3 bullet 1). Raises ``IntegratorError`` subclasses on
   119	        precondition failure; ``GitError`` / ``StorageError`` from
   120	        underlying operations propagate unchanged.
   121	        """
   122	        trial = self._store.read_trial(trial_id)
   123	        proposal = self._store.read_proposal(trial.proposal_id)
   124	        slug = proposal.slug
   125	        branch = f"trial/{trial.trial_id}-{slug}"
   126	        branch_ref = f"refs/heads/{branch}"
   127	
   128	        if trial.trial_commit_sha is not None:
   129	            return self._check_idempotent(trial, branch, branch_ref)
   130	
   131	        self._require_promotion_preconditions(trial)
   132	        self._require_reachability(trial)
   133	        manifest_path = _manifest_path(trial.trial_id)
   134	        self._require_no_manifest_collision(trial, manifest_path)
   135	
   136	        assert trial.commit_sha is not None
   137	        tree_sha = self._build_squash_tree(trial, manifest_path)
   138	        commit_sha = self._commit_squash(trial, slug, tree_sha)
   139	
   140	        self._repo.create_ref(branch_ref, commit_sha)
   141	
   142	        try:
   143	            self._store.integrate_trial(trial.trial_id, commit_sha)
   144	        except BaseException as store_error:
   145	            try:
   146	                self._repo.delete_ref(branch_ref, expected_old_sha=commit_sha)
   147	            except BaseException as rollback_error:
   148	                raise AtomicityViolation(
   149	                    f"integrator failed to commit trial {trial.trial_id!r} "
   150	                    f"and the compensating ref-delete also failed; "
   151	                    f"ref {branch_ref!r} is dangling at {commit_sha}",
   152	                    original=store_error,
   153	                    rollback=rollback_error,
   154	                ) from store_error
   155	            raise
   156	
   157	        return IntegrationResult(
   158	            trial_id=trial.trial_id,
   159	            trial_commit_sha=commit_sha,
   160	            branch=branch,
   161	            already_integrated=False,
   162	        )
   163	
   164	    # ------------------------------------------------------------------
   165	    # Preconditions
   166	    # ------------------------------------------------------------------
   167	
   168	    def _require_promotion_preconditions(self, trial: Trial) -> None:
   169	        if trial.status != "success":
   170	            raise NotReadyForIntegration(
   171	                f"trial {trial.trial_id!r} status is {trial.status!r}, not 'success'"
   172	            )
   173	        if trial.commit_sha is None:
   174	            raise NotReadyForIntegration(
   175	                f"trial {trial.trial_id!r} has no commit_sha"
   176	            )
   177	        if trial.branch is None:
   178	            raise NotReadyForIntegration(
   179	                f"trial {trial.trial_id!r} has no branch"
   180	            )
   181	
   182	        branch_ref = f"refs/heads/{trial.branch}"
   183	        tip = self._repo.resolve_ref(branch_ref)
   184	        if tip is None:
   185	            raise NotReadyForIntegration(
   186	                f"trial {trial.trial_id!r} branch {trial.branch!r} does not exist"
   187	            )
   188	        if tip != trial.commit_sha and not self._repo.is_ancestor(
   189	            trial.commit_sha, tip
   190	        ):
   191	            raise NotReadyForIntegration(
   192	                f"trial {trial.trial_id!r} commit_sha {trial.commit_sha!r} "
   193	                f"is not reachable from branch {trial.branch!r} tip {tip!r}"
   194	            )
   195	
   196	        metrics = trial.metrics if trial.metrics is not None else {}
   197	        try:
   198	            self._store.validate_metrics(metrics)
   199	        except InvalidPrecondition as exc:
   200	            raise NotReadyForIntegration(
   201	                f"trial {trial.trial_id!r} metrics failed schema validation: {exc}"
   202	            ) from exc
   203	
   204	    def _require_reachability(self, trial: Trial) -> None:
   205	        assert trial.commit_sha is not None
   206	        for parent in trial.parent_commits:
   207	            if not self._repo.is_ancestor(parent, trial.commit_sha):
   208	                raise ReachabilityViolation(
   209	                    f"trial {trial.trial_id!r}: parent {parent!r} is not an "
   210	                    f"ancestor of commit_sha {trial.commit_sha!r} (§1.4)"
   211	                )
   212	
   213	    def _require_no_manifest_collision(
   214	        self, trial: Trial, manifest_path: str
   215	    ) -> None:
   216	        assert trial.commit_sha is not None
   217	        if self._repo.tree_entry_exists(trial.commit_sha, manifest_path):
   218	            raise EvalManifestPathCollision(
   219	                f"trial {trial.trial_id!r} worker tree already contains "
   220	                f"{manifest_path!r} (§3.2 — integrator MUST NOT overwrite)"
   221	            )
   222	
   223	    # ------------------------------------------------------------------
   224	    # Squash construction
   225	    # ------------------------------------------------------------------
   226	
   227	    def _build_squash_tree(self, trial: Trial, manifest_path: str) -> str:
   228	        assert trial.commit_sha is not None
   229	        try:
   230	            manifest_bytes = build_manifest(trial)
   231	        except ManifestFieldMissing as exc:
   232	            raise NotReadyForIntegration(
   233	                f"trial {trial.trial_id!r}: {exc}"
   234	            ) from exc
   235	        blob_sha = self._repo.write_blob(manifest_bytes)
   236	        worker_tree = self._repo.commit_tree_sha(trial.commit_sha)
   237	        return self._repo.write_tree_with_file(
   238	            worker_tree, manifest_path, blob_sha, mode="100644"
   239	        )
   240	
   241	    def _commit_squash(self, trial: Trial, slug: str, tree_sha: str) -> str:
   242	        message = f"trial: {trial.trial_id} {slug}\n"
   243	        now = self._clock()
   244	        stamp = _rfc3339(now)
   245	        return self._repo.commit_tree(
   246	            tree_sha,
   247	            parents=list(trial.parent_commits),
   248	            message=message,
   249	            author=self._author,
   250	            committer=self._committer,
   251	            author_date=stamp,
   252	            committer_date=stamp,
   253	        )
   254	
   255	    # ------------------------------------------------------------------
   256	    # §5.3 idempotency
   257	    # ------------------------------------------------------------------
   258	
   259	    def _check_idempotent(
   260	        self, trial: Trial, branch: str, branch_ref: str
   261	    ) -> IntegrationResult:
   262	        recorded = trial.trial_commit_sha
   263	        assert recorded is not None
   264	        ref_tip = self._repo.resolve_ref(branch_ref)
   265	        if ref_tip is None or ref_tip != recorded:
   266	            raise CorruptIntegrationState(
   267	                f"trial {trial.trial_id!r} has trial_commit_sha={recorded!r} "
   268	                f"but {branch_ref!r} resolves to {ref_tip!r} (§5.3)"
   269	            )
   270	
   271	        manifest_path = _manifest_path(trial.trial_id)
   272	        try:
   273	            expected = build_manifest(trial)
   274	        except ManifestFieldMissing as exc:
   275	            raise CorruptIntegrationState(
   276	                f"trial {trial.trial_id!r} is integrated but cannot "
   277	                f"re-derive manifest: {exc}"
   278	            ) from exc
   279	
   280	        # The committed trial commit + manifest blob must still be
   281	        # present; the ref we just confirmed proves reachability.
   282	        try:
   283	            actual_tree = self._repo.commit_tree_sha(recorded)
   284	            actual_blob_entry = _lookup_tree_entry(
   285	                self._repo, actual_tree, manifest_path
   286	            )
   287	            actual_bytes = self._repo.read_blob(actual_blob_entry)
   288	        except GitError as exc:
   289	            raise CorruptIntegrationState(
   290	                f"trial {trial.trial_id!r} is integrated but committed "
   291	                f"manifest read failed: {exc}"
   292	            ) from exc
   293	
   294	        if actual_bytes != expected:
   295	            raise CorruptIntegrationState(
   296	                f"trial {trial.trial_id!r} integrated manifest does not match "
   297	                f"current trial state (§5.3)"
   298	            )
   299	
   300	        # The §3.2 tree-shape check depends on the worker-branch tip
   301	        # commit still being in the object DB. §1.3 permits deployments
   302	        # to delete work/* branches eagerly after promotion, and
   303	        # `git gc --prune=now` may then remove the worker commit
   304	        # object entirely. If so, we cannot re-derive the expected
   305	        # squash tree; we've already verified the ref + manifest bytes
   306	        # above, which is the strongest replay-safety check we can
   307	        # offer without the worker commit. Tree-shape re-verification
   308	        # is best-effort.
   309	        assert trial.commit_sha is not None
   310	        if self._repo.commit_exists(trial.commit_sha):
   311	            self._require_squash_tree_matches(
   312	                trial.commit_sha, actual_tree, actual_blob_entry, manifest_path
   313	            )
   314	
   315	        return IntegrationResult(
   316	            trial_id=trial.trial_id,
   317	            trial_commit_sha=recorded,
   318	            branch=branch,
   319	            already_integrated=True,
   320	        )
   321	
   322	    def _require_squash_tree_matches(
   323	        self,
   324	        worker_commit_sha: str,
   325	        actual_tree: str,
   326	        actual_blob_entry: str,
   327	        manifest_path: str,
   328	    ) -> None:
   329	        """Verify ``actual_tree`` equals worker-tip tree + only the manifest.
   330	
   331	        Re-derives the expected tree from the worker branch tip and the
   332	        committed manifest blob, then compares tree SHAs. Equality
   333	        implies the §3.2 rule holds — only the manifest path differs.
   334	        Callers must have already verified ``worker_commit_sha`` is
   335	        still reachable in the object DB.
   336	        """
   337	        worker_tree = self._repo.commit_tree_sha(worker_commit_sha)
   338	        expected_tree = self._repo.write_tree_with_file(
   339	            worker_tree, manifest_path, actual_blob_entry, mode="100644"
   340	        )
   341	        if expected_tree != actual_tree:
   342	            raise CorruptIntegrationState(
   343	                f"trial {worker_commit_sha!r} integrated tree does not match "
   344	                f"worker-tip tree plus manifest (§3.2 / §5.3)"
   345	            )
   346	
   347	
   348	def _manifest_path(trial_id: str) -> str:
   349	    return f".eden/trials/{trial_id}/eval.json"
   350	
   351	
   352	def _default_clock() -> datetime:
   353	    return datetime.now(tz=UTC)
   354	
   355	
   356	def _rfc3339(dt: datetime) -> str:
   357	    if dt.tzinfo is None:
   358	        dt = dt.replace(tzinfo=UTC)
   359	    return dt.strftime("%Y-%m-%dT%H:%M:%S%z")
   360	
   361	
   362	def _lookup_tree_entry(repo: GitRepo, tree_sha: str, path: str) -> str:
   363	    """Resolve ``path`` under ``tree_sha`` to the blob SHA at that path."""
   364	    for entry in repo.ls_tree(tree_sha, path, recursive=True):
   365	        if entry.path == path and entry.type == "blob":
   366	            return entry.sha
   367	    raise GitError(
   368	        ["ls-tree", "-r", tree_sha, "--", path],
   369	        0,
   370	        "",
   371	        f"path {path!r} not found in tree {tree_sha!r}",
   372	    )

