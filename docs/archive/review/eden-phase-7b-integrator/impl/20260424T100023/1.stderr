   683	
   684	class TestAtomicRollback:
   685	    def test_store_failure_rolls_back_ref(
   686	        self,
   687	        integrator: Integrator,
   688	        store: Store,
   689	        repo: GitRepo,
   690	        seed_sha: str,
   691	        monkeypatch: pytest.MonkeyPatch,
   692	    ) -> None:
   693	        commit = _make_work_branch(repo, branch="work/tr-1", parent=seed_sha)
   694	        _seed_success_trial(
   695	            store,
   696	            trial_id="tr-1",
   697	            proposal_id="p-1",
   698	            slug="speedup",
   699	            parent=seed_sha,
   700	            branch="work/tr-1",
   701	            commit_sha=commit,
   702	        )
   703	
   704	        boom = RuntimeError("store disk full")
   705	
   706	        def _explode(*_a: Any, **_kw: Any) -> None:
   707	            raise boom
   708	
   709	        monkeypatch.setattr(store, "integrate_trial", _explode)
   710	
   711	        with pytest.raises(RuntimeError) as exc_info:
   712	            integrator.integrate("tr-1")
   713	        assert exc_info.value is boom
   714	        # Ref compensated away.
   715	        assert repo.resolve_ref("refs/heads/trial/tr-1-speedup") is None
   716	        # Field still absent.
   717	        assert store.read_trial("tr-1").trial_commit_sha is None
   718	        # No trial.integrated event.
   719	        assert [e for e in store.events() if e.type == "trial.integrated"] == []
