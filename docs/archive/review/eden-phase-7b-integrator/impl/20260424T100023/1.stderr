   781	            store=store, repo=repo, author=AUTHOR, clock=lambda: FIXED_CLOCK
   782	        )
   783	        result = integ.integrate("tr-1")
   784	        header = repo.commit_message(result.trial_commit_sha)  # full message
   785	        # commit_tree stamps via GIT_AUTHOR_* / GIT_COMMITTER_* env vars;
   786	        # asserting identity requires cat-file -p.
   787	        raw = _raw_commit(repo, result.trial_commit_sha)
   788	        assert f"author {AUTHOR.name} <{AUTHOR.email}>" in raw
   789	        assert f"committer {AUTHOR.name} <{AUTHOR.email}>" in raw
   790	        assert "trial: tr-1 speedup" in header
   791	
   792	    def test_explicit_committer_used(
   793	        self,
   794	        store: Store,
   795	        repo: GitRepo,
   796	        seed_sha: str,
   797	    ) -> None:
   798	        commit = _make_work_branch(repo, branch="work/tr-1", parent=seed_sha)
   799	        _seed_success_trial(
