   311	def _retry_submit(
   312	    store: Any, task_id: str, token: str, submission: PlanSubmission
   313	) -> tuple[bool, str | None]:
   314	    """Resubmit on transport-only failures up to 3 times.
   315	
   316	    Per chapter 07 Â§2.4 / Â§8.1, a content-equivalent resubmit is
   317	    idempotent. Returns ``(ok, banner)``:
   318	
   319	    - ``(True, None)`` on success (including a same-content
   320	      resubmit that returns 200).
   321	    - ``(False, banner)`` on a definitive divergent response or
   322	      after 3 indeterminate failures. ``banner`` is the canonical
   323	      ``eden://error/<name>`` (or a transport summary) suitable for
   324	      surfacing to the user.
   325	
   326	    Exception classification (per
   327	    ``feedback_retry_readback_test_mocks.md`` rule 1):
   328	
   329	    - ``WrongToken``, ``ConflictingResubmission``, and
   330	      ``InvalidPrecondition`` are definitive short-circuits;
   331	      retrying them cannot change the outcome.
   332	    - ``IllegalTransition`` is **not** definitive: it falls
   333	      through to a read-back that distinguishes "we won; the
   334	      orchestrator already terminalized" (success) from "we
   335	      lost; task reclaimed or different submission won"
   336	      (orphan). Treating it as a definitive orphan would
   337	      mis-classify a successful submit whose response was lost.
   338	    - Other exceptions (transport-shaped) are retried with
   339	      backoff; on exhaustion, the read-back resolves.
   340	
   341	    On any definitive failure, the caller renders the orphan page
   342	    rather than a "preserve input + claim again" form. Reasoning:
   343	    by the time Phase 3 runs, Phase 1 has already created
   344	    proposals and Phase 2 has marked them ready. The work product
   345	    that needs operator recovery is the orphaned proposals
   346	    themselves (whose IDs the orphan page lists), not the form
   347	    inputs. Form-input preservation applies to *validation*
   348	    errors, where no store mutation has happened yet.
   349	    """
   350	    last_exc: BaseException | None = None
   351	    needs_readback = False
   352	    for delay in _RETRY_DELAYS_S:
   353	        try:
   354	            store.submit(task_id, token, submission)
   355	            return True, None
   356	        except (WrongToken, ConflictingResubmission, InvalidPrecondition) as exc:
   357	            return False, _wire_error_banner(exc)
   358	        except IllegalTransition as exc:
   359	            last_exc = exc
   360	            needs_readback = True
   361	            break
   362	        except Exception as exc:  # noqa: BLE001 â€” transport-shaped or unknown
   363	            last_exc = exc
   364	            time.sleep(delay)
   365	
   366	    # Either retries exhausted with transport-shape failures, or
   367	    # IllegalTransition broke us out of the loop. Either way,
   368	    # read-back disambiguates: an equivalent prior submission means
   369	    # we won and the response was lost in transit; anything else is
   370	    # orphan with a state-specific banner.
   371	    if needs_readback or last_exc is not None:
   372	        return _readback(
   373	            store=store,
   374	            task_id=task_id,
   375	            token=token,
   376	            submission=submission,
   377	            last_exc=last_exc,
   378	        )
   379	
   380	    return True, None
   381	
