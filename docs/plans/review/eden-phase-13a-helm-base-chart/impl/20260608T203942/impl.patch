diff --git a/reference/helm/eden/templates/postgres-statefulset.yaml b/reference/helm/eden/templates/postgres-statefulset.yaml
new file mode 100644
index 0000000..c441b80
--- /dev/null
+++ b/reference/helm/eden/templates/postgres-statefulset.yaml
@@ -0,0 +1,91 @@
+{{- $fullName := include "eden.fullname" . }}
+apiVersion: apps/v1
+kind: StatefulSet
+metadata:
+  name: {{ $fullName }}-postgres
+  labels:
+    {{- include "eden.componentLabels" (dict "ctx" . "component" "postgres") | nindent 4 }}
+spec:
+  serviceName: {{ $fullName }}-postgres
+  replicas: 1
+  selector:
+    matchLabels:
+      {{- include "eden.componentSelectorLabels" (dict "ctx" . "component" "postgres") | nindent 6 }}
+  template:
+    metadata:
+      annotations:
+        {{- include "eden.rolloutChecksums" . | nindent 8 }}
+      labels:
+        {{- include "eden.componentLabels" (dict "ctx" . "component" "postgres") | nindent 8 }}
+    spec:
+      {{- include "eden.imagePullSecrets" . | nindent 6 }}
+      {{- with .Values.nodeSelector }}
+      nodeSelector: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      {{- with .Values.tolerations }}
+      tolerations: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      {{- with .Values.affinity }}
+      affinity: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      containers:
+        - name: postgres
+          image: {{ .Values.postgres.image | quote }}
+          imagePullPolicy: {{ .Values.postgres.pullPolicy }}
+          ports:
+            - name: postgres
+              containerPort: 5432
+          env:
+            - name: POSTGRES_DB
+              value: {{ .Values.postgres.database | quote }}
+            - name: POSTGRES_USER
+              value: {{ .Values.postgres.user | quote }}
+            - name: POSTGRES_DB_CONTROL_PLANE
+              value: {{ .Values.postgres.controlPlaneDatabase | quote }}
+            - name: POSTGRES_PASSWORD
+              valueFrom:
+                secretKeyRef:
+                  name: {{ include "eden.secretName" . }}
+                  key: POSTGRES_PASSWORD
+            # Init hook + data live under PGDATA; point PGDATA at a subdir so
+            # the volume root (which may carry lost+found) doesn't trip initdb.
+            - name: PGDATA
+              value: /var/lib/postgresql/data/pgdata
+          readinessProbe:
+            exec:
+              command: ["pg_isready", "-U", {{ .Values.postgres.user | quote }}, "-d", {{ .Values.postgres.database | quote }}]
+            initialDelaySeconds: 5
+            periodSeconds: 5
+            timeoutSeconds: 3
+            failureThreshold: 10
+          livenessProbe:
+            exec:
+              command: ["pg_isready", "-U", {{ .Values.postgres.user | quote }}, "-d", {{ .Values.postgres.database | quote }}]
+            initialDelaySeconds: 15
+            periodSeconds: 10
+            timeoutSeconds: 3
+            failureThreshold: 6
+          volumeMounts:
+            - name: data
+              mountPath: /var/lib/postgresql/data
+            - name: init
+              mountPath: /docker-entrypoint-initdb.d
+          {{- with .Values.postgres.resources }}
+          resources: {{- toYaml . | nindent 12 }}
+          {{- end }}
+      volumes:
+        - name: init
+          configMap:
+            name: {{ $fullName }}-postgres-init
+            defaultMode: 0555
+  volumeClaimTemplates:
+    - metadata:
+        name: data
+      spec:
+        accessModes: ["ReadWriteOnce"]
+        {{- if .Values.storage.className }}
+        storageClassName: {{ .Values.storage.className | quote }}
+        {{- end }}
+        resources:
+          requests:
+            storage: {{ .Values.storage.postgresSize | quote }}
diff --git a/reference/helm/eden/templates/secret.yaml b/reference/helm/eden/templates/secret.yaml
new file mode 100644
index 0000000..eebd3bf
--- /dev/null
+++ b/reference/helm/eden/templates/secret.yaml
@@ -0,0 +1,36 @@
+{{- /*
+NOTE: this chart-managed Secret is deleted by `helm uninstall`, but the
+StatefulSet PVCs (Postgres data, …) are intentionally RETAINED. A reinstall
+then regenerates secrets while the Postgres data dir still holds the OLD role
+password, so the rendered DSNs can no longer authenticate. For any deployment
+you intend to uninstall + reinstall (rather than fully tearing down PVCs), use
+secrets.existingSecret so the credentials outlive the release. See
+docs/deployment/helm.md §5 "PVC retention".
+*/ -}}
+{{- if not .Values.secrets.existingSecret }}
+{{- $fullName := include "eden.fullname" . }}
+{{- $pw := required "secrets.postgresPassword is required (or set secrets.existingSecret)" .Values.secrets.postgresPassword }}
+{{- $roPw := required "secrets.readonlyPassword is required (or set secrets.existingSecret)" .Values.secrets.readonlyPassword }}
+{{- $pgHost := printf "%s-postgres:5432" $fullName }}
+apiVersion: v1
+kind: Secret
+metadata:
+  name: {{ $fullName }}-secrets
+  labels:
+    {{- include "eden.labels" . | nindent 4 }}
+type: Opaque
+stringData:
+  EDEN_ADMIN_TOKEN: {{ required "secrets.adminToken is required (or set secrets.existingSecret)" .Values.secrets.adminToken | quote }}
+  EDEN_SESSION_SECRET: {{ required "secrets.sessionSecret is required (or set secrets.existingSecret)" .Values.secrets.sessionSecret | quote }}
+  EDEN_READONLY_PASSWORD: {{ $roPw | quote }}
+  POSTGRES_PASSWORD: {{ $pw | quote }}
+  FORGEJO_REMOTE_PASSWORD: {{ required "secrets.forgejoRemotePassword is required (or set secrets.existingSecret)" .Values.secrets.forgejoRemotePassword | quote }}
+  FORGEJO_SECRET_KEY: {{ required "secrets.forgejoSecretKey is required (or set secrets.existingSecret)" .Values.secrets.forgejoSecretKey | quote }}
+  FORGEJO_INTERNAL_TOKEN: {{ required "secrets.forgejoInternalToken is required (or set secrets.existingSecret)" .Values.secrets.forgejoInternalToken | quote }}
+  # Derived Postgres DSNs. The password is interpolated verbatim, so it MUST be
+  # URL-safe (the setup script generates hex; supply pre-encoded DSNs via
+  # existingSecret if you use a password with reserved URI characters).
+  EDEN_STORE_URL: {{ printf "postgresql://%s:%s@%s/%s" .Values.postgres.user $pw $pgHost .Values.postgres.database | quote }}
+  EDEN_READONLY_STORE_URL: {{ printf "postgresql://eden_readonly:%s@%s/%s" $roPw $pgHost .Values.postgres.database | quote }}
+  EDEN_CONTROL_PLANE_STORE_URL: {{ printf "postgresql://%s:%s@%s/%s" .Values.postgres.user $pw $pgHost .Values.postgres.controlPlaneDatabase | quote }}
+{{- end }}
diff --git a/reference/helm/eden/templates/task-store-server-deployment.yaml b/reference/helm/eden/templates/task-store-server-deployment.yaml
new file mode 100644
index 0000000..c4f9e69
--- /dev/null
+++ b/reference/helm/eden/templates/task-store-server-deployment.yaml
@@ -0,0 +1,106 @@
+{{- if eq (include "eden.appEnabled" .) "true" }}
+{{- $fullName := include "eden.fullname" . }}
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ $fullName }}-task-store-server
+  labels:
+    {{- include "eden.componentLabels" (dict "ctx" . "component" "task-store-server") | nindent 4 }}
+spec:
+  replicas: {{ .Values.replicas.taskStoreServer }}
+  selector:
+    matchLabels:
+      {{- include "eden.componentSelectorLabels" (dict "ctx" . "component" "task-store-server") | nindent 6 }}
+  template:
+    metadata:
+      annotations:
+        {{- include "eden.rolloutChecksums" . | nindent 8 }}
+      labels:
+        {{- include "eden.componentLabels" (dict "ctx" . "component" "task-store-server") | nindent 8 }}
+    spec:
+      {{- include "eden.imagePullSecrets" . | nindent 6 }}
+      {{- with .Values.nodeSelector }}
+      nodeSelector: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      {{- with .Values.tolerations }}
+      tolerations: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      {{- with .Values.affinity }}
+      affinity: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      containers:
+        - name: task-store-server
+          image: {{ include "eden.image" . | quote }}
+          imagePullPolicy: {{ .Values.image.pullPolicy }}
+          envFrom:
+            - secretRef:
+                name: {{ include "eden.secretName" . }}
+          ports:
+            - name: http
+              containerPort: 8080
+          args:
+            - python
+            - -m
+            - eden_task_store_server
+            - --store-url
+            - $(EDEN_STORE_URL)
+            - --experiment-id
+            - {{ required "experiment.id is required" .Values.experiment.id | quote }}
+            - --experiment-config
+            - /etc/eden/experiment-config.yaml
+            - --base-commit-sha
+            - {{ .Values.experiment.baseCommitSha | quote }}
+            - --admin-token
+            - $(EDEN_ADMIN_TOKEN)
+            - --host
+            - 0.0.0.0
+            - --port
+            - "8080"
+            - --log-level
+            - info
+          # The task-store-server has no /healthz route and its experiment-
+          # scoped endpoints require an auth header that probe exec commands
+          # cannot supply ($(VAR) is not expanded in probes). A TCP probe on
+          # the bound port is sufficient for readiness ordering — uvicorn
+          # binds 8080 only once the app is constructed.
+          readinessProbe:
+            tcpSocket:
+              port: http
+            initialDelaySeconds: 5
+            periodSeconds: 5
+            timeoutSeconds: 3
+            failureThreshold: 30
+          livenessProbe:
+            tcpSocket:
+              port: http
+            initialDelaySeconds: 15
+            periodSeconds: 10
+            timeoutSeconds: 3
+            failureThreshold: 6
+          volumeMounts:
+            - name: experiment-config
+              mountPath: /etc/eden/experiment-config.yaml
+              subPath: experiment-config.yaml
+          {{- with .Values.resources }}
+          resources: {{- toYaml . | nindent 12 }}
+          {{- end }}
+      volumes:
+        - name: experiment-config
+          configMap:
+            name: {{ $fullName }}-experiment-config
+---
+apiVersion: v1
+kind: Service
+metadata:
+  name: {{ $fullName }}-task-store-server
+  labels:
+    {{- include "eden.componentLabels" (dict "ctx" . "component" "task-store-server") | nindent 4 }}
+spec:
+  type: ClusterIP
+  selector:
+    {{- include "eden.componentSelectorLabels" (dict "ctx" . "component" "task-store-server") | nindent 4 }}
+  ports:
+    - name: http
+      port: 8080
+      targetPort: http
+{{- end }}
diff --git a/reference/helm/eden/templates/tests/test-connection.yaml b/reference/helm/eden/templates/tests/test-connection.yaml
