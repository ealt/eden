+    {{- include "eden.componentLabels" (dict "ctx" . "component" "ideator-host") | nindent 4 }}
+spec:
+  replicas: {{ .Values.replicas.ideatorHost }}
+  # Recreate (not RollingUpdate): the ideator uses a single minted --worker-id,
+  # so a rolling update's overlapping old+new pods would race on the same
+  # worker credential. Recreate terminates the old pod before starting the new.
+  strategy:
+    type: Recreate
+  selector:
+    matchLabels:
+      {{- include "eden.componentSelectorLabels" (dict "ctx" . "component" "ideator-host") | nindent 6 }}
+  template:
+    metadata:
+      annotations:
+        {{- include "eden.rolloutChecksums" . | nindent 8 }}
+        checksum/identity: {{ $id.token | sha256sum }}
+      labels:
+        {{- include "eden.componentLabels" (dict "ctx" . "component" "ideator-host") | nindent 8 }}
+    spec:
+      {{- include "eden.imagePullSecrets" . | nindent 6 }}
+      # fsGroup makes the credentials emptyDir group-writable for the rootless
+      # (uid/gid 1000) image's credential-bootstrap writes.
+      securityContext:
+        fsGroup: 1000
+      {{- with .Values.nodeSelector }}
+      nodeSelector: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      {{- with .Values.tolerations }}
+      tolerations: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      {{- with .Values.affinity }}
+      affinity: {{- toYaml . | nindent 8 }}
+      {{- end }}
+      initContainers:
+        {{- include "eden.identityInitContainer" (dict "ctx" . "workerId" $id.workerId "component" "ideator-host") | nindent 8 }}
+      containers:
+        - name: ideator-host
+          image: {{ include "eden.image" . | quote }}
+          imagePullPolicy: {{ .Values.image.pullPolicy }}
+          envFrom:
+            - secretRef:
+                name: {{ include "eden.secretName" . }}
+          args:
+            - python
+            - -m
+            - eden_ideator_host
+            - --task-store-url
+            - {{ include "eden.taskStoreUrl" . | quote }}
+            - --experiment-id
+            - {{ required "experiment.id is required" .Values.experiment.id | quote }}
+            - --admin-token
+            - $(EDEN_ADMIN_TOKEN)
+            - --worker-id
+            - {{ $id.workerId | quote }}
+            - --mode
+            - {{ .Values.config.workerMode | quote }}
+            - --base-commit-sha
+            - {{ .Values.experiment.baseCommitSha | quote }}
+            - --poll-interval
+            - {{ .Values.config.pollIntervalSeconds | quote }}
+            - --log-level
+            - info
+          volumeMounts:
+            - name: credentials
+              mountPath: /var/lib/eden/credentials
+          {{- with .Values.resources }}
+          resources: {{- toYaml . | nindent 12 }}
+          {{- end }}
+      volumes:
+        {{- include "eden.identityVolumes" (dict "ctx" . "component" "ideator-host") | nindent 8 }}
+{{- end }}
diff --git a/reference/helm/eden/templates/identity-secrets.yaml b/reference/helm/eden/templates/identity-secrets.yaml
new file mode 100644
index 0000000..87306a3
--- /dev/null
+++ b/reference/helm/eden/templates/identity-secrets.yaml
@@ -0,0 +1,38 @@
+{{- /*
+Per-service identity Secrets (#128 opaque-id model). setup-experiment-helm.sh
+mints one worker per service against the task-store-server (POST {"name": ...}),
+captures the minted worker_id + one-time registration_token, and re-runs
+`helm upgrade` to fill values.identity.<svc>.{workerId,token}. Each service then
+renders a Secret here carrying just the token; an initContainer installs it at
+/var/lib/eden/credentials/<workerId>.token so the service's startup credential
+bootstrap verifies it via /whoami (no admin reissue needed).
+
+One Secret per identity-consuming service so each pod mounts only its own token.
+Each renders only once its workerId AND token are set — the same gate that holds
+the app tier back until identities are provisioned. With secrets.existingSecret
+the OTHER chart-managed Secret is suppressed, but these identity Secrets are
+always chart-managed (the tokens are minted at bootstrap time, not pre-known).
+*/ -}}
+{{- $fullName := include "eden.fullname" . -}}
+{{- $services := list
+    (dict "key" "orchestrator"  "component" "orchestrator")
+    (dict "key" "webUi"         "component" "web-ui")
+    (dict "key" "ideatorHost"   "component" "ideator-host")
+    (dict "key" "executorHost"  "component" "executor-host")
+    (dict "key" "evaluatorHost" "component" "evaluator-host")
+-}}
+{{- range $svc := $services }}
+{{- $id := index $.Values.identity $svc.key }}
+{{- if and $id.workerId $id.token }}
+---
+apiVersion: v1
+kind: Secret
+metadata:
+  name: {{ $fullName }}-{{ $svc.component }}-identity
+  labels:
+    {{- include "eden.componentLabels" (dict "ctx" $ "component" $svc.component) | nindent 4 }}
+type: Opaque
+stringData:
+  token: {{ $id.token | quote }}
+{{- end }}
+{{- end }}
