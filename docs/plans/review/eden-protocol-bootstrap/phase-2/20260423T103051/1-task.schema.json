{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EDEN task",
  "description": "A unit of work dispatched to a role. The task object carries kind, state, payload, and optional claim; its state-machine semantics are defined in 04-task-protocol.md.",
  "type": "object",
  "required": ["task_id", "kind", "state", "payload", "created_at", "updated_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["plan", "implement", "evaluate"]
    },
    "state": {
      "type": "string",
      "enum": ["pending", "claimed", "submitted", "completed", "failed"]
    },
    "payload": {
      "type": "object"
    },
    "claim": {
      "type": "object",
      "required": ["token", "worker_id", "claimed_at"],
      "properties": {
        "token": {
          "type": "string",
          "minLength": 1
        },
        "worker_id": {
          "type": "string",
          "minLength": 1
        },
        "claimed_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  },
  "allOf": [
    {
      "if": {"properties": {"kind": {"const": "plan"}}, "required": ["kind"]},
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["experiment_id"],
            "properties": {
              "experiment_id": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"kind": {"const": "implement"}}, "required": ["kind"]},
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["proposal_id"],
            "properties": {
              "proposal_id": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"kind": {"const": "evaluate"}}, "required": ["kind"]},
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["trial_id"],
            "properties": {
              "trial_id": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"state": {"enum": ["claimed", "submitted"]}},
        "required": ["state"]
      },
      "then": {"required": ["claim"]},
      "else": {"not": {"required": ["claim"]}}
    }
  ]
}
